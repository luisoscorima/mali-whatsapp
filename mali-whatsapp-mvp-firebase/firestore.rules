rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: campaigns
    // Document ID: campaignId (auto-generated)
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - status: string (required, enum: ['draft', 'sending', 'completed', 'failed'])
    //   - createdAt: timestamp (required)
    //   - totalMessages: number (required, >= 0)
    //   - sentCount: number (required, >= 0)
    //   - deliveredCount: number (required, >= 0)
    //   - readCount: number (required, >= 0)
    //   - failedCount: number (required, >= 0)
    //   - templateName: string (required)
    //   - authorUid: string (required)
    //
    // Collection: campaigns/{campaignId}/recipients
    // Document ID: recipientId (auto-generated)
    // Fields:
    //   - campaignId: string (required)
    //   - phoneNumber: string (required, regex: ^\d{10,15}$)
    //   - name: string (optional)
    //   - status: string (required, enum: ['pending', 'sent', 'delivered', 'read', 'failed'])
    //   - errorMessage: string (optional)
    //   - sentAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function uidUnchanged() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidCampaign(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.status in ['draft', 'sending', 'completed', 'failed'] &&
             data.totalMessages is number && data.totalMessages >= 0 &&
             data.sentCount is number && data.sentCount >= 0 &&
             data.deliveredCount is number && data.deliveredCount >= 0 &&
             data.readCount is number && data.readCount >= 0 &&
             data.failedCount is number && data.failedCount >= 0 &&
             data.templateName is string &&
             data.authorUid is string;
    }

    function isValidRecipient(data) {
      return data.campaignId is string &&
             data.phoneNumber is string && data.phoneNumber.matches("^\\d{10,15}$") &&
             data.status in ['pending', 'sent', 'delivered', 'read', 'failed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /campaigns/{campaignId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                      hasRequiredFields(['name', 'status', 'createdAt', 'authorUid']) &&
                      isValidCampaign(request.resource.data) &&
                      request.resource.data.authorUid == request.auth.uid;
      allow update: if isDocOwner() && 
                      isValidCampaign(request.resource.data) &&
                      request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isDocOwner();

      match /recipients/{recipientId} {
        allow read: if isAuthenticated(); // Scoped by parent campaign ownership in practice
        allow create: if isAuthenticated() && isValidRecipient(request.resource.data);
        allow update: if isAuthenticated() && isValidRecipient(request.resource.data);
        allow delete: if isAuthenticated();
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
