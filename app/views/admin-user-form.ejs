<%- include('layouts/inbox-shell-start', {
  pageTitle: (mode === 'create' ? 'Nuevo usuario' : 'Editar usuario') + ' · MALI WhatsApp',
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav: typeof activeNav !== 'undefined' ? activeNav : 'admin-users',
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: 'conversations-inbox--detail',
  extraHeadScripts: null
}) %>
<%- include('partials/admin-sidebar', { basePath, adminSection: 'users' }) %>
<section class="inbox-main" aria-label="Usuario">
  <%- include('partials/admin-mobile-nav', { basePath, adminSection: 'users' }) %>
  <div class="inbox-chat-header inbox-chat-header--static">
    <h1 class="inbox-chat-heading"><%= mode === 'create' ? 'Nuevo usuario' : 'Editar usuario' %></h1>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <div class="card">
      <% if (formError) { %>
      <p class="inline-warn"><%= formError %></p>
      <% } %>

      <% const u = userRow || {}; %>
      <form method="post" action="<%= mode === 'create' ? basePath + '/admin/users' : basePath + '/admin/users/' + u.id %>" class="form-grid tight">
        <% if (mode === 'create') { %>
        <label class="field">
          <span class="field-label">Correo (@mali.pe)</span>
          <input type="email" name="email" value="<%= u.email || '' %>" required autocomplete="username" />
        </label>
        <label class="field">
          <span class="field-label">Contraseña</span>
          <input type="password" name="password" required minlength="6" autocomplete="new-password" />
        </label>
        <label class="field field--checkbox">
          <input type="checkbox" name="must_change_password" value="1" <%= u.must_change_password ? 'checked' : '' %> />
          <span class="field-label">Forzar cambio de contraseña al iniciar sesión</span>
        </label>
        <% } else { %>
        <label class="field">
          <span class="field-label">Correo</span>
          <input type="text" value="<%= u.email %>" disabled />
        </label>
        <label class="field">
          <span class="field-label">Nueva contraseña (opcional)</span>
          <input type="password" name="password" minlength="6" autocomplete="new-password" placeholder="Dejar vacío para no cambiar" />
        </label>
        <label class="field field--checkbox">
          <input type="checkbox" name="must_change_password" value="1" <%= u.must_change_password ? 'checked' : '' %> />
          <span class="field-label">Exigir cambio de contraseña en el próximo inicio de sesión</span>
        </label>
        <p class="muted card-lead" style="margin:0">Si asignas una nueva contraseña arriba, no se exigirá cambio (queda desmarcado al guardar).</p>
        <% } %>

        <label class="field">
          <span class="field-label">Área</span>
          <select name="area" required>
            <option value="ti" <%= (u.area || 'ti') === 'ti' ? 'selected' : '' %>>TI (dev)</option>
            <option value="pam" <%= u.area === 'pam' ? 'selected' : '' %>>PAM</option>
            <option value="patronato" <%= u.area === 'patronato' ? 'selected' : '' %>>Patronato</option>
            <option value="educacion" <%= u.area === 'educacion' ? 'selected' : '' %>>Educación</option>
          </select>
        </label>

        <label class="field field--checkbox">
          <input type="checkbox" name="is_master" value="1" <%= u.is_master ? 'checked' : '' %> />
          <span class="field-label">Usuario master</span>
        </label>

        <p class="field-label" style="margin: 0.5rem 0 0">Módulos de Ajustes</p>
        <label class="field field--checkbox">
          <input type="checkbox" name="can_view_integration" value="1" <%= u.can_view_integration ? 'checked' : '' %> />
          <span class="field-label">Integración (webhook y documentación)</span>
        </label>
        <label class="field field--checkbox">
          <input type="checkbox" name="can_edit_ai_prompt" value="1" <%= u.can_edit_ai_prompt ? 'checked' : '' %> />
          <span class="field-label">Respuesta automática (IA)</span>
        </label>
        <label class="field field--checkbox">
          <input type="checkbox" name="can_edit_business_hours" value="1" <%= u.can_edit_business_hours ? 'checked' : '' %> />
          <span class="field-label">Fuera de horario</span>
        </label>
        <label class="field field--checkbox">
          <input type="checkbox" name="can_view_audit_logs" value="1" <%= u.can_view_audit_logs ? 'checked' : '' %> />
          <span class="field-label">Bitácora de auditoría (solo su área)</span>
        </label>
        <label class="field field--checkbox">
          <input type="checkbox" name="can_view_reports" value="1" <%= u.can_view_reports ? 'checked' : '' %> />
          <span class="field-label">Reportería (comunicaciones por contacto)</span>
        </label>

        <div class="field-row">
          <button type="submit" class="primary">Guardar</button>
          <a class="secondary small-btn" href="<%= basePath %>/admin/users">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
