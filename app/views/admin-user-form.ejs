<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= mode === 'create' ? 'Nuevo usuario' : 'Editar usuario' %> · MALI WhatsApp</title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
  </head>
  <body>
    <div class="app-shell">
      <%- include('partials/sidebar-nav', { basePath, appBaseUrl, activeNav, showAdminNav }) %>

      <main class="main-panel">
        <header class="top-bar">
          <%- include('partials/top-bar-actions', { basePath, areaLabel, requireAuth, currentUser }) %>
        </header>

        <section class="content-section is-active">
          <div class="card">
            <h1 class="card-title"><%= mode === 'create' ? 'Nuevo usuario' : 'Editar usuario' %></h1>
            <% if (formError) { %>
            <p class="inline-warn"><%= formError %></p>
            <% } %>

            <% const u = userRow || {}; %>
            <form method="post" action="<%= mode === 'create' ? basePath + '/admin/users' : basePath + '/admin/users/' + u.id %>" class="form-grid tight">
              <% if (mode === 'create') { %>
              <label class="field">
                <span class="field-label">Correo (@mali.pe)</span>
                <input type="email" name="email" value="<%= u.email || '' %>" required autocomplete="username" />
              </label>
              <label class="field">
                <span class="field-label">Contraseña</span>
                <input type="password" name="password" required minlength="6" autocomplete="new-password" />
              </label>
              <% } else { %>
              <label class="field">
                <span class="field-label">Correo</span>
                <input type="text" value="<%= u.email %>" disabled />
              </label>
              <label class="field">
                <span class="field-label">Nueva contraseña (opcional)</span>
                <input type="password" name="password" minlength="6" autocomplete="new-password" placeholder="Dejar vacío para no cambiar" />
              </label>
              <% } %>

              <label class="field">
                <span class="field-label">Área</span>
                <select name="area" required>
                  <option value="pam" <%= (u.area || 'pam') === 'pam' ? 'selected' : '' %>>Comercial (PAM)</option>
                  <option value="educacion" <%= u.area === 'educacion' ? 'selected' : '' %>>Educación</option>
                </select>
              </label>

              <label class="field field--checkbox">
                <input type="checkbox" name="is_master" value="1" <%= u.is_master ? 'checked' : '' %> />
                <span class="field-label">Usuario master</span>
              </label>

              <div class="field-row">
                <button type="submit" class="primary">Guardar</button>
                <a class="secondary small-btn" href="<%= basePath %>/admin/users">Cancelar</a>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
