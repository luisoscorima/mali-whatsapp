<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <% if (typeof selectedConversation !== 'undefined' && selectedConversation) { %>Chat · <%= selectedConversation.phone %><% } else { %>Conversaciones<% } %> · MALI WhatsApp
    </title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <link rel="stylesheet" href="<%= basePath %>/css/wa-shell.css" />
    <link rel="stylesheet" href="<%= basePath %>/css/conversations.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
  </head>
  <body class="page-conversations" data-base-path="<%= basePath %>">
    <% const segmentLabel = function (slug) {
      if (!slug) return '';
      const s = segments.find(function (x) { return x.value === slug; });
      return s ? s.label : slug;
    }; %>
    <% const segmentColorKey = function (slug) {
      if (!slug) return 'slate';
      const s = segments.find(function (x) { return x.value === slug; });
      return s ? s.colorKey : 'slate';
    }; %>
    <% const _segF = typeof segmentFilter !== 'undefined' ? segmentFilter : ''; %>
    <% const _chatFConv = typeof chatFilter !== 'undefined' ? chatFilter : 'all'; %>
    <% function conversationListHref(nextSegmentSlug) {
      const sp = new URLSearchParams();
      if (nextSegmentSlug) sp.set('segment', nextSegmentSlug);
      const _sq = typeof searchQ !== 'undefined' ? searchQ : '';
      if (_sq) sp.set('q', _sq);
      if (_chatFConv === 'unread') sp.set('chat', 'unread');
      else if (_chatFConv === 'bot') sp.set('chat', 'bot');
      else if (_chatFConv === 'human') sp.set('chat', 'human');
      const qs = sp.toString();
      return basePath + '/conversations' + (qs ? '?' + qs : '');
    } %>
    <% function inboxInitials(contactName, phone) {
      var n = String(contactName || '').trim();
      if (n) {
        var parts = n.split(/\s+/).filter(function (x) { return x.length; });
        if (parts.length >= 2) {
          return (parts[0].charAt(0) + parts[1].charAt(0)).toUpperCase().slice(0, 2);
        }
        return n.slice(0, 2).toUpperCase();
      }
      var p = String(phone || '').replace(/\D/g, '');
      return p.slice(-2) || '?';
    } %>
    <div
      class="wa-layout wa-layout--inbox inbox-layout-wa conversations-inbox conversations-page <%= typeof selectedConversation !== 'undefined' && selectedConversation ? 'conversations-inbox--detail' : '' %>"
    >
      <%- include('partials/wa-rail', { basePath, appBaseUrl, activeNav, showAdminNav: typeof showAdminNav !== 'undefined' ? showAdminNav : false, requireAuth, currentUser, areaLabel }) %>

      <aside class="inbox-sidebar" aria-label="Lista de conversaciones">
        <div class="inbox-sidebar-header inbox-sidebar-header--with-actions">
          <h2 class="inbox-sidebar-title">Chats</h2>
          <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar chats', refreshAriaLabel: 'Actualizar chats' }) %>
        </div>
        <% const _chatF = typeof chatFilter !== 'undefined' ? chatFilter : 'all'; %>
        <div class="inbox-chat-filter-pills inbox-chat-filter-pills--row" aria-label="Filtrar lista">
          <a
            href="<%= basePath %>/conversations<%= typeof inboxQueryAll !== 'undefined' ? inboxQueryAll : '' %>"
            class="inbox-chat-pill <%= _chatF === 'all' ? 'is-active' : '' %>"
            title="Todos los chats"
          ><span class="inbox-pill-icon" aria-hidden="true">💬</span> Todos</a>
          <a
            href="<%= basePath %>/conversations<%= typeof inboxQueryUnread !== 'undefined' ? inboxQueryUnread : '' %>"
            class="inbox-chat-pill <%= _chatF === 'unread' ? 'is-active' : '' %>"
            title="Solo no leídos"
          ><span class="inbox-pill-icon" aria-hidden="true">●</span> No leídos</a>
          <% if (typeof aiAreaEnabled !== 'undefined' && aiAreaEnabled) { %>
          <a
            href="<%= basePath %>/conversations<%= typeof inboxQueryBot !== 'undefined' ? inboxQueryBot : '' %>"
            class="inbox-chat-pill <%= _chatF === 'bot' ? 'is-active' : '' %>"
            title="Modo Bot"
          ><span class="inbox-pill-icon" aria-hidden="true">🤖</span> Bot</a>
          <a
            href="<%= basePath %>/conversations<%= typeof inboxQueryHuman !== 'undefined' ? inboxQueryHuman : '' %>"
            class="inbox-chat-pill <%= _chatF === 'human' ? 'is-active' : '' %>"
            title="Modo Asesor"
          ><span class="inbox-pill-icon" aria-hidden="true">👤</span> Asesor</a>
          <% } %>
        </div>
        <div class="inbox-chat-filter-pills inbox-chat-filter-pills--row contact-filter-pills conversation-segment-pills" aria-label="Filtrar por segmento">
          <a
            href="<%= conversationListHref('') %>"
            class="inbox-chat-pill contact-filter-pill <%= _segF === '' ? 'is-active' : '' %>"
            <% if (_segF === '') { %>aria-current="page"<% } %>
          >Todos</a>
          <a
            href="<%= conversationListHref('__none__') %>"
            class="inbox-chat-pill contact-filter-pill <%= _segF === '__none__' ? 'is-active' : '' %>"
            data-seg-tone="slate"
            <% if (_segF === '__none__') { %>aria-current="page"<% } %>
          >Sin segmento</a>
          <% segments.forEach(function (seg) { %>
          <a
            href="<%= conversationListHref(seg.value) %>"
            class="inbox-chat-pill contact-filter-pill <%= _segF === seg.value ? 'is-active' : '' %>"
            data-seg-tone="<%= seg.colorKey || 'slate' %>"
            <% if (_segF === seg.value) { %>aria-current="page"<% } %>
          ><%= seg.label %></a>
          <% }); %>
        </div>
        <form class="inbox-filters" method="get" action="<%= basePath %>/conversations">
          <% if (_chatF === 'unread') { %>
            <input type="hidden" name="chat" value="unread" />
          <% } else if (_chatF === 'bot') { %>
            <input type="hidden" name="chat" value="bot" />
          <% } else if (_chatF === 'human') { %>
            <input type="hidden" name="chat" value="human" />
          <% } %>
          <% if (_segF) { %><input type="hidden" name="segment" value="<%= _segF %>" /><% } %>
          <label class="field field--inbox">
            <span class="field-label">Buscar en todos los chats</span>
            <div class="inbox-search-row">
              <input
                type="search"
                name="q"
                value="<%= searchQ %>"
                placeholder="Palabra o frase…"
                autocomplete="off"
                class="inbox-search-input"
              />
              <button type="submit" class="small-btn">Buscar</button>
            </div>
          </label>
        </form>

        <% if (conversations.length === 0) { %>
          <p class="empty-state inbox-empty-list">No hay conversaciones con estos filtros.</p>
        <% } else { %>
          <ul class="inbox-chat-list">
            <% conversations.forEach(function (c) { %>
              <li class="inbox-chat-item <%= c.inbox_unread ? 'inbox-chat-item--unread' : '' %> <%= typeof selectedConversation !== 'undefined' && selectedConversation && selectedConversation.id === c.id ? 'is-active' : '' %>">
                <a class="inbox-chat-link" href="<%= basePath %>/conversations/<%= c.id %><%= inboxQuery %>">
                  <span class="inbox-chat-avatar" aria-hidden="true"><%= inboxInitials(c.contact_name, c.phone) %></span>
                  <span class="inbox-chat-link-main">
                    <span class="inbox-chat-row-top">
                      <span class="inbox-chat-title-group">
                        <span class="inbox-chat-title-line">
                          <span class="inbox-chat-title"><%= c.contact_name || c.phone %></span>
                          <% if (!c.contact_name && c.contact_lead_score) { %>
                            <span class="inbox-chat-lead-stars" aria-label="Calificación <%= c.contact_lead_score %> de 5" title="Calificación del lead">
                              <% for (var si = 1; si <= 5; si++) { %>
                                <span class="inbox-chat-lead-star <%= si <= c.contact_lead_score ? 'is-on' : '' %>">★</span>
                              <% } %>
                            </span>
                          <% } %>
                        </span>
                        <% if (c.conversation_status && String(c.conversation_status).toLowerCase() === 'bot') { %>
                          <span class="inbox-chat-mode-badge" title="Modo Bot">Bot</span>
                        <% } else if (c.conversation_status && String(c.conversation_status).toLowerCase() === 'human') { %>
                          <span class="inbox-chat-mode-badge inbox-chat-mode-badge--human" title="Modo Asesor">Asesor</span>
                        <% } %>
                      </span>
                      <span class="inbox-chat-time-wrap">
                        <% if (c.inbox_unread) { %>
                          <span class="inbox-unread-dot" title="No leído"></span>
                        <% } %>
                        <span class="inbox-chat-time"><%= formatChatListTime(c.last_message_at) %></span>
                      </span>
                    </span>
                    <% if (c.contact_name) { %>
                      <span class="inbox-chat-phone-row">
                        <span class="inbox-chat-phone mono"><%= c.phone %></span>
                        <% if (c.contact_lead_score) { %>
                          <span class="inbox-chat-lead-stars" aria-label="Calificación <%= c.contact_lead_score %> de 5" title="Calificación del lead">
                            <% for (var si2 = 1; si2 <= 5; si2++) { %>
                              <span class="inbox-chat-lead-star <%= si2 <= c.contact_lead_score ? 'is-on' : '' %>">★</span>
                            <% } %>
                          </span>
                        <% } %>
                      </span>
                    <% } %>
                    <span class="inbox-chat-row-mid">
                      <span class="inbox-chat-preview"><%= (c.preview || '—').slice(0, 120) %></span>
                    </span>
                    <% if (c.meta_ctwa_ad_id) { %>
                      <span class="contact-segment-chips" role="group" aria-label="Anuncio Meta">
                        <span class="inbox-chat-segment inbox-chat-segment--ad" title="Lead desde anuncio">
                          <%= (c.meta_ad_display_name || c.meta_ad_source_id || 'Anuncio').slice(0, 24) %>
                        </span>
                      </span>
                    <% } %>
                    <% if (c.contact_segment_slugs && c.contact_segment_slugs.length) { %>
                      <span class="contact-segment-chips" role="group" aria-label="Segmentos">
                        <% c.contact_segment_slugs.forEach(function (slug) { %>
                          <span class="inbox-chat-segment" data-seg-tone="<%= segmentColorKey(slug) %>"><%= segmentLabel(slug) %></span>
                        <% }); %>
                      </span>
                    <% } %>
                  </span>
                </a>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </aside>

      <section class="inbox-main" aria-label="Hilo de mensajes">
        <% if (typeof selectedConversation === 'undefined' || !selectedConversation) { %>
          <div class="inbox-empty-pane" role="status">
            <div class="inbox-empty-hint">
              <span class="inbox-empty-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </span>
              <h2 class="inbox-empty-heading">Conversaciones</h2>
              <p class="inbox-empty-text">Selecciona un chat para ver los mensajes. Las respuestas del cliente se guardan como mensajes entrantes.</p>
            </div>
          </div>
        <% } else { %>
          <% const _convSt = String(selectedConversation.status || 'bot').toLowerCase(); %>
          <% const _aiOn = typeof aiAreaEnabled !== 'undefined' && aiAreaEnabled; %>
          <div class="inbox-chat-header">
            <a class="inbox-back-mobile" href="<%= basePath %>/conversations<%= inboxQuery %>">← Chats</a>
            <% const _contactProfileId = selectedConversation.contact_id; %>
            <% if (_contactProfileId) { %>
            <a
              href="<%= basePath %>/contacts/<%= _contactProfileId %>"
              class="inbox-chat-header-profile inbox-chat-header-profile--link"
              title="Ver perfil del contacto"
              aria-label="Ver perfil del contacto"
            >
            <% } else { %>
            <div class="inbox-chat-header-profile">
            <% } %>
              <span class="inbox-chat-avatar inbox-chat-avatar--header" aria-hidden="true"><%= inboxInitials(contact ? contact.name : '', selectedConversation.phone) %></span>
              <div class="inbox-chat-header-identity">
                <h1 class="inbox-chat-heading"><%= contact ? contact.name : selectedConversation.phone %></h1>
                <p class="inbox-chat-sub mono"><%= selectedConversation.phone %><% if (_contactProfileId) { %> · Perfil<% } %></p>
                <% if (typeof metaAd !== 'undefined' && metaAd) { %>
                  <p class="inbox-chat-sub muted">
                    Anuncio:
                    <a href="<%= basePath %>/anuncios/<%= metaAd.id %>"><%= metaAd.display_name || metaAd.meta_source_id %></a>
                    · <% var _plat = metaAd.ad_platform; %>
                    <%= _plat === 'facebook' ? 'Facebook' : (_plat === 'instagram' ? 'Instagram' : 'Meta') %>
                  </p>
                <% } %>
                <% if (contact && contact.segment_slugs && contact.segment_slugs.length) { %>
                  <span class="contact-segment-chips contact-segment-chips--header" role="group" aria-label="Segmentos">
                    <% contact.segment_slugs.forEach(function (slug) { %>
                      <span class="inbox-chat-segment inbox-chat-segment--header" data-seg-tone="<%= segmentColorKey(slug) %>"><%= segmentLabel(slug) %></span>
                    <% }); %>
                  </span>
                <% } %>
                <p class="inbox-window-meta">
                  Ventana 24 h:
                  <% if (typeof userServiceWindowOpen !== 'undefined' && userServiceWindowOpen) { %>
                    <span class="badge sent">Abierta</span>
                  <% } else { %>
                    <span class="badge neutral">Cerrada</span>
                  <% } %>
                </p>
              </div>
            <% if (_contactProfileId) { %>
            </a>
            <% } else { %>
            </div>
            <% } %>
            <div class="inbox-chat-header-toolbar">
              <a
                href="<%= basePath %>/conversations/<%= selectedConversation.id %>/export"
                class="small-btn secondary inbox-export-btn inbox-export-btn--icon"
                aria-label="Descargar conversación en Excel"
                title="Descargar Excel"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
              </a>
              <details class="inbox-header-more">
                <summary class="inbox-header-more-trigger small-btn secondary" title="Más" aria-label="Más opciones">
                  <span class="inbox-header-more-icon" aria-hidden="true">+</span>
                  <span class="sr-only">Más opciones</span>
                </summary>
                <div class="inbox-header-more-panel">
                  <form
                    method="POST"
                    action="<%= basePath %>/conversations/<%= selectedConversation.id %>/mark-unread"
                    class="inbox-lead-score-form inbox-lead-score-form--in-more"
                  >
                    <% if (segmentFilter) { %>
                      <input type="hidden" name="inbox_segment" value="<%= segmentFilter %>" />
                    <% } %>
                    <% if (searchQ) { %>
                      <input type="hidden" name="inbox_q" value="<%= searchQ %>" />
                    <% } %>
                    <% if (_chatF === 'unread') { %>
                      <input type="hidden" name="inbox_chat" value="unread" />
                    <% } else if (_chatF === 'bot') { %>
                      <input type="hidden" name="inbox_chat" value="bot" />
                    <% } else if (_chatF === 'human') { %>
                      <input type="hidden" name="inbox_chat" value="human" />
                    <% } %>
                    <button type="submit" class="small-btn secondary">Marcar como no leído</button>
                  </form>
                  <% if (!contact) { %>
                    <% const _prefPhoneDigits = String(selectedConversation.phone || '').replace(/\D/g, ''); %>
                    <% const _prefSp = new URLSearchParams(); %>
                    <% _prefSp.set('prefill_phone', _prefPhoneDigits); %>
                    <a
                      class="small-btn secondary"
                      href="<%= basePath %>/contacts/new?<%= _prefSp.toString() %>"
                    >Guardar contacto</a>
                  <% } %>
                  <div
                    class="inbox-mode-toggle inbox-mode-toggle--in-more<%= !_aiOn ? ' inbox-mode-toggle--disabled' : '' %>"
                    role="group"
                    aria-label="Modo del chat"
                    data-conversation-id="<%= selectedConversation.id %>"
                    data-base-path="<%= basePath %>"
                    <% if (!_aiOn) { %>title="IA desactivada para el área (solo administrador master puede reactivarla)"<% } %>
                  >
                    <span class="inbox-mode-toggle-label">Modo</span>
                    <div class="inbox-mode-toggle-btns">
                      <button
                        type="button"
                        class="inbox-mode-btn inbox-mode-btn--icon-only <%= _convSt === 'bot' ? 'is-active' : '' %>"
                        data-set-status="bot"
                        <%= !_aiOn ? 'disabled' : '' %>
                        title="Bot"
                        aria-label="Modo Bot"
                      ><span aria-hidden="true">🤖</span></button>
                      <button
                        type="button"
                        class="inbox-mode-btn inbox-mode-btn--icon-only <%= _convSt === 'human' ? 'is-active' : '' %>"
                        data-set-status="human"
                        title="Asesor"
                        aria-label="Modo Asesor"
                      ><span aria-hidden="true">👤</span></button>
                    </div>
                  </div>
                  <% if (contact) { %>
                    <form
                      method="POST"
                      action="<%= basePath %>/conversations/<%= selectedConversation.id %>/lead-score"
                      class="inbox-lead-score-form inbox-lead-score-form--in-more"
                    >
                      <% if (segmentFilter) { %>
                        <input type="hidden" name="inbox_segment" value="<%= segmentFilter %>" />
                      <% } %>
                      <% if (searchQ) { %>
                        <input type="hidden" name="inbox_q" value="<%= searchQ %>" />
                      <% } %>
                      <% if (_chatF === 'unread') { %>
                        <input type="hidden" name="inbox_chat" value="unread" />
                      <% } else if (_chatF === 'bot') { %>
                        <input type="hidden" name="inbox_chat" value="bot" />
                      <% } else if (_chatF === 'human') { %>
                        <input type="hidden" name="inbox_chat" value="human" />
                      <% } %>
                      <div class="inbox-lead-score-row">
                        <span class="inbox-lead-score-label" id="lead-score-label">Calificación del lead</span>
                        <div class="inbox-lead-stars-input" role="group" aria-labelledby="lead-score-label">
                          <% for (var st = 1; st <= 5; st++) { %>
                            <button
                              type="submit"
                              name="lead_score"
                              value="<%= st %>"
                              class="inbox-lead-star-btn <%= contact.lead_score && contact.lead_score >= st ? 'is-on' : '' %>"
                              title="<%= st %> de 5"
                              aria-label="Calificar <%= st %> de 5"
                            >★</button>
                          <% } %>
                          <button type="submit" name="lead_score_clear" value="1" class="inbox-lead-clear" title="Quitar calificación" aria-label="Quitar calificación">Borrar</button>
                        </div>
                      </div>
                    </form>
                  <% } %>
                </div>
              </details>
            </div>
          </div>
          <div class="inbox-chat-body">
            <%- include('partials/inbox-thread', { messages, basePath, conversationId: selectedConversation.id }) %>
          </div>
          <div class="inbox-compose">
            <h2 class="inbox-compose-title">Responder</h2>
            <%- include('partials/inbox-reply', { conversation: selectedConversation, canReply, basePath, segmentFilter, searchQ, chatFilter, replyBlockedReason }) %>
          </div>
        <% } %>
      </section>
    </div>
    <script src="<%= basePath %>/js/conversations-inbox.js" defer></script>
    <script>
      (function () {
        var el = document.getElementById('chat-thread');
        if (el) el.scrollTop = el.scrollHeight;
      })();
    </script>
  </body>
</html>
