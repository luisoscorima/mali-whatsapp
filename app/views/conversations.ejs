<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <% if (typeof selectedConversation !== 'undefined' && selectedConversation) { %>Chat · <%= selectedConversation.phone %><% } else { %>Conversaciones<% } %> · MALI WhatsApp
    </title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <link rel="stylesheet" href="<%= basePath %>/css/wa-shell.css" />
    <link rel="stylesheet" href="<%= basePath %>/css/conversations.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
  </head>
  <body class="page-conversations">
    <% const segmentLabel = function (slug) {
      if (!slug) return '';
      const s = segments.find(function (x) { return x.value === slug; });
      return s ? s.label : slug;
    }; %>
    <% const segmentColorKey = function (slug) {
      if (!slug) return 'slate';
      const s = segments.find(function (x) { return x.value === slug; });
      return s ? s.colorKey : 'slate';
    }; %>
    <% function inboxInitials(contactName, phone) {
      var n = String(contactName || '').trim();
      if (n) {
        var parts = n.split(/\s+/).filter(function (x) { return x.length; });
        if (parts.length >= 2) {
          return (parts[0].charAt(0) + parts[1].charAt(0)).toUpperCase().slice(0, 2);
        }
        return n.slice(0, 2).toUpperCase();
      }
      var p = String(phone || '').replace(/\D/g, '');
      return p.slice(-2) || '?';
    } %>
    <% function formatChatTime(d) {
      if (!d) return '—';
      var date = new Date(d);
      if (isNaN(date.getTime())) return '—';
      var now = new Date();
      var sameDay = date.toDateString() === now.toDateString();
      if (sameDay) return date.toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' });
      var y1 = date.getFullYear();
      var y2 = now.getFullYear();
      if (y1 === y2) return date.toLocaleDateString('es-PE', { day: '2-digit', month: 'short' });
      return date.toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: '2-digit' });
    } %>
    <div
      class="wa-layout wa-layout--inbox inbox-layout-wa conversations-inbox conversations-page <%= typeof selectedConversation !== 'undefined' && selectedConversation ? 'conversations-inbox--detail' : '' %>"
    >
      <%- include('partials/wa-rail', { basePath, appBaseUrl, activeNav, showAdminNav: typeof showAdminNav !== 'undefined' ? showAdminNav : false, requireAuth, currentUser, areaLabel }) %>

      <aside class="inbox-sidebar" aria-label="Lista de conversaciones">
        <div class="inbox-sidebar-header inbox-sidebar-header--with-actions">
          <h2 class="inbox-sidebar-title">Chats</h2>
          <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar chats', refreshAriaLabel: 'Actualizar chats' }) %>
        </div>
        <form class="inbox-filters" method="get" action="<%= basePath %>/conversations">
          <label class="field field--inbox">
            <span class="field-label">Segmento</span>
            <select name="segment" class="inbox-select" data-inbox-filter>
              <option value="" <%= segmentFilter === '' ? 'selected' : '' %>>Todos</option>
              <option value="__none__" <%= segmentFilter === '__none__' ? 'selected' : '' %>>Sin segmento</option>
              <% segments.forEach(function (seg) { %>
                <option value="<%= seg.value %>" <%= segmentFilter === seg.value ? 'selected' : '' %>><%= seg.label %></option>
              <% }); %>
            </select>
          </label>
          <label class="field field--inbox">
            <span class="field-label">Buscar en todos los chats</span>
            <div class="inbox-search-row">
              <input
                type="search"
                name="q"
                value="<%= searchQ %>"
                placeholder="Palabra o frase…"
                autocomplete="off"
                class="inbox-search-input"
              />
              <button type="submit" class="small-btn">Buscar</button>
            </div>
          </label>
        </form>

        <% if (conversations.length === 0) { %>
          <p class="empty-state inbox-empty-list">No hay conversaciones con estos filtros.</p>
        <% } else { %>
          <ul class="inbox-chat-list">
            <% conversations.forEach(function (c) { %>
              <li class="inbox-chat-item <%= typeof selectedConversation !== 'undefined' && selectedConversation && selectedConversation.id === c.id ? 'is-active' : '' %>">
                <a class="inbox-chat-link" href="<%= basePath %>/conversations/<%= c.id %><%= inboxQuery %>">
                  <span class="inbox-chat-avatar" aria-hidden="true"><%= inboxInitials(c.contact_name, c.phone) %></span>
                  <span class="inbox-chat-link-main">
                    <span class="inbox-chat-row-top">
                      <span class="inbox-chat-title"><%= c.contact_name || c.phone %></span>
                      <span class="inbox-chat-time"><%= formatChatTime(c.last_message_at) %></span>
                    </span>
                    <% if (c.contact_name) { %>
                      <span class="inbox-chat-phone mono"><%= c.phone %></span>
                    <% } %>
                    <span class="inbox-chat-row-mid">
                      <span class="inbox-chat-preview"><%= (c.preview || '—').slice(0, 120) %></span>
                    </span>
                    <% if (c.contact_segment) { %>
                      <span class="inbox-chat-segment" data-seg-tone="<%= segmentColorKey(c.contact_segment) %>"><%= segmentLabel(c.contact_segment) %></span>
                    <% } %>
                  </span>
                </a>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </aside>

      <section class="inbox-main" aria-label="Hilo de mensajes">
        <% if (typeof selectedConversation === 'undefined' || !selectedConversation) { %>
          <div class="inbox-empty-pane" role="status">
            <div class="inbox-empty-hint">
              <span class="inbox-empty-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </span>
              <h2 class="inbox-empty-heading">Conversaciones</h2>
              <p class="inbox-empty-text">Selecciona un chat para ver los mensajes. Las respuestas del cliente se guardan como mensajes entrantes.</p>
            </div>
          </div>
        <% } else { %>
          <div class="inbox-chat-header">
            <a class="inbox-back-mobile" href="<%= basePath %>/conversations<%= inboxQuery %>">← Chats</a>
            <span class="inbox-chat-avatar inbox-chat-avatar--header" aria-hidden="true"><%= inboxInitials(contact ? contact.name : '', selectedConversation.phone) %></span>
            <div class="inbox-chat-header-main">
              <h1 class="inbox-chat-heading"><%= contact ? contact.name : selectedConversation.phone %></h1>
              <p class="inbox-chat-sub mono"><%= selectedConversation.phone %></p>
              <% if (contact && contact.segment) { %>
                <span class="inbox-chat-segment inbox-chat-segment--header" data-seg-tone="<%= segmentColorKey(contact.segment) %>"><%= segmentLabel(contact.segment) %></span>
              <% } %>
              <p class="inbox-window-meta">
                Ventana 24 h:
                <% if (canReply) { %>
                  <span class="badge sent">Abierta</span>
                <% } else { %>
                  <span class="badge neutral">Cerrada</span>
                <% } %>
              </p>
            </div>
          </div>
          <div class="inbox-chat-body">
            <%- include('partials/inbox-thread', { messages, basePath }) %>
          </div>
          <div class="inbox-compose">
            <h2 class="inbox-compose-title">Responder</h2>
            <%- include('partials/inbox-reply', { conversation: selectedConversation, canReply, basePath, segmentFilter, searchQ }) %>
          </div>
        <% } %>
      </section>
    </div>
    <script src="<%= basePath %>/js/conversations-inbox.js" defer></script>
    <script>
      (function () {
        var el = document.getElementById('chat-thread');
        if (el) el.scrollTop = el.scrollHeight;
      })();
    </script>
  </body>
</html>
