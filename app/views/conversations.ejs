<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Conversaciones · MALI WhatsApp</title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
  </head>
  <body>
    <div class="page page--detail">
      <div class="detail-top">
        <div class="detail-top-start">
          <button type="button" class="theme-toggle" data-theme-toggle title="Modo claro / oscuro" aria-label="Cambiar tema">◐</button>
          <a class="back-link" href="<%= basePath %>/">← Panel</a>
        </div>
        <% if (typeof requireAuth !== 'undefined' && requireAuth) { %>
          <div class="user-bar user-bar--inline">
            <span class="area-pill"><%= areaLabel %></span>
            <% if (currentUser.isMaster) { %>
              <span class="area-pill area-pill--master">Master</span>
            <% } %>
            <span class="user-name"><%= currentUser.email %></span>
            <form method="post" action="<%= basePath %>/logout" class="logout-form">
              <button type="submit" class="secondary small-btn">Salir</button>
            </form>
          </div>
        <% } %>
      </div>

      <div class="card">
        <h1 class="card-title">Conversaciones</h1>
        <p class="card-lead">Mensajes entrantes vía webhook. Responde con texto solo dentro de la ventana de 24 h desde el último mensaje del usuario.</p>

        <% if (conversations.length === 0) { %>
          <p class="empty-state">Aún no hay conversaciones. Cuando un usuario escriba al número de WhatsApp de esta área, aparecerá aquí.</p>
        <% } else { %>
          <div class="table-wrap">
            <table class="conversation-list">
              <thead>
                <tr>
                  <th>Teléfono</th>
                  <th>Contacto</th>
                  <th>Último mensaje</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% conversations.forEach((c) => { %>
                  <tr>
                    <td class="mono"><%= c.phone %></td>
                    <td><%= c.contact_name || '—' %></td>
                    <td class="conversation-preview"><%= c.preview || '—' %></td>
                    <td><a class="text-link" href="<%= basePath %>/conversations/<%= c.id %>">Abrir</a></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </body>
</html>
