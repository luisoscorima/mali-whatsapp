<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <% if (typeof selectedConversation !== 'undefined' && selectedConversation) { %>Chat · <%= selectedConversation.phone %><% } else { %>Conversaciones<% } %> · MALI WhatsApp
    </title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
  </head>
  <body class="has-wave-bg">
    <%- include('partials/wave-background') %>
    <% const segmentLabel = function (slug) {
      if (!slug) return '';
      const s = segments.find(function (x) { return x.value === slug; });
      return s ? s.label : slug;
    }; %>
    <div class="app-shell">
      <%- include('partials/sidebar-nav', { basePath, appBaseUrl, activeNav }) %>

      <main class="main-panel main-panel--inbox">
        <header class="top-bar">
          <%- include('partials/top-bar-actions', { basePath, areaLabel, requireAuth, currentUser }) %>
        </header>

        <div class="conversations-inbox <%= typeof selectedConversation !== 'undefined' && selectedConversation ? 'conversations-inbox--detail' : '' %>">
          <aside class="inbox-sidebar" aria-label="Lista de conversaciones">
            <form class="inbox-filters" method="get" action="<%= basePath %>/conversations">
              <label class="field field--inbox">
                <span class="field-label">Segmento</span>
                <select name="segment" class="inbox-select" data-inbox-filter>
                  <option value="" <%= segmentFilter === '' ? 'selected' : '' %>>Todos</option>
                  <option value="__none__" <%= segmentFilter === '__none__' ? 'selected' : '' %>>Sin segmento</option>
                  <% segments.forEach(function (seg) { %>
                    <option value="<%= seg.value %>" <%= segmentFilter === seg.value ? 'selected' : '' %>><%= seg.label %></option>
                  <% }); %>
                </select>
              </label>
              <label class="field field--inbox">
                <span class="field-label">Buscar en todos los chats</span>
                <div class="inbox-search-row">
                  <input
                    type="search"
                    name="q"
                    value="<%= searchQ %>"
                    placeholder="Palabra o frase…"
                    autocomplete="off"
                    class="inbox-search-input"
                  />
                  <button type="submit" class="secondary small-btn">Buscar</button>
                </div>
              </label>
            </form>

            <% if (conversations.length === 0) { %>
              <p class="empty-state inbox-empty-list">No hay conversaciones con estos filtros.</p>
            <% } else { %>
              <ul class="inbox-chat-list">
                <% conversations.forEach(function (c) { %>
                  <li class="inbox-chat-item <%= typeof selectedConversation !== 'undefined' && selectedConversation && selectedConversation.id === c.id ? 'is-active' : '' %>">
                    <a class="inbox-chat-link" href="<%= basePath %>/conversations/<%= c.id %><%= inboxQuery %>">
                      <span class="inbox-chat-title"><%= c.contact_name || c.phone %></span>
                      <% if (c.contact_name) { %>
                        <span class="inbox-chat-phone mono"><%= c.phone %></span>
                      <% } %>
                      <% if (c.contact_segment) { %>
                        <span class="inbox-chat-segment"><%= segmentLabel(c.contact_segment) %></span>
                      <% } %>
                      <span class="inbox-chat-preview"><%= (c.preview || '—').slice(0, 120) %></span>
                      <span class="inbox-chat-time">
                        <%= c.last_message_at ? new Date(c.last_message_at).toLocaleString('es-PE', { dateStyle: 'short', timeStyle: 'short' }) : '—' %>
                      </span>
                    </a>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </aside>

          <section class="inbox-main" aria-label="Hilo de mensajes">
            <% if (typeof selectedConversation === 'undefined' || !selectedConversation) { %>
              <div class="inbox-empty-pane">
                <p class="inbox-empty-title">Conversaciones</p>
                <p class="muted">Selecciona un chat para ver los mensajes. Las respuestas del cliente se guardan como mensajes entrantes.</p>
              </div>
            <% } else { %>
              <div class="inbox-chat-header">
                <a class="inbox-back-mobile" href="<%= basePath %>/conversations<%= inboxQuery %>">← Chats</a>
                <div class="inbox-chat-header-main">
                  <h1 class="inbox-chat-heading"><%= contact ? contact.name : selectedConversation.phone %></h1>
                  <p class="inbox-chat-sub mono"><%= selectedConversation.phone %></p>
                  <% if (contact && contact.segment) { %>
                    <p class="inbox-chat-sub"><%= segmentLabel(contact.segment) %></p>
                  <% } %>
                  <p class="inbox-window-meta">
                    Ventana 24 h:
                    <% if (canReply) { %>
                      <span class="badge sent">Abierta</span>
                    <% } else { %>
                      <span class="badge neutral">Cerrada</span>
                    <% } %>
                  </p>
                </div>
              </div>
              <div class="inbox-chat-body">
                <%- include('partials/inbox-thread', { messages, basePath }) %>
              </div>
              <div class="inbox-compose">
                <h2 class="inbox-compose-title">Responder</h2>
                <%- include('partials/inbox-reply', { conversation: selectedConversation, canReply, basePath, segmentFilter, searchQ }) %>
              </div>
            <% } %>
          </section>
        </div>
      </main>
    </div>
    <script src="<%= basePath %>/js/conversations-inbox.js" defer></script>
    <script>
      (function () {
        var el = document.getElementById('chat-thread');
        if (el) el.scrollTop = el.scrollHeight;
      })();
    </script>
  </body>
</html>
