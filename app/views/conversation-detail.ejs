<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Conversación · <%= conversation.phone %></title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
  </head>
  <body>
    <div class="page page--detail">
      <div class="detail-top">
        <div class="detail-top-start">
          <button type="button" class="theme-toggle" data-theme-toggle title="Modo claro / oscuro" aria-label="Cambiar tema">◐</button>
          <a class="back-link" href="<%= basePath %>/conversations">← Conversaciones</a>
        </div>
        <% if (typeof requireAuth !== 'undefined' && requireAuth) { %>
          <div class="user-bar user-bar--inline">
            <span class="area-pill"><%= areaLabel %></span>
            <% if (currentUser.isMaster) { %>
              <span class="area-pill area-pill--master">Master</span>
            <% } %>
            <span class="user-name"><%= currentUser.email %></span>
            <form method="post" action="<%= basePath %>/logout" class="logout-form">
              <button type="submit" class="secondary small-btn">Salir</button>
            </form>
          </div>
        <% } %>
      </div>

      <div class="card">
        <h1 class="card-title">Chat · <span class="mono"><%= conversation.phone %></span></h1>
        <dl class="detail-dl detail-dl--compact">
          <% if (contact) { %>
            <div><dt>Contacto</dt><dd><%= contact.name %></dd></div>
          <% } %>
          <div>
            <dt>Ventana 24 h</dt>
            <dd>
              <% if (canReply) { %>
                <span class="badge sent">Abierta</span> (respuesta libre con texto)
              <% } else { %>
                <span class="badge neutral">Cerrada</span> — espera un mensaje del usuario o usa una campaña con plantilla.
              <% } %>
            </dd>
          </div>
        </dl>
      </div>

      <div class="card">
        <h2 class="card-title">Mensajes</h2>
        <% if (messages.length === 0) { %>
          <p class="empty-state">Sin mensajes almacenados.</p>
        <% } else { %>
          <div class="chat-thread" id="chat-thread">
            <% messages.forEach((m) => { %>
              <div class="chat-bubble <%= m.direction === 'outbound' ? 'chat-bubble--out' : 'chat-bubble--in' %>">
                <div><%= m.body_text %></div>
                <div class="chat-meta">
                  <%= m.direction === 'outbound' ? 'Tú' : 'Usuario' %> · <%= m.message_type %> ·
                  <%= new Date(m.created_at).toLocaleString('es-PE', { dateStyle: 'short', timeStyle: 'short' }) %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>

      <div class="card">
        <h2 class="card-title">Responder</h2>
        <% if (!canReply) { %>
          <p class="inline-warn">No puedes enviar texto libre hasta que el usuario te escriba de nuevo (ventana de 24 h).</p>
        <% } else { %>
          <form method="POST" action="<%= basePath %>/conversations/<%= conversation.id %>/reply" class="reply-form reply-form--stack">
            <label class="field">
              <span class="field-label">Mensaje (máx. 4096 caracteres)</span>
              <textarea name="message" required maxlength="4096" placeholder="Escribe tu respuesta…"></textarea>
            </label>
            <div class="form-actions">
              <button type="submit">Enviar por WhatsApp</button>
            </div>
          </form>
        <% } %>
      </div>
    </div>
    <script>
      (function () {
        var el = document.getElementById('chat-thread');
        if (el) el.scrollTop = el.scrollHeight;
      })();
    </script>
  </body>
</html>
