<% const _backList = '/campaigns'; %>
<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  layoutModifier: typeof layoutModifier !== 'undefined' ? layoutModifier : 'conversations-inbox--detail',
  extraHeadScripts: null
}) %>
<%- include('partials/campaign-list-sidebar', {
  campaigns,
  basePath,
  listBasePath: typeof listBasePath !== 'undefined' ? listBasePath : '/campaigns',
  sidebarTitle: typeof sidebarTitle !== 'undefined' ? sidebarTitle : 'Campañas',
  showNewLink: typeof showNewLink !== 'undefined' ? showNewLink : true,
  selectedCampaignId: campaign.id
}) %>
<section class="inbox-main" aria-label="Detalle de campaña">
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %><%= _backList %>">← Lista</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading">Campaña #<%= campaign.id %></h1>
      <p class="inbox-chat-sub mono"><%= campaign.template_name %> · <%= campaign.segment %></p>
    </div>
    <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar campaña', refreshAriaLabel: 'Actualizar campaña' }) %>
  </div>
  <div class="inbox-chat-body inbox-chat-body--scroll">
    <%- include('partials/campaign-detail-body', { campaign, logs }) %>
    <p class="inbox-detail-footer-link"><a class="text-link" href="<%= basePath %>/conversations">Ir a conversaciones</a></p>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
