<%- include('layouts/inbox-shell-start', {
  pageTitle: 'Usuarios · MALI WhatsApp',
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav: typeof activeNav !== 'undefined' ? activeNav : 'admin-users',
  showAdminNav,
  layoutModifier: '',
  extraHeadScripts: null
}) %>
<%- include('partials/admin-sidebar', { basePath, adminSection: 'users' }) %>
<section class="inbox-main" aria-label="Usuarios del panel">
  <div class="inbox-chat-header inbox-chat-header--static inbox-chat-header--spread">
    <h1 class="inbox-chat-heading">Usuarios del panel</h1>
    <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar usuarios', refreshAriaLabel: 'Actualizar usuarios' }) %>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <div class="card">
      <div class="card-head card-head--actions-only">
        <a class="small-btn primary" href="<%= basePath %>/admin/users/new">Nuevo usuario</a>
      </div>
      <% if (userSaved) { %>
      <p class="toast toast--ok">Cambios guardados.</p>
      <% } %>
      <% if (userErr === 'self') { %>
      <p class="inline-warn">No puedes eliminar tu propia cuenta mientras tienes la sesión iniciada.</p>
      <% } %>

      <div class="table-wrap table-wrap--compact">
        <table>
          <thead>
            <tr>
              <th>Correo</th>
              <th>Área</th>
              <th>Master</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function (u) { %>
            <tr>
              <td><%= u.email %></td>
              <td><%= u.area %></td>
              <td><%= u.is_master ? 'Sí' : '—' %></td>
              <td class="table-actions">
                <a class="small-btn secondary" href="<%= basePath %>/admin/users/<%= u.id %>/edit">Editar</a>
                <% if (currentUser && currentUser.id !== u.id) { %>
                <form method="post" action="<%= basePath %>/admin/users/<%= u.id %>/delete" class="inline-delete-form" onsubmit="return confirm('¿Eliminar este usuario?');">
                  <button type="submit" class="small-btn danger">Eliminar</button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <p class="card-lead muted"><a href="<%= basePath %>/campaigns">← Volver a campañas</a></p>
    </div>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
