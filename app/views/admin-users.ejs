<%- include('layouts/inbox-shell-start', {
  pageTitle: 'Usuarios · MALI WhatsApp',
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav: typeof activeNav !== 'undefined' ? activeNav : 'admin-users',
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: 'conversations-inbox--detail',
  extraHeadScripts: null
}) %>
<%- include('partials/admin-sidebar', { basePath, adminSection: 'users' }) %>
<section class="inbox-main" aria-label="Usuarios del panel">
  <%- include('partials/admin-mobile-nav', { basePath, adminSection: 'users' }) %>
  <div class="inbox-chat-header inbox-chat-header--static">
    <h1 class="inbox-chat-heading">Usuarios del panel</h1>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <div class="card">
      <div class="card-head card-head--actions-only">
        <a class="small-btn primary" href="<%= basePath %>/admin/users/new">Nuevo usuario</a>
      </div>
      <% if (userSaved) { %>
      <p class="toast toast--ok">Cambios guardados.</p>
      <% } %>
      <% if (userErr === 'self') { %>
      <p class="inline-warn">No puedes eliminar tu propia cuenta mientras tienes la sesión iniciada.</p>
      <% } %>
      <% if (typeof bulkImport !== 'undefined' && bulkImport) { %>
      <div class="toast <%= bulkImport.err ? 'toast--err' : 'toast--ok' %>">
        <% if (bulkImport.err) { %>
          <% if (bulkImport.err === 'no_file') { %>Selecciona un archivo CSV o Excel.<% } else if (bulkImport.err === 'type') { %>Solo archivos .csv o .xlsx.<% } else if (bulkImport.err === 'too_big') { %>Archivo demasiado grande.<% } else if (bulkImport.err === 'too_many') { %>Demasiadas filas (máx. <%= typeof maxBulkRows !== 'undefined' ? maxBulkRows : 10000 %>).<% } else if (bulkImport.err === 'empty') { %>Archivo sin correos válidos.<% } else if (bulkImport.err === 'weak_password') { %>La contraseña inicial debe tener al menos 6 caracteres.<% } else if (bulkImport.err === 'bad_area') { %>Área inválida.<% } else if (bulkImport.err === 'parse') { %>No se pudo leer el archivo.<% } else { %>Error en la importación.<% } %>
        <% } else { %>
          Creados: <%= bulkImport.ok %>.<% if (bulkImport.bad > 0) { %> Correos inválidos u omitidos en archivo: <%= bulkImport.bad %>.<% } %><% if (bulkImport.dup > 0) { %> Ya existían (omitidos): <%= bulkImport.dup %>.<% } %>
        <% } %>
      </div>
      <% } %>

      <h2 class="card-title" style="margin-top: 0.5rem">Carga masiva</h2>
      <p class="card-lead muted">Sube un CSV o Excel con correos <code>@mali.pe</code> (columna <code>email</code> o primera columna). Todos reciben la misma contraseña inicial y deberán cambiarla al primer inicio de sesión.</p>
      <form method="post" action="<%= basePath %>/admin/users/bulk-import" enctype="multipart/form-data" class="form-grid tight" style="margin-bottom: 1.5rem">
        <label class="field">
          <span class="field-label">Archivo (.csv o .xlsx)</span>
          <input type="file" name="bulkfile" accept=".csv,.xlsx,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
        </label>
        <label class="field">
          <span class="field-label">Contraseña inicial (todos)</span>
          <input type="password" name="password" required minlength="6" autocomplete="new-password" />
        </label>
        <label class="field">
          <span class="field-label">Área</span>
          <select name="area" required>
            <option value="ti">TI (dev)</option>
            <option value="pam">PAM</option>
            <option value="patronato">Patronato</option>
            <option value="educacion">Educación</option>
          </select>
        </label>
        <div class="field-row">
          <button type="submit" class="primary">Importar usuarios</button>
          <a class="text-link sample-csv-link" href="<%= basePath %>/admin/users/sample.csv">Plantilla CSV</a>
        </div>
      </form>

      <div class="table-wrap table-wrap--compact">
        <table>
          <thead>
            <tr>
              <th>Correo</th>
              <th>Área</th>
              <th>Master</th>
              <th>Integr.</th>
              <th>IA</th>
              <th>Horario</th>
              <th>Bitácora</th>
              <th>Reportes</th>
              <th>Cambio pwd</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function (u) { %>
            <tr>
              <td><%= u.email %></td>
              <td><%= u.area %></td>
              <td><%= u.is_master ? 'Sí' : '—' %></td>
              <td><%= u.can_view_integration ? 'Sí' : '—' %></td>
              <td><%= u.can_edit_ai_prompt ? 'Sí' : '—' %></td>
              <td><%= u.can_edit_business_hours ? 'Sí' : '—' %></td>
              <td><%= u.can_view_audit_logs ? 'Sí' : '—' %></td>
              <td><%= u.can_view_reports ? 'Sí' : '—' %></td>
              <td><%= u.must_change_password ? 'Sí' : '—' %></td>
              <td class="table-actions">
                <a class="small-btn secondary" href="<%= basePath %>/admin/users/<%= u.id %>/edit">Editar</a>
                <% if (currentUser && currentUser.id !== u.id) { %>
                <form method="post" action="<%= basePath %>/admin/users/<%= u.id %>/delete" class="inline-delete-form" onsubmit="return confirm('¿Eliminar este usuario?');">
                  <button type="submit" class="small-btn danger">Eliminar</button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <p class="card-lead muted"><a href="<%= basePath %>/campaigns">← Volver a campañas</a></p>
    </div>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
