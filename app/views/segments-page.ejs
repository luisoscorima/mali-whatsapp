<% const _segSel = typeof selectedSegmentId !== 'undefined' ? selectedSegmentId : null; %>
<% var _segmentsMobileDetail = view === 'detail' || view === 'new'; %>
<% function segmentMemberLabel(slug) {
  if (!slug) return '';
  const s = segments.find(function (x) { return x.value === slug; });
  return s ? s.label : slug;
}
function segmentMemberColorKey(slug) {
  if (!slug) return 'slate';
  const s = segments.find(function (x) { return x.value === slug; });
  return s && s.colorKey ? s.colorKey : 'slate';
}
function segmentMemberChatHref(member) {
  const targetId = member && member.chat_target_id ? member.chat_target_id : -(member && member.id ? member.id : 0);
  return basePath + '/conversations/' + targetId;
}
%>
<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: _segmentsMobileDetail ? 'conversations-inbox--detail' : '',
  extraHeadScripts: view === 'detail' ? [(basePath || '') + '/js/segments-detail.js'] : null
}) %>
<aside class="inbox-sidebar" aria-label="Segmentos">
  <div class="inbox-sidebar-header inbox-sidebar-header--with-actions">
    <h2 class="inbox-sidebar-title">Segmentos</h2>
    <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar segmentos', refreshAriaLabel: 'Actualizar segmentos' }) %>
  </div>
  <div class="inbox-filters inbox-filters--campaign-new">
    <a href="<%= basePath %>/segments/new" class="small-btn primary">+ Añadir segmento</a>
  </div>
  <% if (!segments || segments.length === 0) { %>
  <p class="empty-state inbox-empty-list">No hay segmentos definidos.</p>
  <% } else { %>
  <ul class="inbox-chat-list">
    <% segments.forEach(function (seg) { %>
    <li class="inbox-chat-item <%= _segSel === seg.id ? 'is-active' : '' %>">
      <a class="inbox-chat-link" href="<%= basePath %>/segments/<%= seg.id %>">
        <span class="inbox-chat-link-main">
          <span class="inbox-chat-row-top">
            <span class="inbox-chat-title"><%= seg.label %></span>
          </span>
          <span class="inbox-chat-row-mid">
            <span class="inbox-chat-preview">
              <span class="inbox-chat-segment inbox-chat-segment--slug-tag mono" data-seg-tone="<%= seg.colorKey || 'teal' %>"><%= seg.value %></span>
            </span>
          </span>
        </span>
      </a>
    </li>
    <% }); %>
  </ul>
  <% } %>
</aside>
<section class="inbox-main" aria-label="Detalle de segmentos">
  <% if (view === 'list') { %>
  <div class="inbox-empty-pane" role="status">
    <div class="inbox-empty-hint">
      <span class="inbox-empty-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      </span>
      <h2 class="inbox-empty-heading">Segmentos</h2>
      <p class="inbox-empty-text">Selecciona un segmento en la lista para editarlo, o pulsa <strong>Añadir segmento</strong>. Por área (<strong><%= areaLabel %></strong>).</p>
      <% if (typeof segmentsSaved !== 'undefined' && segmentsSaved) { %>
      <p class="toast toast--ok">Segmentos actualizados.</p>
      <% } %>
    </div>
  </div>
  <% } else if (view === 'new') { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/segments">← Segmentos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading">Añadir segmento</h1>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (typeof segmentsSaved !== 'undefined' && segmentsSaved) { %>
    <p class="toast toast--ok">Segmentos actualizados.</p>
    <% } %>
    <%- include('partials/segment-add-form') %>
  </div>
  <% } else if (view === 'detail' && selectedSegment) { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/segments">← Segmentos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading"><%= selectedSegment.label %></h1>
      <p class="inbox-chat-sub mono"><%= selectedSegment.value %></p>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (typeof segmentsSaved !== 'undefined' && segmentsSaved) { %>
    <p class="toast toast--ok">Segmentos actualizados.</p>
    <% } %>
    <% if (typeof segmentMemberRemoved !== 'undefined' && segmentMemberRemoved) { %>
    <p class="toast toast--ok">Contacto quitado del segmento.</p>
    <% } %>
    <% if (typeof segmentMemberError !== 'undefined' && segmentMemberError === 'last_segment') { %>
    <p class="toast toast--warn">No se puede quitar el único segmento del contacto.</p>
    <% } else if (typeof segmentMemberError !== 'undefined' && segmentMemberError === 'not_found') { %>
    <p class="toast toast--warn">Ese contacto ya no pertenece a este segmento.</p>
    <% } %>
    <div class="card">
      <h2 class="card-title">Editar segmento</h2>
      <p class="card-lead">Si cambias el slug, se actualizan los contactos y el histórico de campañas de ese segmento en esta área.</p>
      <form method="POST" action="<%= basePath %>/settings/segment-update" class="segment-update-form" id="segment-edit-form">
        <input type="hidden" name="id" value="<%= selectedSegment.id %>" />
        <div class="segment-update-row">
          <label class="segment-field segment-field--slug">
            <span class="segment-field-lbl">Slug</span>
            <input
              type="text"
              name="slug"
              value="<%= selectedSegment.value %>"
              required
              pattern="[a-z0-9_]{1,50}"
              maxlength="50"
              class="segment-slug-input mono"
              title="Minusculas, numeros y guion bajo"
              autocomplete="off"
            />
          </label>
          <label class="segment-field">
            <span class="segment-field-lbl">Etiqueta</span>
            <input type="text" name="label" value="<%= selectedSegment.label %>" maxlength="120" required class="segment-label-input" />
          </label>
          <label class="segment-field segment-field--order">
            <span class="segment-field-lbl">Orden</span>
            <input type="number" name="sort_order" value="<%= selectedSegment.sort_order %>" step="1" class="segment-order-input" />
          </label>
          <%- include('partials/segment-color-field', { selectedColorKey: selectedSegment.colorKey || 'teal', compactRow: true }) %>
        </div>
      </form>
      <div class="resource-actions-row">
        <button type="submit" form="segment-edit-form" class="small-btn primary">Guardar cambios</button>
        <form method="POST" action="<%= basePath %>/settings/segment-delete" class="inline-delete-form inline-delete-form--spaced" onsubmit="return confirm('¿Borrar este segmento? Se quitará de los contactos (vínculos), no se borran las personas.');">
          <input type="hidden" name="id" value="<%= selectedSegment.id %>" />
          <button type="submit" class="small-btn danger-outline">Borrar segmento</button>
        </form>
      </div>
    </div>
    <div class="card segment-members-card">
      <div class="segment-members-card__head">
        <div>
          <h2 class="card-title">Contactos del segmento</h2>
          <p class="card-lead">Aquí puedes revisar quién pertenece a <strong><%= selectedSegment.label %></strong>, abrir su chat o quitar solo este vínculo.</p>
        </div>
        <span class="badge neutral"><%= (segmentMembers || []).length %> contacto(s)</span>
      </div>
      <% if (!segmentMembers || segmentMembers.length === 0) { %>
      <p class="empty-state">No hay contactos activos en este segmento.</p>
      <% } else { %>
      <ul class="segment-members-list" aria-label="Contactos del segmento">
        <% segmentMembers.forEach(function (member) { %>
        <% const _memberSlugs = member.segment_slugs || []; %>
        <% const _canRemove = _memberSlugs.length > 1; %>
        <li class="segment-members-item">
          <div class="segment-members-item__main">
            <div class="segment-members-item__top">
              <strong class="segment-members-item__name"><%= member.name || member.phone %></strong>
              <span class="mono muted"><%= member.phone %></span>
            </div>
            <div class="contact-segment-chips segment-members-item__chips" role="group" aria-label="Segmentos del contacto">
              <% _memberSlugs.forEach(function (slug) { %>
              <span class="inbox-chat-segment inbox-chat-segment--contact-pill" data-seg-tone="<%= segmentMemberColorKey(slug) %>"><%= segmentMemberLabel(slug) %></span>
              <% }); %>
            </div>
          </div>
          <div class="segment-members-item__actions" role="group" aria-label="Acciones del contacto">
            <a class="contact-row-action-btn" href="<%= segmentMemberChatHref(member) %>" title="Abrir chat" aria-label="Abrir chat">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
            </a>
            <a class="contact-row-action-btn" href="<%= basePath %>/contacts/<%= member.id %>" title="Editar contacto" aria-label="Editar contacto">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M12 20h9" />
                <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4Z" />
              </svg>
            </a>
            <form method="POST" action="<%= basePath %>/segments/<%= selectedSegment.id %>/contacts/<%= member.id %>/remove" class="inline-delete-form inline-delete-form--inline segment-remove-form" onsubmit="return confirm('¿Quitar este contacto del segmento?');">
              <div class="segment-remove-wrap<%= !_canRemove ? ' is-blocked' : '' %>"<% if (!_canRemove) { %> data-blocked-msg="El contacto debe conservar al menos un segmento. Asígnale otro segmento antes de quitar este vínculo."<% } %>>
                <button
                  type="submit"
                  class="small-btn danger-outline segment-remove-btn"
                  <%= !_canRemove ? 'disabled aria-disabled="true"' : '' %>
                  <% if (!_canRemove) { %>aria-describedby="segment-remove-hint-<%= member.id %>"<% } %>
                >Quitar</button>
                <% if (!_canRemove) { %>
                <span id="segment-remove-hint-<%= member.id %>" class="segment-remove-hint">Único segmento del contacto</span>
                <% } %>
              </div>
            </form>
          </div>
        </li>
        <% }); %>
      </ul>
      <% } %>
    </div>
  </div>
  <% } %>
</section>
<%- include('layouts/inbox-shell-end') %>
