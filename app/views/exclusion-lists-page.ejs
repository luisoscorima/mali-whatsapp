<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/app-head', { pageTitle, basePath }) %>
</head>
<body class="page-conversations">
  <div class="wa-layout wa-layout--inbox" style="display:flex;min-height:100vh">
  <%- include('partials/wa-rail', { basePath, appBaseUrl, activeNav, showAdminNav, requireAuth, currentUser, areaLabel }) %>
  <main class="main-panel" style="flex:1;padding:1.5rem">
    <header class="page-header">
      <h1>Listas de exclusión</h1>
      <p class="muted">Contactos en estas listas no recibirán campañas cuando selecciones la lista al enviar.</p>
    </header>
    <% if (flash === 'created') { %><p class="toast toast--ok">Lista creada.</p><% } %>
    <% if (error === 'duplicate') { %><p class="inline-warn">Ya existe una lista con ese nombre.</p><% } %>
    <div class="card">
      <h2 class="card-title">Nueva lista</h2>
      <form method="post" action="<%= basePath %>/exclusion-lists" class="form-row">
        <label class="field">
          <span class="field-label">Nombre</span>
          <input type="text" name="name" required maxlength="120" placeholder="Ej. Blacklist cobranza" />
        </label>
        <button type="submit" class="small-btn primary">Crear</button>
      </form>
    </div>
    <div class="card">
      <h2 class="card-title">Listas (<%= lists.length %>)</h2>
      <% if (lists.length === 0) { %>
      <p class="muted">Sin listas aún.</p>
      <% } else { %>
      <ul class="simple-list">
        <% lists.forEach(function (l) { %>
        <li><a href="<%= basePath %>/exclusion-lists/<%= l.id %>"><%= l.name %></a> — <%= l.member_count %> contacto(s)</li>
        <% }); %>
      </ul>
      <% } %>
    </div>
    <p><a class="text-link" href="<%= basePath %>/campaigns/new">Volver a campañas</a></p>
  </main>
  </div>
</body>
</html>
