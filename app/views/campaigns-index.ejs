<% const summary = typeof campaignSummary !== 'undefined' && campaignSummary ? campaignSummary : { business: [], results: [], hint: '', campaignsCount: 0 }; %>
<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: '',
  extraHeadScripts: null
}) %>
<%- include('partials/campaign-list-sidebar', {
  campaigns,
  basePath,
  listBasePath: '/campaigns',
  sidebarTitle: 'Campañas',
  showNewLink: true,
  selectedCampaignId: null
}) %>
<section class="inbox-main" aria-label="Campañas">
  <div class="inbox-empty-pane inbox-empty-pane--history" role="status">
    <div class="campaign-index-summary">
      <div class="campaign-index-summary__section">
        <h2 class="card-title">Negocio</h2>
        <div class="metrics-row metrics-row--history campaign-dashboard-grid campaign-dashboard-grid--2" role="region" aria-label="Resumen de negocio">
          <% summary.business.forEach(function (metric) { %>
          <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
            <% if (metric.displayLines && metric.displayLines.length) { %>
            <span class="metric-num metric-num--stack">
              <% metric.displayLines.forEach(function (line, idx) { %>
              <span class="money-stack__line<%= idx > 0 ? ' money-stack__line--secondary' : '' %>"><%= line %></span>
              <% }); %>
            </span>
            <% } else { %>
            <span class="metric-num"><%= metric.display %></span>
            <% } %>
            <span class="metric-lbl"><%= metric.label %></span>
          </div>
          <% }); %>
        </div>
      </div>
      <div class="campaign-index-summary__section">
        <h2 class="card-title">Resultado global</h2>
        <div class="metrics-row metrics-row--history campaign-dashboard-grid campaign-dashboard-grid--3" role="region" aria-label="Resumen operativo">
          <% summary.results.forEach(function (metric) { %>
          <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
            <span class="metric-num"><%= metric.display %></span>
            <span class="metric-lbl"><%= metric.label %></span>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
    <p class="muted metrics-row-hint history-metrics-hint">
      <%= summary.hint %> Campañas visibles: <strong><%= summary.campaignsCount %></strong>.
    </p>
    <div class="inbox-empty-hint">
      <span class="inbox-empty-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </span>
      <h2 class="inbox-empty-heading">Campañas</h2>
      <p class="inbox-empty-text">Selecciona una campaña en la lista para ver rendimiento e incidencias de entrega, o crea una nueva para lanzar una plantilla Meta a un segmento.</p>
      <% if (typeof templatesSynced !== 'undefined' && templatesSynced) { %>
      <p class="toast toast--ok">Plantillas sincronizadas desde Meta.</p>
      <% } %>
    </div>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
