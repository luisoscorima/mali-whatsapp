<% const ct = typeof campaignTotals !== 'undefined' && campaignTotals ? campaignTotals : {};
  const totals = {
    sent: Number(ct.sent_count || 0),
    delivered: Number(ct.delivered_count || 0),
    read: Number(ct.read_count || 0),
    failed: Number(ct.failed_count || 0),
    totalLogs: Number(ct.total_logs || 0),
  };
  const deliveryRate =
    totals.sent > 0 ? Math.round((totals.delivered / totals.sent) * 100) : null;
  const readRate =
    totals.delivered > 0 ? Math.round((totals.read / totals.delivered) * 100) : null;
  const errorRate =
    totals.totalLogs > 0 ? Math.round((totals.failed / totals.totalLogs) * 100) : 0;
%>
<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  layoutModifier: typeof layoutModifier !== 'undefined' ? layoutModifier : '',
  extraHeadScripts: null
}) %>
<%- include('partials/campaign-list-sidebar', {
  campaigns,
  basePath,
  listBasePath: '/campaigns',
  sidebarTitle: 'Campañas',
  showNewLink: true,
  selectedCampaignId: null
}) %>
<section class="inbox-main" aria-label="Campañas">
  <div class="inbox-empty-pane inbox-empty-pane--history" role="status">
    <div class="metrics-row metrics-row--history" role="region" aria-label="Resumen de envíos">
      <div class="metric">
        <span class="metric-num"><%= totals.totalLogs %></span>
        <span class="metric-lbl">Total</span>
      </div>
      <div class="metric">
        <span class="metric-num"><%= totals.sent %></span>
        <span class="metric-lbl">Enviados (API)</span>
      </div>
      <div class="metric">
        <span class="metric-num"><%= deliveryRate !== null ? deliveryRate + '%' : '—' %></span>
        <span class="metric-lbl">Entregados</span>
      </div>
      <div class="metric">
        <span class="metric-num"><%= readRate !== null ? readRate + '%' : '—' %></span>
        <span class="metric-lbl">Lectura</span>
      </div>
      <div class="metric">
        <span class="metric-num"><%= errorRate %>%</span>
        <span class="metric-lbl">Error</span>
      </div>
    </div>
    <p class="muted metrics-row-hint history-metrics-hint">
      Sobre <strong>todas</strong> las campañas de esta área. <strong>Total</strong> = filas en registro de envíos.
      <strong>Enviados (API)</strong> = aceptados por Meta (estados sent / delivered / read).
      <strong>Entregados</strong> = % de esos que llegaron al dispositivo (delivered + read) sobre aceptados.
      <strong>Lectura</strong> = % leídos sobre entregados al dispositivo (read sobre delivered+read); requiere webhooks y lecturas activas en WhatsApp del usuario.
      <strong>Error</strong> = % de filas con fallo sobre el total de registros.
    </p>
    <div class="inbox-empty-hint">
      <span class="inbox-empty-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </span>
      <h2 class="inbox-empty-heading">Campañas</h2>
      <p class="inbox-empty-text">Selecciona una campaña en la lista para ver el registro de envíos, o crea una nueva para lanzar una plantilla Meta a un segmento.</p>
      <% if (typeof templatesSynced !== 'undefined' && templatesSynced) { %>
      <p class="toast toast--ok">Plantillas sincronizadas desde Meta.</p>
      <% } %>
    </div>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
