<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: 'conversations-inbox--detail',
  extraHeadScripts: null
}) %>
<aside class="inbox-sidebar" aria-label="Ajustes">
  <div class="inbox-sidebar-header">
    <h2 class="inbox-sidebar-title">Ajustes</h2>
  </div>
  <ul class="inbox-chat-list">
    <li class="inbox-chat-item is-active">
      <span class="inbox-chat-link" style="cursor: default">
        <span class="inbox-chat-link-main">
          <span class="inbox-chat-row-top">
            <span class="inbox-chat-title">Aplicación</span>
          </span>
          <span class="inbox-chat-row-mid">
            <span class="inbox-chat-preview">Webhook, API y documentación</span>
          </span>
        </span>
      </span>
    </li>
  </ul>
</aside>
<section class="inbox-main" aria-label="Ajustes de la aplicación">
  <div class="inbox-chat-header inbox-chat-header--static">
    <h1 class="inbox-chat-heading">Ajustes</h1>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <div class="card">
      <h2 class="card-title">Integración</h2>
      <div class="config-compact">
        <div>
          <span class="config-k">Webhook</span>
          <code class="config-code"><%= appBaseUrl %>/webhook</code>
        </div>
        <div class="config-links">
          <a href="<%= basePath %>/health">Salud</a>
          <span class="dot">·</span>
          <a href="<%= basePath %>/api/dashboard">API JSON</a>
        </div>
      </div>
      <details class="inline-help">
        <summary>Documentación</summary>
        <p>En el repo: <code>PRODUCCION_WHATSAPP_META.md</code> (índice), <code>DESPLIEGUE_PRODUCCION_APP.md</code> (app/Docker) y <code>CONFIGURACION_META.md</code> (Meta, webhooks, <code>subscribed_apps</code>). Token de sistema con permisos para gestionar plantillas de WhatsApp.</p>
      </details>
    </div>
    <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.isMaster) { %>
    <div class="card" id="settings-ai-area-card">
      <h2 class="card-title">Respuesta automática (IA) · <%= areaLabel %></h2>
      <p class="inbox-compose-hint-inline">
        Solo administrador master. Al desactivar, todos los chats del área pasan a modo Asesor y la IA deja de responder. Al activar, todos los chats vuelven a Bot (reset).
      </p>
      <div class="settings-ai-toggle">
        <label class="settings-ai-switch">
          <input
            type="checkbox"
            id="settings-ai-area-enabled"
            <%= typeof aiAreaEnabled !== 'undefined' && aiAreaEnabled ? 'checked' : '' %>
            data-area="<%= typeof masterArea !== 'undefined' ? masterArea : '' %>"
          />
          <span>IA habilitada para el área</span>
        </label>
        <p class="inline-warn" id="settings-ai-feedback" hidden></p>
      </div>
      <div class="settings-ai-prompt-block">
        <label class="settings-ai-prompt-label" for="settings-ai-prompt">Instrucciones del modelo (system prompt)</label>
        <p class="inbox-compose-hint-inline settings-ai-prompt-hint">
          Define el comportamiento del asistente en esta área. Se aplica a las respuestas automáticas (IA vía Groq).
        </p>
        <textarea
          id="settings-ai-prompt"
          class="settings-ai-prompt-textarea"
          name="ai_prompt"
          rows="10"
          maxlength="32000"
          placeholder="Instrucciones en español para el modelo…"
        ><%= typeof aiPrompt !== 'undefined' ? aiPrompt : '' %></textarea>
        <label class="settings-ai-prompt-label settings-ai-prompt-label--secondary" for="settings-ai-transfer">Palabra clave de transferencia a asesor</label>
        <input
          type="text"
          id="settings-ai-transfer"
          class="settings-ai-transfer-input"
          name="ai_transfer_keyword"
          value="<%= typeof aiTransferKeyword !== 'undefined' ? aiTransferKeyword : '[TRANSFERIR]' %>"
          maxlength="200"
          autocomplete="off"
          placeholder="[TRANSFERIR]"
        />
        <p class="inbox-compose-hint-inline">Si la respuesta del modelo contiene exactamente este texto, el chat pasa a modo Asesor sin enviar mensaje al cliente.</p>
        <div class="settings-ai-prompt-actions">
          <button type="button" class="small-btn" id="settings-ai-save-prompt">Guardar instrucciones</button>
          <span class="settings-ai-prompt-status" id="settings-ai-prompt-status" aria-live="polite"></span>
        </div>
      </div>
    </div>
    <% } %>
    <% if (typeof settingsShowAiPromptEditor !== 'undefined' && settingsShowAiPromptEditor) { %>
    <div class="card" id="settings-business-hours-card">
      <h2 class="card-title">Fuera de horario · <%= areaLabel %></h2>
      <p class="inbox-compose-hint-inline">
        Fuera de este horario se envía el mensaje predefinido <strong>una sola vez</strong> por chat hasta que un asesor lo abra. Aplica en modo Bot y Asesor. No usa IA.
      </p>
      <div class="settings-ai-toggle">
        <label class="settings-ai-switch">
          <input
            type="checkbox"
            id="settings-bh-enabled"
            <%= typeof businessHoursEnabled !== 'undefined' && businessHoursEnabled ? 'checked' : '' %>
            data-area="<%= typeof masterArea !== 'undefined' ? masterArea : '' %>"
          />
          <span>Activar mensaje fuera de horario</span>
        </label>
      </div>
      <fieldset class="campaign-schedule-fieldset" style="margin-top: 1rem; border: none; padding: 0;">
        <legend class="settings-ai-prompt-label">Días de atención</legend>
        <div class="campaign-schedule-options" style="flex-wrap: wrap; gap: 0.75rem;">
          <% const _bhDayLabels = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb']; %>
          <% const _bhDays = typeof businessHoursDays !== 'undefined' && Array.isArray(businessHoursDays) ? businessHoursDays : [1,2,3,4,5]; %>
          <% for (let d = 0; d <= 6; d++) { %>
          <label class="campaign-schedule-option">
            <input type="checkbox" class="settings-bh-day" value="<%= d %>" <%= _bhDays.indexOf(d) >= 0 ? 'checked' : '' %> />
            <%= _bhDayLabels[d] %>
          </label>
          <% } %>
        </div>
      </fieldset>
      <div class="settings-bh-times" style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1rem;">
        <label class="settings-ai-prompt-label">
          Desde
          <input type="time" id="settings-bh-from" class="settings-ai-transfer-input" value="<%= typeof businessHoursFrom !== 'undefined' ? businessHoursFrom : '09:00' %>" />
        </label>
        <label class="settings-ai-prompt-label">
          Hasta
          <input type="time" id="settings-bh-to" class="settings-ai-transfer-input" value="<%= typeof businessHoursTo !== 'undefined' ? businessHoursTo : '18:00' %>" />
        </label>
      </div>
      <p class="inbox-compose-hint-inline">Zona horaria: <%= typeof businessHoursTimezone !== 'undefined' ? businessHoursTimezone : 'America/Lima' %></p>
      <label class="settings-ai-prompt-label" for="settings-bh-message">Mensaje predefinido (fuera de horario)</label>
      <textarea
        id="settings-bh-message"
        class="settings-ai-prompt-textarea"
        rows="5"
        maxlength="4096"
        placeholder="Ej.: Gracias por escribir. Te responderemos en horario de atención (Lun–Vie 9–18h)."
      ><%= typeof businessHoursMessage !== 'undefined' ? businessHoursMessage : '' %></textarea>
      <div class="settings-ai-prompt-actions">
        <button type="button" class="small-btn" id="settings-bh-save">Guardar horario</button>
        <span class="settings-ai-prompt-status" id="settings-bh-status" aria-live="polite"></span>
      </div>
    </div>
    <% } %>
  </div>
</section>
<% if (typeof currentUser !== 'undefined' && currentUser && (currentUser.isMaster || (typeof settingsShowAiPromptEditor !== 'undefined' && settingsShowAiPromptEditor))) { %>
<script>
  (function () {
    var cb = document.getElementById('settings-ai-area-enabled');
    var fb = document.getElementById('settings-ai-feedback');
    var bp = '<%= basePath %>';
    if (cb) {
      cb.addEventListener('change', function () {
        var area = String(cb.getAttribute('data-area') || '').trim();
        if (!area) return;
        fetch(bp + '/api/settings/ai/' + encodeURIComponent(area) + '/enable', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ enabled: cb.checked }),
        })
          .then(function (r) {
            if (!r.ok) return r.json().then(function (j) { throw new Error(j.error || 'Error'); });
            if (fb) {
              fb.hidden = true;
              fb.textContent = '';
            }
          })
          .catch(function (e) {
            cb.checked = !cb.checked;
            if (fb) {
              fb.hidden = false;
              fb.textContent = e.message || 'Error';
            }
          });
      });
    }
    var saveBtn = document.getElementById('settings-ai-save-prompt');
    var ta = document.getElementById('settings-ai-prompt');
    var tk = document.getElementById('settings-ai-transfer');
    var st = document.getElementById('settings-ai-prompt-status');
    if (saveBtn && ta && tk && cb) {
      saveBtn.addEventListener('click', function () {
        var area = String(cb.getAttribute('data-area') || '').trim();
        if (!area) return;
        var prompt = String(ta.value || '').trim();
        if (!prompt) {
          if (st) st.textContent = 'El prompt no puede estar vacío.';
          return;
        }
        var transferKw = String(tk.value || '').trim() || '[TRANSFERIR]';
        saveBtn.disabled = true;
        if (st) st.textContent = 'Guardando…';
        fetch(bp + '/api/settings/ai/' + encodeURIComponent(area), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({
            enabled: cb.checked,
            prompt: prompt,
            transfer_keyword: transferKw,
          }),
        })
          .then(function (r) {
            if (!r.ok) return r.json().then(function (j) { throw new Error(j.error || 'Error'); });
            if (st) st.textContent = 'Guardado.';
            setTimeout(function () {
              if (st) st.textContent = '';
            }, 4000);
          })
          .catch(function (e) {
            if (st) st.textContent = e.message || 'Error';
          })
          .finally(function () {
            saveBtn.disabled = false;
          });
      });
    }
    var bhSave = document.getElementById('settings-bh-save');
    var bhEnabled = document.getElementById('settings-bh-enabled');
    var bhFrom = document.getElementById('settings-bh-from');
    var bhTo = document.getElementById('settings-bh-to');
    var bhMsg = document.getElementById('settings-bh-message');
    var bhSt = document.getElementById('settings-bh-status');
    if (bhSave && bhEnabled && bhFrom && bhTo && bhMsg) {
      bhSave.addEventListener('click', function () {
        var area = String(bhEnabled.getAttribute('data-area') || '').trim();
        if (!area) return;
        var days = [];
        document.querySelectorAll('.settings-bh-day:checked').forEach(function (el) {
          days.push(Number(el.value));
        });
        var payload = {
          enabled: bhEnabled.checked,
          timezone: 'America/Lima',
          days: days,
          from: String(bhFrom.value || '').slice(0, 5),
          to: String(bhTo.value || '').slice(0, 5),
          outside_hours_message: String(bhMsg.value || '').trim(),
        };
        if (payload.enabled && days.length === 0) {
          if (bhSt) bhSt.textContent = 'Selecciona al menos un día.';
          return;
        }
        if (payload.enabled && !payload.outside_hours_message) {
          if (bhSt) bhSt.textContent = 'El mensaje fuera de horario es obligatorio.';
          return;
        }
        bhSave.disabled = true;
        if (bhSt) bhSt.textContent = 'Guardando…';
        fetch(bp + '/api/settings/business-hours/' + encodeURIComponent(area), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(payload),
        })
          .then(function (r) {
            if (!r.ok) return r.json().then(function (j) { throw new Error(j.error || 'Error'); });
            if (bhSt) bhSt.textContent = 'Guardado.';
            setTimeout(function () {
              if (bhSt) bhSt.textContent = '';
            }, 4000);
          })
          .catch(function (e) {
            if (bhSt) bhSt.textContent = e.message || 'Error';
          })
          .finally(function () {
            bhSave.disabled = false;
          });
      });
    }
  })();
</script>
<% } %>
<%- include('layouts/inbox-shell-end') %>
