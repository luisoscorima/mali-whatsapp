<% const _contactSel = typeof selectedContactId !== 'undefined' ? selectedContactId : null; %>
<% const _cq = typeof contactListQuery !== 'undefined' ? contactListQuery : ''; %>
<% const _segF = typeof contactSegmentFilter !== 'undefined' ? contactSegmentFilter : ''; %>
<% const _qF = typeof contactSearchQ !== 'undefined' ? contactSearchQ : ''; %>
<% function contactSegmentColorKey(slug) {
  if (!slug) return 'slate';
  const s = segments.find(function (x) { return x.value === slug; });
  return s && s.colorKey ? s.colorKey : 'slate';
}
%>
<% function contactSegmentLabel(slug) {
  if (!slug) return '';
  const s = segments.find(function (x) { return x.value === slug; });
  return s ? s.label : slug;
}
  var _contactsMobileDetail = view === 'edit' || view === 'new';
%>
<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: _contactsMobileDetail ? 'conversations-inbox--detail' : '',
  extraHeadScripts: null
}) %>
<aside class="inbox-sidebar" aria-label="Contactos">
  <div class="inbox-sidebar-header inbox-sidebar-header--with-actions">
    <h2 class="inbox-sidebar-title">Contactos</h2>
    <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar contactos', refreshAriaLabel: 'Actualizar contactos' }) %>
  </div>
  <div class="inbox-filters inbox-filters--campaign-new">
    <a href="<%= basePath %>/contacts/new<%= _cq %>" class="small-btn primary">Añadir contacto</a>
  </div>
  <form class="inbox-filters" method="get" action="<%= basePath %>/contacts">
    <label class="field field--inbox">
      <span class="field-label">Segmento</span>
      <select name="segment" class="inbox-select" data-inbox-filter>
        <option value="" <%= _segF === '' ? 'selected' : '' %>>Todos</option>
        <% segments.forEach(function (seg) { %>
        <option value="<%= seg.value %>" <%= _segF === seg.value ? 'selected' : '' %>><%= seg.label %></option>
        <% }); %>
      </select>
    </label>
    <label class="field field--inbox">
      <span class="field-label">Buscar número</span>
      <div class="inbox-search-row">
        <input
          type="search"
          name="q"
          value="<%= _qF %>"
          placeholder="Ej. 982160981"
          autocomplete="off"
          class="inbox-search-input"
          inputmode="numeric"
        />
        <button type="submit" class="small-btn primary">Buscar</button>
      </div>
    </label>
  </form>
  <% if (view === 'list' && contacts && contacts.length && segments.length) { %>
  <form
    id="contacts-bulk-segment-form"
    method="POST"
    action="<%= basePath %>/contacts/bulk-add-segment"
    class="inbox-filters contact-bulk-bar"
  >
    <label class="field field--inbox field--grow">
      <span class="field-label">Asignar seleccionados a</span>
      <select name="segment_slug" class="inbox-select" required>
        <option value="">— Segmento —</option>
        <% segments.forEach(function (seg) { %>
        <option value="<%= seg.value %>"><%= seg.label %></option>
        <% }); %>
      </select>
    </label>
    <button type="submit" class="small-btn secondary">Añadir a segmento</button>
  </form>
  <% } %>
  <% if (!contacts || contacts.length === 0) { %>
  <p class="empty-state inbox-empty-list"><%= _segF || _qF ? 'No hay contactos con estos filtros.' : 'No hay contactos en esta área.' %></p>
  <% } else { %>
  <ul class="inbox-chat-list">
    <% contacts.forEach(function (c) { %>
    <li class="inbox-chat-item inbox-chat-item--with-bulk <%= _contactSel === c.id ? 'is-active' : '' %>">
      <% if (view === 'list' && segments.length) { %>
      <input
        type="checkbox"
        class="contact-bulk-cb"
        name="contact_ids"
        value="<%= c.id %>"
        form="contacts-bulk-segment-form"
        aria-label="Seleccionar para asignar a segmento"
        onclick="event.stopPropagation();"
      />
      <% } %>
      <a class="inbox-chat-link" href="<%= basePath %>/contacts/<%= c.id %><%= _cq %>">
        <span class="inbox-chat-link-main">
          <span class="inbox-chat-row-top">
            <span class="inbox-chat-title"><%= c.name || c.phone %></span>
          </span>
          <% if (c.name) { %>
          <span class="inbox-chat-phone mono"><%= c.phone %></span>
          <% } %>
          <span class="inbox-chat-row-mid">
            <span class="inbox-chat-preview contact-segment-chips">
              <% const _slugs = c.segment_slugs || []; %>
              <% if (_slugs.length === 0) { %>
              <span class="inbox-meta-muted">Sin segmento</span>
              <% } else { %>
              <% _slugs.forEach(function (slug) { %>
              <span class="inbox-chat-segment" data-seg-tone="<%= contactSegmentColorKey(slug) %>"><%= contactSegmentLabel(slug) %></span>
              <% }); %>
              <% } %>
            </span>
          </span>
        </span>
      </a>
    </li>
    <% }); %>
  </ul>
  <% } %>
</aside>
<section class="inbox-main" aria-label="Detalle de contactos">
  <% if (view === 'list') { %>
  <div class="inbox-empty-pane" role="status">
    <div class="inbox-empty-hint">
      <span class="inbox-empty-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
      <h2 class="inbox-empty-heading">Contactos</h2>
      <p class="inbox-empty-text">Selecciona un contacto en la lista o añade uno nuevo. Puedes importar un CSV desde «Añadir contacto».</p>
      <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
      <p class="toast toast--ok">Contacto actualizado.</p>
      <% } %>
      <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
      <p class="toast toast--ok">Contacto eliminado.</p>
      <% } %>
    </div>
  </div>
  <% } else if (view === 'new') { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/contacts<%= _cq %>">← Contactos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading">Añadir contacto</h1>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
    <p class="toast toast--ok">Contacto actualizado.</p>
    <% } %>
    <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
    <p class="toast toast--ok">Contacto eliminado.</p>
    <% } %>
    <% if (csvImport) { %>
    <div class="toast <%= csvImport.err ? 'toast--err' : 'toast--ok' %>">
        <% if (csvImport.err) { %>
        <% if (csvImport.err === 'no_file') { %>Selecciona un archivo CSV o Excel.<% } else if (csvImport.err === 'type') { %>Solo archivos .csv o .xlsx.<% } else if (csvImport.err === 'too_big') { %>Archivo demasiado grande.<% } else if (csvImport.err === 'too_many') { %>Demasiadas filas (máx. <%= maxCsvRows %>).<% } else if (csvImport.err === 'empty') { %>Archivo sin datos.<% } else { %>No se pudo leer el archivo.<% } %>
      <% } else { %>
        OK: <%= csvImport.ok %> fila(s).<% if (csvImport.bad > 0) { %> Omitidas: <%= csvImport.bad %>.<% } %>
      <% } %>
    </div>
    <% } %>
    <div class="card">
      <h2 class="card-title">Datos</h2>
      <form method="POST" action="<%= basePath %>/contacts" class="form-grid tight">
        <label class="field">
          <span class="field-label">Nombre</span>
          <input name="name" required <%= segments.length === 0 ? 'disabled' : '' %> />
        </label>
        <div class="inline-fields contact-phone-split">
          <label class="field">
            <span class="field-label">Prefijo país</span>
            <input name="phone_prefix" value="51" maxlength="4" inputmode="numeric" autocomplete="tel-country-code" <%= segments.length === 0 ? 'disabled' : '' %> />
          </label>
          <label class="field contact-phone-local-field">
            <span class="field-label">Número (sin +51)</span>
            <input name="phone_local" required placeholder="982160981" inputmode="numeric" autocomplete="tel-national" <%= segments.length === 0 ? 'disabled' : '' %> />
          </label>
        </div>
        <fieldset class="field segment-chips-fieldset">
          <legend class="field-label">Segmentos</legend>
          <% if (segments.length === 0) { %>
          <p class="inline-warn">Define segmentos en <strong>Segmentos</strong>.</p>
          <% } else { %>
          <div class="segment-checkbox-grid">
            <% segments.forEach(function (segment) { %>
            <label class="segment-checkbox-label">
              <input type="checkbox" name="segments" value="<%= segment.value %>" />
              <span><%= segment.label %></span>
            </label>
            <% }) %>
          </div>
          <p class="inline-help muted">Marca uno o varios.</p>
          <% } %>
        </fieldset>
        <button type="submit" <%= segments.length === 0 ? 'disabled' : '' %>>Guardar</button>
      </form>
    </div>
    <div class="card">
      <h2 class="card-title">Importar CSV o Excel</h2>
      <form method="POST" action="<%= basePath %>/contacts/import" enctype="multipart/form-data" class="form-grid tight">
        <label class="field">
          <span class="field-label">Archivo</span>
          <input type="file" name="csvfile" accept=".csv,.xlsx,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
        </label>
        <div class="row-actions">
          <button type="submit" class="secondary">Importar</button>
          <a class="text-link" href="<%= basePath %>/contacts/sample.csv">Plantilla CSV</a>
        </div>
      </form>
      <details class="inline-help">
        <summary>Formato CSV / Excel</summary>
        <p>
          Columnas: <code>name</code>, <code>phone</code>, <code>segment</code>. Opcional: <code>prefix</code> (código de país sin +) para números internacionales.
          En <code>segment</code> puedes indicar varios slugs separados por <code>;</code> o <code>,</code>.
          Sin <code>prefix</code>, se aceptan móviles Perú de 9 dígitos (ej. <code>982160981</code>, se guarda como 51…) o un número E.164 completo sin +.
          Si el teléfono ya existe, se actualizan nombre y segmentos (se reemplazan por los de la fila).
        </p>
      </details>
    </div>
  </div>
  <% } else if (view === 'edit' && contact) { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/contacts<%= _cq %>">← Contactos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading"><%= contact.name || contact.phone %></h1>
      <p class="inbox-chat-sub mono"><%= contact.phone %></p>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
    <p class="toast toast--ok">Contacto actualizado.</p>
    <% } %>
    <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
    <p class="toast toast--ok">Contacto eliminado.</p>
    <% } %>
    <div class="card">
      <h2 class="card-title">Editar contacto</h2>
      <form method="POST" action="<%= basePath %>/contacts/<%= contact.id %>/update" class="form-grid tight">
        <label class="field">
          <span class="field-label">Nombre</span>
          <input type="text" name="name" value="<%= contact.name %>" required maxlength="150" />
        </label>
        <label class="field">
          <span class="field-label">Teléfono (E.164 sin +)</span>
          <input type="text" name="phone" value="<%= contact.phone %>" required inputmode="numeric" />
        </label>
        <fieldset class="field segment-chips-fieldset">
          <legend class="field-label">Segmentos</legend>
          <div class="segment-checkbox-grid">
            <% const _editSlugs = contact.segment_slugs || []; %>
            <% segments.forEach(function (segment) { %>
            <label class="segment-checkbox-label">
              <input
                type="checkbox"
                name="segments"
                value="<%= segment.value %>"
                <%= _editSlugs.indexOf(segment.value) !== -1 ? 'checked' : '' %>
              />
              <span><%= segment.label %></span>
            </label>
            <% }) %>
          </div>
          <p class="inline-help muted">Marca uno o varios.</p>
        </fieldset>
        <div class="form-actions">
          <button type="submit">Guardar cambios</button>
        </div>
      </form>
      <form method="POST" action="<%= basePath %>/contacts/<%= contact.id %>/delete" class="inline-delete-form" onsubmit="return confirm('¿Eliminar este contacto?');">
        <button type="submit" class="small-btn danger-outline">Eliminar contacto</button>
      </form>
    </div>
  </div>
  <% } %>
</section>
<script>
  (function () {
    document.querySelectorAll('[data-inbox-filter]').forEach(function (el) {
      el.addEventListener('change', function () {
        if (el.form) el.form.submit();
      });
    });
  })();
</script>
<%- include('layouts/inbox-shell-end') %>
