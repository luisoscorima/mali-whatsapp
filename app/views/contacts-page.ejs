<% const _contactSel = typeof selectedContactId !== 'undefined' ? selectedContactId : null; %>
<% const _cq = typeof contactListQuery !== 'undefined' ? contactListQuery : ''; %>
<% const _segF = typeof contactSegmentFilter !== 'undefined' ? contactSegmentFilter : ''; %>
<% const _qF = typeof contactSearchQ !== 'undefined' ? contactSearchQ : ''; %>
<% const _showReplaced = typeof showReplaced !== 'undefined' ? Boolean(showReplaced) : false; %>
<% const _prefillName = typeof prefillName !== 'undefined' ? prefillName : ''; %>
<% const _prefillPhonePrefix = typeof prefillPhonePrefix !== 'undefined' ? prefillPhonePrefix : '51'; %>
<% const _prefillPhoneLocal = typeof prefillPhoneLocal !== 'undefined' ? prefillPhoneLocal : ''; %>
<% function contactSegmentColorKey(slug) {
  if (!slug) return 'slate';
  const s = segments.find(function (x) { return x.value === slug; });
  return s && s.colorKey ? s.colorKey : 'slate';
}
%>
<% function contactSegmentLabel(slug) {
  if (!slug) return '';
  const s = segments.find(function (x) { return x.value === slug; });
  return s ? s.label : slug;
}
  var _contactsMobileDetail = view === 'edit' || view === 'new' || view === 'import';
%>
<%- include('layouts/inbox-shell-start', {
  pageTitle,
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav,
  showAdminNav,
  shellPageClass: 'conversations-page',
  layoutModifier: _contactsMobileDetail ? 'conversations-inbox--detail' : '',
  extraHeadScripts: null
}) %>
<aside class="inbox-sidebar" aria-label="Contactos">
  <div class="inbox-sidebar-header inbox-sidebar-header--with-actions">
    <h2 class="inbox-sidebar-title">Contactos</h2>
    <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar contactos', refreshAriaLabel: 'Actualizar contactos' }) %>
  </div>
  <div class="inbox-filters inbox-filters--campaign-new contact-actions-row-wrap">
    <div class="contact-actions-row" role="group" aria-label="Añadir o importar contactos">
      <a
        href="<%= basePath %>/contacts/new<%= _cq %>"
        class="contact-action-tile <%= view === 'new' ? 'is-active' : '' %>"
        aria-label="Añadir un contacto"
        <% if (view === 'new') { %>aria-current="page"<% } %>
      >
        <span class="contact-action-tile__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <line x1="19" y1="8" x2="19" y2="14" />
            <line x1="22" y1="11" x2="16" y2="11" />
          </svg>
        </span>
        <span class="contact-action-tile__label">Añadir</span>
      </a>
      <a
        href="<%= basePath %>/contacts/import<%= _cq %>"
        class="contact-action-tile <%= view === 'import' ? 'is-active' : '' %>"
        aria-label="Importar desde Excel o CSV"
        <% if (view === 'import') { %>aria-current="page"<% } %>
      >
        <span class="contact-action-tile__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <path d="M12 18V9" />
            <polyline points="9 12 12 9 15 12" />
          </svg>
        </span>
        <span class="contact-action-tile__label">Excel</span>
      </a>
    </div>
  </div>
  <form class="inbox-filters" method="get" action="<%= basePath %>/contacts">
    <label class="field field--inbox">
      <span class="field-label">Segmento</span>
      <select name="segment" class="inbox-select" data-inbox-filter>
        <option value="" <%= _segF === '' ? 'selected' : '' %>>Todos</option>
        <% segments.forEach(function (seg) { %>
        <option value="<%= seg.value %>" <%= _segF === seg.value ? 'selected' : '' %>><%= seg.label %></option>
        <% }); %>
      </select>
    </label>
    <label class="field field--inbox">
      <span class="field-label">Buscar número o nombre</span>
      <div class="inbox-search-row">
        <input
          type="search"
          name="q"
          value="<%= _qF %>"
          placeholder="Ej. 982160981 o Juan Pérez"
          autocomplete="off"
          class="inbox-search-input"
        />
        <button type="submit" class="small-btn primary">Buscar</button>
      </div>
    </label>
    <label class="field field--inbox">
      <span class="field-label">Mostrar reemplazados</span>
      <select name="show_replaced" class="inbox-select" data-inbox-filter>
        <option value="0" <%= !_showReplaced ? 'selected' : '' %>>No</option>
        <option value="1" <%= _showReplaced ? 'selected' : '' %>>Sí</option>
      </select>
    </label>
  </form>
  <% if (view === 'list' && contacts && contacts.length && segments.length) { %>
  <span id="contact-bulk-live" class="sr-only" aria-live="polite"></span>
  <div id="contact-bulk-root" class="contact-bulk-compact" hidden>
    <div class="contact-bulk-compact__row">
      <button type="button" class="small-btn ghost contact-bulk-mini" id="contact-bulk-select-all">
        Seleccionar todos
      </button>
      <button type="button" class="small-btn ghost contact-bulk-mini" id="contact-bulk-select-none">
        Quitar selección
      </button>
      <button
        type="button"
        class="contact-bulk-plus-btn"
        id="contact-bulk-toggle"
        aria-expanded="false"
        aria-controls="contact-bulk-panel"
        title="Elegir segmento y aplicar"
      >
        <span aria-hidden="true">+</span>
      </button>
    </div>
    <div id="contact-bulk-panel" class="contact-bulk-panel" hidden>
      <form
        id="contacts-bulk-segment-form"
        method="POST"
        action="<%= basePath %>/contacts/bulk-add-segment"
        class="contact-bulk-panel__form"
      >
        <label class="contact-bulk-panel__field">
          <span class="sr-only">Segmento</span>
          <select name="segment_slug" class="inbox-select contact-bulk-panel__select" required>
            <option value="">— Segmento —</option>
            <% segments.forEach(function (seg) { %>
            <option value="<%= seg.value %>"><%= seg.label %></option>
            <% }); %>
          </select>
        </label>
        <button type="submit" class="small-btn primary contact-bulk-panel__submit">Aplicar</button>
      </form>
    </div>
  </div>
  <% } %>
  <% if (!contacts || contacts.length === 0) { %>
  <p class="empty-state inbox-empty-list"><%= _segF || _qF ? 'No hay contactos con estos filtros.' : 'No hay contactos en esta área.' %></p>
  <% } else { %>
  <ul class="inbox-chat-list">
    <% contacts.forEach(function (c) { %>
    <li class="inbox-chat-item inbox-chat-item--with-bulk <%= _contactSel === c.id ? 'is-active' : '' %>">
      <% if (view === 'list' && segments.length) { %>
      <label class="contact-bulk-hit">
        <input
          type="checkbox"
          class="contact-bulk-cb"
          name="contact_ids"
          value="<%= c.id %>"
          form="contacts-bulk-segment-form"
        />
        <span class="sr-only">Seleccionar contacto</span>
      </label>
      <% } %>
      <a class="inbox-chat-link" href="<%= basePath %>/contacts/<%= c.id %><%= _cq %>">
        <span class="inbox-chat-link-main">
          <span class="inbox-chat-row-top">
            <span class="inbox-chat-title"><%= c.name || c.phone %></span>
          </span>
          <% if (c.name) { %>
          <span class="inbox-chat-phone mono"><%= c.phone %></span>
          <% } %>
          <span class="inbox-chat-row-mid">
            <span class="inbox-chat-preview contact-segment-chips">
              <% const _slugs = c.segment_slugs || []; %>
              <% if (_slugs.length === 0) { %>
              <span class="inbox-meta-muted">Sin segmento</span>
              <% } else { %>
              <% _slugs.forEach(function (slug) { %>
              <span class="inbox-chat-segment inbox-chat-segment--contact-pill" data-seg-tone="<%= contactSegmentColorKey(slug) %>"><%= contactSegmentLabel(slug) %></span>
              <% }); %>
              <% } %>
            </span>
          </span>
        </span>
      </a>
    </li>
    <% }); %>
  </ul>
  <% } %>
</aside>
<section class="inbox-main" aria-label="Detalle de contactos">
  <% if (view === 'list') { %>
  <div class="inbox-empty-pane" role="status">
    <div class="inbox-empty-hint">
      <span class="inbox-empty-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
      <h2 class="inbox-empty-heading">Contactos</h2>
      <p class="inbox-empty-text">Selecciona un contacto en la lista, usa <strong>Añadir</strong> para uno solo o <strong>Excel</strong> para importar CSV / Excel.</p>
      <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
      <p class="toast toast--ok">Contacto actualizado.</p>
      <% } %>
      <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
      <p class="toast toast--ok">Contacto eliminado.</p>
      <% } %>
    </div>
  </div>
  <% } else if (view === 'new') { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/contacts<%= _cq %>">← Contactos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading">Añadir contacto</h1>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
    <p class="toast toast--ok">Contacto actualizado.</p>
    <% } %>
    <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
    <p class="toast toast--ok">Contacto eliminado.</p>
    <% } %>
    <div class="card">
      <h2 class="card-title">Datos</h2>
      <form method="POST" action="<%= basePath %>/contacts" class="form-grid tight">
        <label class="field">
          <span class="field-label">Nombre</span>
          <input name="name" value="<%= _prefillName %>" required autofocus <%= segments.length === 0 ? 'disabled' : '' %> />
        </label>
        <div class="inline-fields contact-phone-split">
          <label class="field">
            <span class="field-label">Prefijo país</span>
            <input name="phone_prefix" value="<%= _prefillPhonePrefix %>" maxlength="4" inputmode="numeric" autocomplete="tel-country-code" <%= segments.length === 0 ? 'disabled' : '' %> />
          </label>
          <label class="field contact-phone-local-field">
            <span class="field-label">Número (sin +51)</span>
            <input name="phone_local" value="<%= _prefillPhoneLocal %>" required placeholder="982160981" inputmode="numeric" autocomplete="tel-national" <%= segments.length === 0 ? 'disabled' : '' %> />
          </label>
        </div>
        <fieldset class="field segment-chips-fieldset">
          <legend class="field-label">Segmentos</legend>
          <% if (segments.length === 0) { %>
          <p class="inline-warn">Define segmentos en <strong>Segmentos</strong>.</p>
          <% } else { %>
          <div class="segment-checkbox-grid segment-checkbox-grid--responsive">
            <% segments.forEach(function (segment) { %>
            <label class="segment-checkbox-label">
              <input type="checkbox" name="segments" value="<%= segment.value %>" />
              <span><%= segment.label %></span>
            </label>
            <% }) %>
          </div>
          <p class="inline-help muted">Marca uno o varios.</p>
          <% } %>
        </fieldset>
        <button type="submit" <%= segments.length === 0 ? 'disabled' : '' %>>Guardar</button>
      </form>
    </div>
  </div>
  <% } else if (view === 'import') { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/contacts<%= _cq %>">← Contactos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading">Importar Excel</h1>
      <p class="inbox-chat-sub">CSV o .xlsx masivo</p>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (csvImport) { %>
    <div class="toast <%= csvImport.err ? 'toast--err' : 'toast--ok' %>">
        <% if (csvImport.err) { %>
        <% if (csvImport.err === 'no_file') { %>Selecciona un archivo CSV o Excel.<% } else if (csvImport.err === 'type') { %>Solo archivos .csv o .xlsx.<% } else if (csvImport.err === 'too_big') { %>Archivo demasiado grande.<% } else if (csvImport.err === 'too_many') { %>Demasiadas filas (máx. <%= maxCsvRows %>).<% } else if (csvImport.err === 'empty') { %>Archivo sin datos.<% } else { %>No se pudo leer el archivo.<% } %>
      <% } else { %>
        OK: <%= csvImport.ok %> fila(s).<% if (csvImport.bad > 0) { %> Omitidas: <%= csvImport.bad %>.<% } %>
        <% if (csvImport.dup && csvImport.dup > 0) { %>
        Aviso: <%= csvImport.dup %> teléfono(s) repetido(s) en archivo (<%= csvImport.dupRows %> fila(s) involucrada(s)); aplica "last row wins".
        <% if (csvImport.dupExamples && csvImport.dupExamples.length) { %>
        Ejemplos: <%= csvImport.dupExamples.join(', ') %>.
        <% } %>
        <% } %>
      <% } %>
    </div>
    <% } %>
    <div class="card">
      <h2 class="card-title">Archivo</h2>
      <form method="POST" action="<%= basePath %>/contacts/import" enctype="multipart/form-data" class="form-grid tight">
        <label class="field">
          <span class="field-label">CSV o Excel</span>
          <input type="file" name="csvfile" accept=".csv,.xlsx,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
        </label>
        <div class="row-actions">
          <button type="submit" class="secondary">Importar</button>
          <a class="text-link" href="<%= basePath %>/contacts/sample.csv">Plantilla CSV</a>
        </div>
      </form>
      <details class="inline-help">
        <summary>Formato CSV / Excel</summary>
        <p>
          Columnas: <code>name</code>, <code>phone</code>, <code>segment</code>. Opcional: <code>prefix</code> (código de país sin +) para números internacionales.
          En <code>segment</code> puedes indicar varios slugs separados por <code>;</code> o <code>,</code>.
          Sin <code>prefix</code>, se aceptan móviles Perú de 9 dígitos (ej. <code>982160981</code>, se guarda como 51…) o un número E.164 completo sin +.
          Si el teléfono ya existe, se actualizan nombre y segmentos (se reemplazan por los de la fila). Si el archivo trae teléfonos repetidos, gana la última fila.
        </p>
      </details>
    </div>
  </div>
  <% } else if (view === 'edit' && contact) { %>
  <div class="inbox-chat-header">
    <a class="inbox-back-mobile" href="<%= basePath %>/contacts<%= _cq %>">← Contactos</a>
    <div class="inbox-chat-header-main">
      <h1 class="inbox-chat-heading"><%= contact.name || contact.phone %></h1>
      <p class="inbox-chat-sub mono"><%= contact.phone %></p>
    </div>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
    <p class="toast toast--ok">Contacto actualizado.</p>
    <% } %>
    <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
    <p class="toast toast--ok">Contacto eliminado.</p>
    <% } %>
    <div class="card">
      <h2 class="card-title">Editar contacto</h2>
      <% const _isReplaced = Boolean(contact.replacement_reason) || contact.replaced_by_contact_id != null; %>
      <% if (_isReplaced) { %>
      <p class="toast toast--warn">
        Este contacto está reemplazado (<%= contact.replacement_reason || 'replaced' %>) y no se puede editar.
      </p>
      <% } %>
      <form method="POST" action="<%= basePath %>/contacts/<%= contact.id %>/update" class="form-grid tight">
        <label class="field">
          <span class="field-label">Nombre</span>
          <input type="text" name="name" value="<%= contact.name %>" required maxlength="150" <%= _isReplaced ? 'disabled' : '' %> />
        </label>
        <label class="field">
          <span class="field-label">Teléfono (E.164 sin +)</span>
          <input type="text" name="phone" value="<%= contact.phone %>" required inputmode="numeric" <%= _isReplaced ? 'disabled' : '' %> />
        </label>
        <fieldset class="field segment-chips-fieldset">
          <legend class="field-label">Segmentos</legend>
          <div class="segment-checkbox-grid segment-checkbox-grid--responsive">
            <% const _editSlugs = contact.segment_slugs || []; %>
            <% segments.forEach(function (segment) { %>
            <label class="segment-checkbox-label">
              <input
                type="checkbox"
                name="segments"
                value="<%= segment.value %>"
                <%= _editSlugs.indexOf(segment.value) !== -1 ? 'checked' : '' %>
                <%= _isReplaced ? 'disabled' : '' %>
              />
              <span><%= segment.label %></span>
            </label>
            <% }) %>
          </div>
          <p class="inline-help muted">Marca uno o varios.</p>
        </fieldset>
        <div class="form-actions">
          <button type="submit" <%= _isReplaced ? 'disabled' : '' %>>Guardar cambios</button>
        </div>
      </form>
      <% if (_isReplaced) { %>
      <form method="POST" action="<%= basePath %>/contacts/<%= contact.id %>/reactivate" class="inline-delete-form" onsubmit="return confirm('¿Reactivar este contacto?');">
        <button type="submit" class="small-btn">Reactivar contacto</button>
      </form>
      <% } %>
      <form method="POST" action="<%= basePath %>/contacts/<%= contact.id %>/delete" class="inline-delete-form" onsubmit="return confirm('¿Eliminar este contacto?');">
        <button type="submit" class="small-btn danger-outline">Eliminar contacto</button>
      </form>
    </div>
  </div>
  <% } %>
</section>
<script>
  (function () {
    document.querySelectorAll('[data-inbox-filter]').forEach(function (el) {
      el.addEventListener('change', function () {
        if (el.form) el.form.submit();
      });
    });

    var liveEl = document.getElementById('contact-bulk-live');
    var rootEl = document.getElementById('contact-bulk-root');
    var panelEl = document.getElementById('contact-bulk-panel');
    var toggleEl = document.getElementById('contact-bulk-toggle');
    var cbs = document.querySelectorAll('.contact-bulk-cb');

    function closeBulkPanel() {
      if (panelEl) panelEl.hidden = true;
      if (toggleEl) toggleEl.setAttribute('aria-expanded', 'false');
    }

    function openBulkPanel() {
      if (panelEl) panelEl.hidden = false;
      if (toggleEl) toggleEl.setAttribute('aria-expanded', 'true');
      var sel = panelEl && panelEl.querySelector('select[name="segment_slug"]');
      if (sel) setTimeout(function () { sel.focus(); }, 0);
    }

    if (rootEl && cbs.length) {
      function updateBulkSelection() {
        var n = 0;
        cbs.forEach(function (cb) {
          if (cb.checked) n += 1;
        });
        if (liveEl) {
          liveEl.textContent =
            n === 0 ? '' : n === 1 ? '1 contacto seleccionado' : n + ' contactos seleccionados';
        }
        rootEl.hidden = n === 0;
        if (n === 0) {
          closeBulkPanel();
        }
      }

      cbs.forEach(function (cb) {
        cb.addEventListener('change', updateBulkSelection);
      });

      var allBtn = document.getElementById('contact-bulk-select-all');
      var noneBtn = document.getElementById('contact-bulk-select-none');
      if (allBtn) {
        allBtn.addEventListener('click', function () {
          cbs.forEach(function (cb) {
            cb.checked = true;
          });
          updateBulkSelection();
        });
      }
      if (noneBtn) {
        noneBtn.addEventListener('click', function () {
          cbs.forEach(function (cb) {
            cb.checked = false;
          });
          updateBulkSelection();
        });
      }

      if (toggleEl && panelEl) {
        toggleEl.addEventListener('click', function (ev) {
          ev.stopPropagation();
          if (rootEl.hidden) return;
          if (panelEl.hidden) {
            openBulkPanel();
          } else {
            closeBulkPanel();
          }
        });
        panelEl.addEventListener('click', function (ev) {
          ev.stopPropagation();
        });
        document.addEventListener('click', function () {
          if (!panelEl.hidden) {
            closeBulkPanel();
          }
        });
      }

      updateBulkSelection();
    }
  })();
</script>
<%- include('layouts/inbox-shell-end') %>
