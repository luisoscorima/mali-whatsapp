<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MALI WhatsApp</title>
    <script>
      try {
        var _t = localStorage.getItem('mali-theme');
        if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
    <link rel="stylesheet" href="<%= basePath %>/css/wa-shell.css" />
    <script src="<%= basePath %>/js/theme.js" defer></script>
    <script src="<%= basePath %>/js/campaign-template.js" defer></script>
  </head>
  <body class="wa-body-dashboard">
    <div class="wa-layout wa-layout--dashboard">
      <%- include('partials/wa-rail', { basePath, appBaseUrl, activeNav: typeof activeNav !== 'undefined' ? activeNav : 'dashboard', showAdminNav: typeof showAdminNav !== 'undefined' ? showAdminNav : false, requireAuth, currentUser, areaLabel }) %>

      <div class="wa-main-column">
        <main class="main-panel wa-main-panel">
        <% const totals = campaigns.reduce((acc, campaign) => {
            acc.sent += Number(campaign.sent_count || 0);
            acc.delivered += Number(campaign.delivered_count || 0);
            acc.read += Number(campaign.read_count || 0);
            acc.failed += Number(campaign.failed_count || 0);
            return acc;
          }, { sent: 0, delivered: 0, read: 0, failed: 0 });
          const deliveryRate = totals.sent ? Math.round((totals.delivered / totals.sent) * 100) : 0;
          const readRate = totals.sent ? Math.round((totals.read / totals.sent) * 100) : 0;
          const errorRate = totals.sent ? Math.round((totals.failed / totals.sent) * 100) : 0;
        %>
        <section class="content-section is-active" id="send-campaign">
          <div class="card">
            <h2 class="card-title">Nueva campaña</h2>
            <% if (templatesSynced) { %>
            <p class="toast toast--ok">Plantillas sincronizadas desde Meta.</p>
            <% } %>
            <div class="template-sync-row">
              <form method="POST" action="<%= basePath %>/templates/sync" class="inline-form-sync">
                <button type="submit" class="secondary">Sincronizar plantillas</button>
              </form>
              <p class="card-lead template-sync-hint">Trae la lista actualizada de plantillas <strong>aprobadas</strong> de tu cuenta WhatsApp (Meta). Hazlo cuando cambien o aprueben nuevas.</p>
            </div>
            <% if (!syncedTemplates || syncedTemplates.length === 0) { %>
            <p class="inline-warn">No hay plantillas en caché. Pulsa <strong>Sincronizar plantillas</strong> (requiere token con permisos para la cuenta de WhatsApp).</p>
            <% } %>
            <form method="POST" action="<%= basePath %>/campaigns/send" class="form-grid" id="campaign-form" data-base-path="<%= basePath %>">
              <div class="form-section">
                <span class="form-section-label">Quién recibe</span>
                <label class="field">
                  <span class="field-label">Segmento</span>
                  <% if (segments.length === 0) { %>
                  <p class="inline-warn">Añade segmentos en la sección <strong>Segmentos</strong>.</p>
                  <select name="segment" disabled>
                    <option value="">—</option>
                  </select>
                  <% } else { %>
                  <select name="segment" required>
                    <% segments.forEach((segment) => { %>
                      <option value="<%= segment.value %>"><%= segment.label %></option>
                    <% }) %>
                  </select>
                  <% } %>
                </label>
              </div>

              <div class="form-section">
                <span class="form-section-label">Plantilla (Meta)</span>
                <label class="field">
                  <span class="field-label">Seleccionar plantilla</span>
                  <select name="templateSyncId" id="template-sync-select" required <%= (!syncedTemplates || syncedTemplates.length === 0) ? 'disabled' : '' %>>
                    <option value="">— Elige una plantilla —</option>
                    <% if (syncedTemplates && syncedTemplates.length) { %>
                      <% syncedTemplates.forEach((t) => { %>
                        <option value="<%= t.id %>"><%= t.name %> · <%= t.language %> · <%= t.category || '—' %></option>
                      <% }) %>
                    <% } %>
                  </select>
                </label>
              </div>

              <div id="dynamic-template-fields" class="form-section" hidden></div>

              <div class="form-section">
                <span class="form-section-label">Envío</span>
                <div class="field-row">
                  <label class="field">
                    <span class="field-label">Lote</span>
                    <input type="number" name="batchSize" value="40" min="1" max="100" />
                  </label>
                  <label class="field">
                    <span class="field-label">Pausa (ms)</span>
                    <input type="number" name="batchDelayMs" value="1500" min="0" step="500" />
                  </label>
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" <%= segments.length === 0 || !syncedTemplates || syncedTemplates.length === 0 ? 'disabled' : '' %>>Enviar campaña</button>
              </div>
            </form>
          </div>
        </section>

        <section class="content-section" id="contacts">
            <div class="card">
              <h2 class="card-title">Añadir contacto</h2>
              <% if (typeof contactUpdated !== 'undefined' && contactUpdated) { %>
              <p class="toast toast--ok">Contacto actualizado.</p>
              <% } %>
              <% if (typeof contactDeleted !== 'undefined' && contactDeleted) { %>
              <p class="toast toast--ok">Contacto eliminado.</p>
              <% } %>
              <% if (csvImport) { %>
              <div class="toast <%= csvImport.err ? 'toast--err' : 'toast--ok' %>">
                <% if (csvImport.err) { %>
                  <% if (csvImport.err === 'no_file') { %>Selecciona un archivo CSV.<% } else if (csvImport.err === 'type') { %>Solo archivos .csv.<% } else if (csvImport.err === 'too_big') { %>Archivo demasiado grande.<% } else if (csvImport.err === 'too_many') { %>Demasiadas filas (máx. <%= maxCsvRows %>).<% } else if (csvImport.err === 'empty') { %>CSV sin datos.<% } else { %>No se pudo leer el CSV.<% } %>
                <% } else { %>
                  OK: <%= csvImport.ok %> fila(s).<% if (csvImport.bad > 0) { %> Omitidas: <%= csvImport.bad %>.<% } %>
                <% } %>
              </div>
              <% } %>
              <form method="POST" action="<%= basePath %>/contacts" class="form-grid tight">
                <label class="field">
                  <span class="field-label">Nombre</span>
                  <input name="name" required <%= segments.length === 0 ? 'disabled' : '' %> />
                </label>
                <label class="field">
                  <span class="field-label">Teléfono (E.164 sin +)</span>
                  <input name="phone" required placeholder="51999999999" inputmode="numeric" <%= segments.length === 0 ? 'disabled' : '' %> />
                </label>
                <label class="field">
                  <span class="field-label">Segmento</span>
                  <% if (segments.length === 0) { %>
                  <p class="inline-warn">Define segmentos en <strong>Segmentos</strong>.</p>
                  <select name="segment" disabled>
                    <option value="">—</option>
                  </select>
                  <% } else { %>
                  <select name="segment" required>
                    <% segments.forEach((segment) => { %>
                      <option value="<%= segment.value %>"><%= segment.label %></option>
                    <% }) %>
                  </select>
                  <% } %>
                </label>
                <button type="submit" <%= segments.length === 0 ? 'disabled' : '' %>>Guardar</button>
              </form>

              <div class="divider"></div>
              <h3 class="card-subtitle">Importar CSV</h3>
              <form method="POST" action="<%= basePath %>/contacts/import" enctype="multipart/form-data" class="form-grid tight">
                <label class="field">
                  <span class="field-label">Archivo</span>
                  <input type="file" name="csvfile" accept=".csv,text/csv" required />
                </label>
                <div class="row-actions">
                  <button type="submit" class="secondary">Importar</button>
                  <a class="text-link" href="<%= basePath %>/contacts/sample.csv">Plantilla CSV</a>
                </div>
              </form>
              <details class="inline-help">
                <summary>Formato del CSV</summary>
                <p>Columnas: <code>name</code>, <code>phone</code>, <code>segment</code>. Si el teléfono ya existe, se actualiza.</p>
              </details>
            </div>
        </section>

        <section class="content-section" id="segments">
          <div class="card">
            <h2 class="card-title">Segmentos</h2>
            <p class="card-lead">Por área (<strong><%= areaLabel %></strong>). En cada fila puedes editar <strong>slug</strong> (identificador en CSV y campañas), <strong>etiqueta</strong> y <strong>orden</strong>. Si cambias el slug, se actualizan los contactos y el histórico de campañas de ese segmento en esta área.</p>
            <% if (segmentsSaved) { %>
            <p class="toast toast--ok">Segmentos actualizados.</p>
            <% } %>
            <h3 class="card-subtitle">Añadir segmento</h3>
            <form method="POST" action="<%= basePath %>/settings/segment-add" class="form-grid tight segment-add-form">
              <label class="field">
                <span class="field-label">Slug</span>
                <input name="slug" required pattern="[a-z0-9_]{1,50}" placeholder="ej.: vip_cliente" autocomplete="off" title="Solo minúsculas, números y guion bajo" />
              </label>
              <label class="field">
                <span class="field-label">Etiqueta</span>
                <input name="label" required maxlength="120" placeholder="Nombre visible" />
              </label>
              <label class="field">
                <span class="field-label">Orden</span>
                <input type="number" name="sort_order" value="0" step="1" />
              </label>
              <button type="submit">Añadir segmento</button>
            </form>
          </div>
        </section>

        <section class="content-section" id="history">
          <div class="card card--history">
            <div class="metrics-row metrics-row--history" role="region" aria-label="Resumen de envíos">
            <div class="metric">
              <span class="metric-num"><%= totals.sent %></span>
              <span class="metric-lbl">Enviados</span>
            </div>
            <div class="metric">
              <span class="metric-num"><%= deliveryRate %>%</span>
              <span class="metric-lbl">Entrega</span>
            </div>
            <div class="metric">
              <span class="metric-num"><%= readRate %>%</span>
              <span class="metric-lbl">Lectura</span>
            </div>
            <div class="metric">
              <span class="metric-num"><%= errorRate %>%</span>
              <span class="metric-lbl">Error</span>
            </div>
            </div>
            <h2 class="card-title">Campañas recientes</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Segmento</th>
                    <th>Estado</th>
                    <th>Avance</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% campaigns.forEach((campaign) => { %>
                    <% const base = Number(campaign.total_recipients || 0) || 1; %>
                    <% const pct = Math.min(100, Math.round((Number(campaign.sent_count || 0) / base) * 100)); %>
                    <tr>
                      <td class="mono"><%= campaign.id %></td>
                      <td><%= campaign.segment %></td>
                      <td><span class="badge <%= campaign.status %>"><%= campaign.status %></span></td>
                      <td>
                        <div class="progress-meta"><span><%= pct %>%</span><span><%= campaign.sent_count || 0 %>/<%= campaign.total_recipients %></span></div>
                        <div class="progress-bar"><span style="width: <%= pct %>%"></span></div>
                      </td>
                      <td>
                        <button type="button" class="text-link js-campaign-detail-btn" data-campaign-id="<%= campaign.id %>">Detalle</button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="content-section" id="configuration">
          <div class="card">
            <h2 class="card-title">Ajustes</h2>
            <div class="config-compact">
              <div>
                <span class="config-k">Webhook</span>
                <code class="config-code"><%= appBaseUrl %>/webhook</code>
              </div>
              <div class="config-links">
                <a href="<%= basePath %>/health">Salud</a>
                <span class="dot">·</span>
                <a href="<%= basePath %>/api/dashboard">API JSON</a>
              </div>
            </div>
            <details class="inline-help">
              <summary>Documentación</summary>
              <p><code>PRODUCCION_WHATSAPP_META.md</code> en el proyecto. Token de sistema con permisos para gestionar plantillas de WhatsApp.</p>
            </details>
          </div>
        </section>

        </main>
      </div>

      <aside class="wa-tertiary" aria-label="Panel lateral">
        <div class="wa-tertiary-inner wa-tertiary-inner--dashboard-panels">
          <div class="wa-tertiary-panel wa-tertiary-panel--hint is-active" data-tertiary-panel="send-campaign">
            <div class="wa-placeholder wa-placeholder--tab-hint" role="status">
              <span class="wa-placeholder-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              </span>
              <h2 class="wa-placeholder-title">Envío masivo</h2>
              <p class="wa-placeholder-text">Plantillas Meta y segmentos: completa el formulario en la columna central para lanzar una campaña.</p>
            </div>
          </div>
          <div class="wa-tertiary-panel <%= contacts.length === 0 && stats.length === 0 ? 'wa-tertiary-panel--hint' : '' %>" data-tertiary-panel="contacts">
            <% if (contacts.length === 0 && stats.length === 0) { %>
            <div class="wa-placeholder wa-placeholder--tab-hint" role="status">
              <span class="wa-placeholder-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </span>
              <h2 class="wa-placeholder-title">Contactos</h2>
              <p class="wa-placeholder-text">Aún no hay contactos en esta área. Añade uno o importa un CSV desde la columna central.</p>
            </div>
            <% } else { %>
            <div class="card wa-tertiary-card">
              <h2 class="card-title">Activos por segmento</h2>
              <div class="segment-tags">
                <% if (stats.length === 0) { %>
                  <p class="empty-state">Sin contactos aún</p>
                <% } %>
                <% stats.forEach((item) => { %>
                  <span class="segment-pill"><%= item.segment %> · <strong><%= item.total %></strong></span>
                <% }) %>
              </div>
              <h3 class="card-subtitle">Listado (hasta 400, más recientes primero)</h3>
              <div class="table-wrap table-wrap--compact">
                <table class="contacts-table">
                  <thead>
                    <tr>
                      <th>Nombre</th>
                      <th>Tel.</th>
                      <th>Segmento</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (contacts.length === 0) { %>
                      <tr>
                        <td colspan="4" class="empty-state">No hay contactos en esta área.</td>
                      </tr>
                    <% } %>
                    <% contacts.forEach((contact) => { %>
                      <% const contactPayload = encodeURIComponent(JSON.stringify({ id: contact.id, name: contact.name, phone: contact.phone, segment: contact.segment })); %>
                      <tr>
                        <td><%= contact.name %></td>
                        <td class="mono"><%= contact.phone %></td>
                        <td><span class="badge neutral"><%= contact.segment %></span></td>
                        <td class="contacts-actions-cell">
                          <button type="button" class="secondary small-btn js-edit-contact" data-contact="<%= contactPayload %>">Editar</button>
                          <form method="POST" action="<%= basePath %>/contacts/<%= contact.id %>/delete" class="inline-delete-form" onsubmit="return confirm('¿Eliminar este contacto?');">
                            <button type="submit" class="small-btn danger-outline">Eliminar</button>
                          </form>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
            <% } %>
          </div>
          <div class="wa-tertiary-panel <%= segments.length === 0 ? 'wa-tertiary-panel--hint' : '' %>" data-tertiary-panel="segments">
            <% if (segments.length === 0) { %>
            <div class="wa-placeholder wa-placeholder--tab-hint" role="status">
              <span class="wa-placeholder-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              </span>
              <h2 class="wa-placeholder-title">Segmentos</h2>
              <p class="wa-placeholder-text">No hay segmentos definidos. Crea el primero con el formulario en la columna central.</p>
            </div>
            <% } else { %>
            <div class="card wa-tertiary-card">
              <h2 class="card-title">Definidos</h2>
              <p class="card-lead">Slug, etiqueta y orden por fila. Borrar solo si no hay contactos.</p>
              <div class="table-wrap">
                <table class="segment-table">
                  <thead>
                    <tr>
                      <th>Slug, etiqueta y orden</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% segments.forEach((seg) => { %>
                    <tr>
                      <td>
                        <form method="POST" action="<%= basePath %>/settings/segment-update" class="segment-update-form">
                          <input type="hidden" name="id" value="<%= seg.id %>" />
                          <div class="segment-update-row">
                            <label class="segment-field segment-field--slug">
                              <span class="segment-field-lbl">Slug</span>
                              <input
                                type="text"
                                name="slug"
                                value="<%= seg.value %>"
                                required
                                pattern="[a-z0-9_]{1,50}"
                                maxlength="50"
                                class="segment-slug-input mono"
                                title="Minusculas, numeros y guion bajo"
                                autocomplete="off"
                              />
                            </label>
                            <label class="segment-field">
                              <span class="segment-field-lbl">Etiqueta</span>
                              <input type="text" name="label" value="<%= seg.label %>" maxlength="120" required class="segment-label-input" />
                            </label>
                            <label class="segment-field segment-field--order">
                              <span class="segment-field-lbl">Orden</span>
                              <input type="number" name="sort_order" value="<%= seg.sort_order %>" step="1" class="segment-order-input" />
                            </label>
                            <button type="submit" class="small-btn segment-save-btn">Guardar</button>
                          </div>
                        </form>
                      </td>
                      <td>
                        <form method="POST" action="<%= basePath %>/settings/segment-delete" class="inline-delete-form" onsubmit="return confirm('¿Borrar este segmento? Solo si no hay contactos.');">
                          <input type="hidden" name="id" value="<%= seg.id %>" />
                          <button type="submit" class="small-btn danger-outline">Borrar</button>
                        </form>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
            <% } %>
          </div>
          <div class="wa-tertiary-panel wa-tertiary-panel--hint" data-tertiary-panel="history">
            <div class="wa-placeholder wa-placeholder--tab-hint" role="status">
              <span class="wa-placeholder-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <h2 class="wa-placeholder-title">Historial</h2>
              <p class="wa-placeholder-text">Indicadores y tabla de campañas recientes. Pulsa <strong>Detalle</strong> en una fila para ver el desglose aquí.</p>
            </div>
          </div>
          <div class="wa-tertiary-panel" data-tertiary-panel="campaign-detail" id="wa-tertiary-campaign-detail">
            <div class="wa-campaign-detail-shell">
              <button type="button" class="text-link wa-campaign-detail-back">← Volver al historial</button>
              <div id="campaign-detail-root" class="wa-campaign-detail-root"></div>
            </div>
          </div>
          <div class="wa-tertiary-panel wa-tertiary-panel--hint" data-tertiary-panel="configuration">
            <div class="wa-placeholder wa-placeholder--tab-hint" role="status">
              <span class="wa-placeholder-icon" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              </span>
              <h2 class="wa-placeholder-title">Ajustes</h2>
              <p class="wa-placeholder-text">Webhook, API JSON y documentación en la columna central.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <dialog id="dialog-edit-contact" class="modal-dialog">
      <form method="POST" id="form-edit-contact" class="modal-dialog-form">
        <h3 class="modal-dialog-title">Editar contacto</h3>
        <label class="field">
          <span class="field-label">Nombre</span>
          <input type="text" name="name" id="edit-contact-name" required maxlength="150" />
        </label>
        <label class="field">
          <span class="field-label">Teléfono (E.164 sin +)</span>
          <input type="text" name="phone" id="edit-contact-phone" required inputmode="numeric" />
        </label>
        <label class="field">
          <span class="field-label">Segmento</span>
          <select name="segment" id="edit-contact-segment" required>
            <% segments.forEach((segment) => { %>
              <option value="<%= segment.value %>"><%= segment.label %></option>
            <% }) %>
          </select>
        </label>
        <div class="modal-dialog-actions">
          <button type="button" class="secondary" id="edit-contact-cancel">Cancelar</button>
          <button type="submit">Guardar cambios</button>
        </div>
      </form>
    </dialog>

    <script>
      (function () {
        const VALID = new Set(['send-campaign', 'contacts', 'segments', 'history', 'configuration']);
        function sectionFromHash() {
          const h = (location.hash || '#send-campaign').slice(1);
          return VALID.has(h) ? h : 'send-campaign';
        }

        const navItems = Array.from(document.querySelectorAll('.nav-item[data-target-section]'));
        const sections = Array.from(document.querySelectorAll('.content-section'));
        const layoutRoot = document.querySelector('.wa-layout--dashboard');
        const tertiaryPanels = Array.from(document.querySelectorAll('.wa-tertiary-panel'));
        const campaignDetailRoot = document.getElementById('campaign-detail-root');
        const apiBase = '<%= basePath %>';

        let currentSection = 'send-campaign';
        let campaignDetailOpen = false;

        function tertiaryKeyForSection(sectionId) {
          if (sectionId === 'contacts') return 'contacts';
          if (sectionId === 'segments') return 'segments';
          if (sectionId === 'history') return 'history';
          if (sectionId === 'configuration') return 'configuration';
          return 'send-campaign';
        }

        function clearCampaignDetailRoot() {
          if (campaignDetailRoot) campaignDetailRoot.innerHTML = '';
        }

        function syncTertiaryPanels() {
          tertiaryPanels.forEach(function (panel) {
            var key = panel.getAttribute('data-tertiary-panel');
            var active =
              campaignDetailOpen && currentSection === 'history' && key === 'campaign-detail';
            if (!active) {
              active = !campaignDetailOpen && key === tertiaryKeyForSection(currentSection);
            }
            panel.classList.toggle('is-active', active);
          });
        }

        function updateSplitLayout() {
          if (!layoutRoot) return;
          layoutRoot.classList.toggle(
            'wa-layout--dashboard-split',
            currentSection === 'contacts' ||
              currentSection === 'segments' ||
              (currentSection === 'history' && campaignDetailOpen)
          );
        }

        function setActiveSection(targetId) {
          campaignDetailOpen = false;
          clearCampaignDetailRoot();
          currentSection = targetId;
          sections.forEach((section) => {
            section.classList.toggle('is-active', section.id === targetId);
          });
          navItems.forEach((el) => {
            el.classList.toggle('is-active', el.dataset.targetSection === targetId);
          });
          var nextHash = '#' + targetId;
          if (location.hash !== nextHash) {
            history.replaceState(null, '', nextHash);
          }
          syncTertiaryPanels();
          updateSplitLayout();
        }

        function renderCampaignDetail(data) {
          if (!campaignDetailRoot) return;
          var c = data.campaign;
          var logs = data.logs || [];
          var queued = c.status === 'queued' || c.status === 'processing';
          var wrap = document.createElement('div');
          var card1 = document.createElement('div');
          card1.className = 'card wa-tertiary-card';
          var h1 = document.createElement('h2');
          h1.className = 'card-title';
          h1.textContent = 'Campaña #' + c.id;
          card1.appendChild(h1);
          if (queued) {
            var toast = document.createElement('p');
            toast.className = 'toast toast--ok';
            toast.textContent = 'Envío en segundo plano. Actualiza el historial para ver el progreso.';
            card1.appendChild(toast);
          }
          var dl = document.createElement('dl');
          dl.className = 'detail-dl';
          function row(label, valueNode) {
            var div = document.createElement('div');
            var dt = document.createElement('dt');
            dt.textContent = label;
            var dd = document.createElement('dd');
            dd.appendChild(valueNode);
            div.appendChild(dt);
            div.appendChild(dd);
            dl.appendChild(div);
          }
          function ddText(t) {
            var n = document.createElement('span');
            n.textContent = t;
            return n;
          }
          row('Segmento', ddText(c.segment || '—'));
          row('Plantilla', ddText(c.template_name || '—'));
          var st = document.createElement('span');
          st.className = 'badge ' + (c.status || '');
          st.textContent = c.status || '—';
          row('Estado', st);
          row('Destinatarios', ddText(String(c.total_recipients != null ? c.total_recipients : '—')));
          row('Parámetros', ddText(c.message_text || '—'));
          if (c.image_url) {
            var a = document.createElement('a');
            a.href = c.image_url;
            a.target = '_blank';
            a.rel = 'noopener';
            a.textContent = 'Abrir enlace';
            row('Imagen', a);
          }
          card1.appendChild(dl);
          wrap.appendChild(card1);

          var card2 = document.createElement('div');
          card2.className = 'card wa-tertiary-card';
          var h2 = document.createElement('h2');
          h2.className = 'card-title';
          h2.textContent = 'Registro de envíos';
          card2.appendChild(h2);
          var tw = document.createElement('div');
          tw.className = 'table-wrap';
          var table = document.createElement('table');
          var thead = document.createElement('thead');
          var trh = document.createElement('tr');
          ['Teléfono', 'Estado', 'ID mensaje', 'Detalle'].forEach(function (lbl) {
            var th = document.createElement('th');
            th.textContent = lbl;
            trh.appendChild(th);
          });
          thead.appendChild(trh);
          table.appendChild(thead);
          var tbody = document.createElement('tbody');
          logs.forEach(function (log) {
            var tr = document.createElement('tr');
            var td1 = document.createElement('td');
            td1.className = 'mono';
            td1.textContent = log.phone || '—';
            var td2 = document.createElement('td');
            var b = document.createElement('span');
            b.className = 'badge ' + (log.status || '');
            b.textContent = log.status || '—';
            td2.appendChild(b);
            var td3 = document.createElement('td');
            td3.className = 'mono';
            td3.textContent = log.whatsapp_message_id || '—';
            var td4 = document.createElement('td');
            var pre = document.createElement('pre');
            pre.className = 'log-pre';
            try {
              pre.textContent = JSON.stringify(log.response, null, 2);
            } catch (e) {
              pre.textContent = String(log.response);
            }
            td4.appendChild(pre);
            tr.appendChild(td1);
            tr.appendChild(td2);
            tr.appendChild(td3);
            tr.appendChild(td4);
            tbody.appendChild(tr);
          });
          if (logs.length === 0) {
            var tr0 = document.createElement('tr');
            var td0 = document.createElement('td');
            td0.colSpan = 4;
            td0.className = 'empty-state';
            td0.textContent = 'Sin registros aún.';
            tr0.appendChild(td0);
            tbody.appendChild(tr0);
          }
          table.appendChild(tbody);
          tw.appendChild(table);
          card2.appendChild(tw);
          wrap.appendChild(card2);

          campaignDetailRoot.innerHTML = '';
          campaignDetailRoot.appendChild(wrap);
        }

        function openCampaignDetail(id) {
          if (currentSection !== 'history') {
            setActiveSection('history');
          }
          campaignDetailOpen = true;
          clearCampaignDetailRoot();
          if (campaignDetailRoot) {
            var p = document.createElement('p');
            p.className = 'muted';
            p.textContent = 'Cargando…';
            campaignDetailRoot.appendChild(p);
          }
          syncTertiaryPanels();
          updateSplitLayout();

          fetch(apiBase + '/api/campaigns/' + id, { credentials: 'same-origin' })
            .then(function (r) {
              if (!r.ok) throw new Error('HTTP ' + r.status);
              return r.json();
            })
            .then(function (data) {
              renderCampaignDetail(data);
            })
            .catch(function () {
              if (campaignDetailRoot) {
                campaignDetailRoot.innerHTML = '';
                var err = document.createElement('p');
                err.className = 'inline-warn';
                err.textContent = 'No se pudo cargar el detalle.';
                campaignDetailRoot.appendChild(err);
              }
            });
        }

        function closeCampaignDetail() {
          campaignDetailOpen = false;
          clearCampaignDetailRoot();
          syncTertiaryPanels();
          updateSplitLayout();
        }

        document.querySelectorAll('.js-campaign-detail-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-campaign-id');
            if (!id) return;
            openCampaignDetail(id);
          });
        });

        var backBtn = document.querySelector('.wa-campaign-detail-back');
        if (backBtn) {
          backBtn.addEventListener('click', function () {
            closeCampaignDetail();
          });
        }

        function applyFromQueryOrHash() {
          const params = new URLSearchParams(window.location.search);
          if (params.get('contacts_import') === '1') {
            setActiveSection('contacts');
            return;
          }
          if (params.get('segments_saved') === '1') {
            setActiveSection('segments');
            return;
          }
          if (params.get('templates_synced') === '1') {
            setActiveSection('send-campaign');
            return;
          }
          if (params.get('contact_updated') === '1' || params.get('contact_deleted') === '1') {
            setActiveSection('contacts');
            return;
          }
          setActiveSection(sectionFromHash());
        }

        window.addEventListener('hashchange', function () {
          setActiveSection(sectionFromHash());
        });

        applyFromQueryOrHash();
      })();
    </script>
    <script>
      (function () {
        var dlg = document.getElementById('dialog-edit-contact');
        var form = document.getElementById('form-edit-contact');
        if (!dlg || !form) return;
        var basePath = '<%= basePath %>';
        document.querySelectorAll('.js-edit-contact').forEach(function (btn) {
          btn.addEventListener('click', function () {
            try {
              var raw = btn.getAttribute('data-contact');
              if (!raw) return;
              var c = JSON.parse(decodeURIComponent(raw));
              form.action = basePath + '/contacts/' + c.id + '/update';
              document.getElementById('edit-contact-name').value = c.name;
              document.getElementById('edit-contact-phone').value = c.phone;
              document.getElementById('edit-contact-segment').value = c.segment;
              dlg.showModal();
            } catch (e) {}
          });
        });
        var cancel = document.getElementById('edit-contact-cancel');
        if (cancel) cancel.addEventListener('click', function () { dlg.close(); });
        dlg.addEventListener('click', function (e) {
          if (e.target === dlg) dlg.close();
        });
      })();
    </script>
  </body>
</html>
