<%- include('layouts/inbox-shell-start', {
  pageTitle: 'Credenciales Meta · MALI WhatsApp',
  basePath,
  appBaseUrl,
  requireAuth,
  currentUser,
  areaLabel,
  activeNav: typeof activeNav !== 'undefined' ? activeNav : 'admin-meta',
  showAdminNav,
  layoutModifier: '',
  extraHeadScripts: null
}) %>
<%- include('partials/admin-sidebar', { basePath, adminSection: 'meta' }) %>
<section class="inbox-main" aria-label="Credenciales Meta">
  <div class="inbox-chat-header inbox-chat-header--static inbox-chat-header--spread">
    <h1 class="inbox-chat-heading">Credenciales Meta</h1>
    <%- include('partials/wa-refresh-btn', { refreshTitle: 'Actualizar credenciales', refreshAriaLabel: 'Actualizar credenciales' }) %>
  </div>
  <div class="inbox-chat-body inbox-chat-body--form">
    <div class="card">
      <p class="card-lead">
        Los valores guardados aquí tienen prioridad sobre <code>.env</code>. Deja un campo vacío y guarda para volver a usar solo el entorno.
      </p>
      <% if (metaSaved) { %>
      <p class="toast toast--ok">Configuración guardada.</p>
      <% } %>

      <form method="post" action="<%= basePath %>/admin/meta" class="form-grid">
        <h2 class="card-subtitle">Webhook (toda la app)</h2>
        <label class="field">
          <span class="field-label">Verify token (Meta)</span>
          <input type="password" name="verify_token" autocomplete="off" value="<%= metaRows.global[keys.verifyToken] || '' %>" placeholder="Si vacío: VERIFY_TOKEN en .env" />
        </label>
        <label class="field">
          <span class="field-label">App Secret</span>
          <input type="password" name="app_secret" autocomplete="off" value="<%= metaRows.global[keys.appSecret] || '' %>" placeholder="Si vacío: APP_SECRET en .env" />
        </label>

        <h2 class="card-subtitle">Comercial (PAM)</h2>
        <label class="field">
          <span class="field-label">Token de acceso WhatsApp</span>
          <input type="password" name="pam_whatsapp_token" autocomplete="off" value="<%= metaRows.pam[keys.whatsappToken] || '' %>" />
        </label>
        <label class="field">
          <span class="field-label">Phone number ID</span>
          <input type="text" name="pam_phone_number_id" value="<%= metaRows.pam[keys.phoneNumberId] || '' %>" />
        </label>
        <label class="field">
          <span class="field-label">WABA ID (opcional)</span>
          <input type="text" name="pam_waba_id" value="<%= metaRows.pam[keys.wabaId] || '' %>" />
        </label>

        <h2 class="card-subtitle">Educación</h2>
        <label class="field">
          <span class="field-label">Token de acceso WhatsApp</span>
          <input type="password" name="edu_whatsapp_token" autocomplete="off" value="<%= metaRows.educacion[keys.whatsappToken] || '' %>" />
        </label>
        <label class="field">
          <span class="field-label">Phone number ID</span>
          <input type="text" name="edu_phone_number_id" value="<%= metaRows.educacion[keys.phoneNumberId] || '' %>" />
        </label>
        <label class="field">
          <span class="field-label">WABA ID (opcional)</span>
          <input type="text" name="edu_waba_id" value="<%= metaRows.educacion[keys.wabaId] || '' %>" />
        </label>

        <div class="field-row">
          <button type="submit" class="primary">Guardar</button>
        </div>
      </form>

      <p class="card-lead muted"><a href="<%= basePath %>/campaigns">← Volver a campañas</a></p>
    </div>
  </div>
</section>
<%- include('layouts/inbox-shell-end') %>
