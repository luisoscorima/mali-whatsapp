<%
  const _mode = typeof formMode !== 'undefined' ? formMode : 'create';
  const _isClone = _mode === 'clone';
  const _isEdit = _mode === 'edit';
  const _state = typeof templateBuilderState !== 'undefined' && templateBuilderState ? templateBuilderState : {
    header: { type: 'none', text: '', exampleValues: [], exampleMediaUrl: '', exampleHandle: '' },
    body: { text: '', exampleValues: [] },
    footer: { text: '' },
    buttons: []
  };
  const _stateJson = JSON.stringify(_state).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
  const _action = typeof formAction !== 'undefined' ? formAction : `${basePath}/templates/create`;
  const _submitLabel = typeof submitLabel !== 'undefined'
    ? submitLabel
    : (_isEdit ? 'Guardar y reenviar a revisión' : _isClone ? 'Crear nueva versión' : 'Enviar a revisión Meta');
  const _title = _isEdit ? 'Editar y reenviar a Meta' : _isClone ? 'Editar como nueva versión' : 'Nueva plantilla';
  const _initialName = typeof initialName !== 'undefined'
    ? initialName
    : (_isClone && selectedTemplate ? `${selectedTemplate.name}_v2` : '');
  const _initialLanguage = typeof initialLanguage !== 'undefined'
    ? initialLanguage
    : (selectedTemplate && selectedTemplate.language ? selectedTemplate.language : 'es');
  const _sourceTemplateId = typeof sourceTemplateId !== 'undefined'
    ? sourceTemplateId
    : (_isClone && selectedTemplate ? selectedTemplate.id : null);
%>
<form method="post" action="<%= _action %>" class="form-stack template-builder-form" data-template-builder-root>
  <div class="template-builder-page">
    <div class="card template-builder-card">
      <h2 class="card-title"><%= _title %></h2>
      <p class="card-lead">
        <% if (_isEdit) { %>
        Ajusta cuerpo, cabecera, pie y botones URL. Los aliases como <code>{{fecha}}</code> o <code>{{mes}}</code> se convierten internamente a <code>{{1}}</code>, <code>{{2}}</code>, etc.
        <% } else if (_isClone) { %>
        Meta no permite editar plantillas aprobadas en el mismo nombre. Aquí puedes modificar la plantilla y crear una <strong>nueva versión</strong> con otro nombre.
        <% } else { %>
        Se envía a revisión en Meta. Puedes trabajar con variables nombradas como <code>{{fecha}}</code>, <code>{{horario}}</code> o <code>{{mes}}</code>; el sistema las normaliza a placeholders numéricos.
        <% } %>
      </p>
      <% if (error) { %><p class="inline-warn"><%= error %></p><% } %>

    <% if (_isEdit && selectedTemplate) { %>
    <div class="field-row">
      <label class="field">
        <span class="field-label">Nombre</span>
        <input type="text" value="<%= selectedTemplate.name %>" readonly disabled />
      </label>
      <label class="field">
        <span class="field-label">Idioma</span>
        <input type="text" value="<%= selectedTemplate.language %>" readonly disabled />
      </label>
    </div>
    <% } else { %>
    <label class="field">
      <span class="field-label">Nombre (snake_case)</span>
      <input type="text" name="name" required pattern="[a-z0-9_]+" placeholder="recordatorio_pago_mayo" value="<%= _initialName %>" />
    </label>
    <label class="field">
      <span class="field-label">Idioma</span>
      <input type="text" name="language" value="<%= _initialLanguage %>" required />
    </label>
    <% } %>

    <label class="field">
      <span class="field-label">Categoría</span>
      <select name="category">
        <option value="MARKETING" <%= selectedTemplate && (selectedTemplate.category || '').toUpperCase() === 'MARKETING' ? 'selected' : '' %>>MARKETING</option>
        <option value="UTILITY" <%= selectedTemplate && (selectedTemplate.category || '').toUpperCase() === 'UTILITY' ? 'selected' : '' %>>UTILITY</option>
        <option value="AUTHENTICATION" <%= selectedTemplate && (selectedTemplate.category || '').toUpperCase() === 'AUTHENTICATION' ? 'selected' : '' %>>AUTHENTICATION</option>
      </select>
    </label>

    <% if (_sourceTemplateId) { %>
    <input type="hidden" name="sourceTemplateId" value="<%= _sourceTemplateId %>" />
    <% } %>

    <input type="hidden" name="builderPayloadJson" value="" data-template-builder-payload />
    <script type="application/json" data-template-builder-state><%- _stateJson %></script>

      <div class="template-builder-shell" data-template-builder-shell></div>

      <noscript>
        <p class="inline-warn">Activa JavaScript para usar el constructor de plantillas.</p>
      </noscript>

      <button type="submit" class="small-btn primary"><%= _submitLabel %></button>
    </div>

    <aside class="template-builder-page__preview" aria-label="Vista previa editorial">
      <div class="template-live-preview" data-template-preview-shell></div>
    </aside>
  </div>
</form>
