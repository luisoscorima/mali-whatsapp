<div class="card">
  <h2 class="card-title">Nueva campaña</h2>
  <% if (typeof templatesSynced !== 'undefined' && templatesSynced) { %>
  <p class="toast toast--ok">Plantillas sincronizadas desde Meta.</p>
  <% } %>
  <% if (typeof templatesSyncError !== 'undefined' && templatesSyncError) { %>
  <p class="inline-warn">No se pudieron sincronizar: <%= templatesSyncError %></p>
  <% } %>
  <div class="template-sync-row">
    <form method="POST" action="<%= basePath %>/templates/sync" class="inline-form-sync">
      <input type="hidden" name="returnTo" value="campaigns" />
      <button type="submit" class="secondary">Sincronizar todo</button>
    </form>
    <p class="card-lead template-sync-hint">Trae la lista actualizada de plantillas <strong>aprobadas</strong> de tu cuenta WhatsApp (Meta). Hazlo cuando cambien o aprueben nuevas.</p>
  </div>
  <% if (!syncedTemplates || syncedTemplates.length === 0) { %>
  <p class="inline-warn">No hay plantillas en caché. Pulsa <strong>Sincronizar todo</strong> (requiere token con permisos para la cuenta de WhatsApp).</p>
  <% } %>
  <form method="POST" action="<%= basePath %>/campaigns/send" class="form-grid" id="campaign-form" data-base-path="<%= basePath %>">
    <div class="form-section">
      <span class="form-section-label">Quién recibe</span>
      <% if (segments.length === 0) { %>
      <p class="inline-warn">Añade segmentos en la sección <strong>Segmentos</strong>.</p>
      <% } else { %>
      <div class="campaign-audience-stack">
        <fieldset class="campaign-segments-fieldset campaign-segments-panel">
          <legend class="visually-hidden">Elegir segmentos para la campaña</legend>
          <div class="campaign-segments-head">
            <span class="campaign-step-badge campaign-step-badge--compact" aria-hidden="true">1</span>
            <span class="campaign-segments-titleline">Segmentos</span>
          </div>
          <p class="inline-help campaign-segments-hint">
            Marca uno o más segmentos; se incluyen los contactos que pertenezcan a <strong>cualquiera</strong> de ellos (unión).
          </p>
          <div class="campaign-segments-grid" role="group" aria-label="Segmentos disponibles">
            <% segments.forEach(function (segment) { %>
            <label class="campaign-segment-tile">
              <input type="checkbox" name="campaignSegment" value="<%= segment.value %>" class="campaign-segment-input" />
              <span class="campaign-segment-text"><%= segment.label %></span>
            </label>
            <% }) %>
          </div>
        </fieldset>

        <fieldset class="campaign-segments-fieldset campaign-segments-panel">
          <legend class="visually-hidden">Excluir segmentos de la campaña</legend>
          <div class="campaign-segments-head">
            <span class="campaign-step-badge campaign-step-badge--compact" aria-hidden="true">—</span>
            <span class="campaign-segments-titleline">Excluir segmentos (opcional)</span>
          </div>
          <p class="inline-help campaign-segments-hint">
            Los contactos en estos segmentos <strong>no recibirán</strong> el mensaje, aunque también estén en un segmento incluido arriba.
            Para quitar contactos puntuales, desmárcalos en el paso <strong>Destinatarios</strong>.
          </p>
          <div class="campaign-segments-grid" role="group" aria-label="Segmentos a excluir">
            <% segments.forEach(function (segment) { %>
            <label class="campaign-segment-tile campaign-segment-tile--exclude">
              <input type="checkbox" name="campaignExcludeSegment" value="<%= segment.value %>" class="campaign-exclude-segment-input" />
              <span class="campaign-segment-text"><%= segment.label %></span>
            </label>
            <% }) %>
          </div>
        </fieldset>

        <div class="campaign-destinatarios-block">
          <div class="campaign-destinatarios-head">
            <span class="campaign-step-badge" aria-hidden="true">2</span>
            <div>
              <span class="campaign-destinatarios-title">Destinatarios</span>
              <p class="campaign-destinatarios-sub">Pulsa <strong>Mostrar destinatarios</strong> para ver la lista y marca o desmarca contactos uno a uno.</p>
            </div>
          </div>
          <div class="campaign-recipients-actions">
            <button type="button" class="campaign-load-btn" id="campaign-load-recipients">Mostrar destinatarios</button>
            <span id="campaign-recipients-status" class="campaign-recipients-status" aria-live="polite"></span>
          </div>
          <div class="campaign-recipients-shell">
            <div id="campaign-recipients-toolbar" class="campaign-recipients-toolbar" hidden>
              <div class="campaign-recipients-toolbar-start">
                <span class="campaign-recipients-toolbar-label">Lista</span>
                <span id="campaign-recipients-count" class="campaign-recipients-count"></span>
              </div>
              <div class="campaign-recipients-toolbar-actions">
                <button type="button" class="small-btn secondary" id="campaign-select-all">Marcar todos</button>
                <button type="button" class="small-btn secondary" id="campaign-select-none">Ninguno</button>
              </div>
            </div>
            <div id="campaign-recipients-list" class="campaign-recipients-list" hidden role="group" aria-label="Lista de destinatarios"></div>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <div class="form-section">
      <div class="campaign-step-head">
        <span class="campaign-step-badge campaign-step-badge--compact" aria-hidden="true">3</span>
        <span class="campaign-segments-titleline">Plantilla (Meta)</span>
      </div>
      <label class="field">
        <span class="field-label">Seleccionar plantilla</span>
        <select name="templateSyncId" id="template-sync-select" required <%= (!syncedTemplates || syncedTemplates.length === 0) ? 'disabled' : '' %>>
          <option value="">— Elige una plantilla —</option>
          <% if (syncedTemplates && syncedTemplates.length) { %>
            <% syncedTemplates.forEach(function (t) { %>
            <option value="<%= t.id %>"><%= t.name %> · <%= t.language %> · <%= t.category || '—' %></option>
            <% }) %>
          <% } %>
        </select>
      </label>
    </div>

    <div id="dynamic-template-fields" class="form-section" hidden></div>

    <p id="campaign-send-error" class="inline-warn" hidden></p>

    <div class="form-section">
      <div class="campaign-step-head">
        <span class="campaign-step-badge campaign-step-badge--compact" aria-hidden="true">4</span>
        <span class="campaign-segments-titleline">Cuándo enviar</span>
      </div>
      <fieldset class="campaign-schedule-fieldset">
        <legend class="visually-hidden">Modo de envío</legend>
        <div class="campaign-schedule-options">
          <label class="field field--row campaign-schedule-option">
            <input type="radio" name="scheduleMode" value="now" checked />
            <span>Enviar ahora</span>
          </label>
          <label class="field field--row campaign-schedule-option">
            <input type="radio" name="scheduleMode" value="scheduled" />
            <span>Programar</span>
          </label>
        </div>
        <div id="campaign-schedule-datetime-wrap" class="campaign-schedule-datetime-wrap" hidden>
          <label class="field">
            <span class="field-label">Fecha y hora</span>
            <input type="datetime-local" id="campaign-scheduled-at" autocomplete="off" />
          </label>
          <p class="inline-help campaign-schedule-hint">La hora es la de este equipo; al enviar se convierte a un instante universal para que coincida con el reloj del servidor.</p>
        </div>
      </fieldset>
    </div>

    <details class="form-section form-section--adv">
      <summary class="form-section--adv-summary">Avanzado</summary>
      <div class="form-section--adv-body">
        <p class="inline-help form-section--adv-hint">Control opcional del ritmo de envío (lotes y pausa entre lotes).</p>
        <div class="field-row">
          <label class="field">
            <span class="field-label">Lote</span>
            <input type="number" name="batchSize" value="40" min="1" max="100" />
          </label>
          <label class="field">
            <span class="field-label">Pausa (ms)</span>
            <input type="number" name="batchDelayMs" value="1500" min="0" step="500" />
          </label>
        </div>
      </div>
    </details>

    <div class="form-actions">
      <button type="submit" id="campaign-submit-btn" <%= segments.length === 0 || !syncedTemplates || syncedTemplates.length === 0 ? 'disabled data-disabled-by-server="1"' : '' %>>Enviar campaña</button>
    </div>
  </form>
</div>
