<div class="page page--detail campaign-detail-page">
  <% 
    var _logTotal = logs.length;
    var _sent = 0, _del = 0, _read = 0, _fail = 0;
    logs.forEach(function (log) {
      var s = String(log.status || '').trim().toLowerCase();
      if (s === 'read') { _read++; _del++; _sent++; }
      else if (s === 'delivered') { _del++; _sent++; }
      else if (s === 'sent') { _sent++; }
      else if (s === 'error' || s === 'failed' || s === 'undelivered') _fail++;
    });
    var _den = Number(campaign.total_recipients) > 0 ? Number(campaign.total_recipients) : _logTotal;
    var _ratio = _den > 0 ? (_sent + '/' + _den) : '—';
    var _dPct = _sent > 0 ? Math.round((_del / _sent) * 100) : null;
    var _rPct = _del > 0 ? Math.round((_read / _del) * 100) : null;
    var _ePct = _logTotal > 0 ? Math.round((_fail / _logTotal) * 100) : 0;
  %>
  <div class="card campaign-detail-metrics">
    <h2 class="card-title">Indicadores de esta campaña</h2>
    <div class="metrics-row metrics-row--history metrics-row--compact" role="region" aria-label="Indicadores de campaña">
      <div class="metric"><span class="metric-num"><%= _logTotal %></span><span class="metric-lbl">Total</span></div>
      <div class="metric"><span class="metric-num"><%= _ratio %></span><span class="metric-lbl">Aceptados / meta</span></div>
      <div class="metric"><span class="metric-num"><%= _dPct !== null ? _dPct + '%' : '—' %></span><span class="metric-lbl">Entregados</span></div>
      <div class="metric"><span class="metric-num"><%= _rPct !== null ? _rPct + '%' : '—' %></span><span class="metric-lbl">Lectura</span></div>
      <div class="metric"><span class="metric-num"><%= _ePct %>%</span><span class="metric-lbl">Error</span></div>
    </div>
  </div>
  <div class="card">
    <% if (campaign.status === 'queued' || campaign.status === 'processing') { %>
    <p class="toast toast--ok">Envío en segundo plano. Actualiza la página para ver el progreso.</p>
    <% } %>
    <dl class="detail-dl">
      <div><dt>Segmento</dt><dd><%= campaign.segment %></dd></div>
      <div><dt>Plantilla</dt><dd><%= campaign.template_name %></dd></div>
      <div><dt>Estado</dt><dd><span class="badge <%= campaign.status %>"><%= campaign.status %></span></dd></div>
      <div><dt>Destinatarios</dt><dd><%= campaign.total_recipients %></dd></div>
      <div><dt>Parámetros</dt><dd><%= campaign.message_text %></dd></div>
      <% if (campaign.image_url) { %>
      <div><dt>Imagen</dt><dd><a href="<%= campaign.image_url %>" target="_blank" rel="noopener">Abrir enlace</a></dd></div>
      <% } %>
    </dl>
  </div>

  <div class="card">
    <h2 class="card-title">Registro de envíos</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>ID mensaje</th>
            <th>Detalle</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(function (log) { %>
          <tr>
            <td class="mono"><%= log.phone %></td>
            <td><span class="badge <%= log.status %>"><%= log.status %></span></td>
            <td class="mono"><%= log.whatsapp_message_id || '—' %></td>
            <td><pre class="log-pre"><%= JSON.stringify(log.response, null, 2) %></pre></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
