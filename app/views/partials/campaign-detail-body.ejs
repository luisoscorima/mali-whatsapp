<div class="page page--detail campaign-detail-page">
  <%
    var _analytics = typeof analytics !== 'undefined' && analytics ? analytics : null;
    var _businessMetrics = _analytics ? _analytics.business : [];
    var _globalMetrics = _analytics ? _analytics.globalResult : [];
    var _performanceMetrics = _analytics ? _analytics.performance : [];
    var _funnelMetrics = _analytics ? _analytics.funnel : [];
    var _incidentMetrics = _analytics ? _analytics.incidents : [];
    var _performanceNote = _analytics ? _analytics.performanceNote : '';
    var _incidentsNote = _analytics ? _analytics.incidentsNote : '';
    var _costInfo = _analytics ? _analytics.cost : null;
    var _respMetrics = typeof responderMetrics !== 'undefined' && responderMetrics ? responderMetrics : null;
    var _respWindow = _analytics ? _analytics.responseWindowDays : (_respMetrics ? _respMetrics.windowDays : 7);
    var _respCount = _respMetrics ? _respMetrics.respondedCount : 0;
    var _respList = _respMetrics && Array.isArray(_respMetrics.responders) ? _respMetrics.responders : [];
    var _retryStats = typeof retryStats !== 'undefined' && retryStats ? retryStats : null;
    var _recoveredCount = _retryStats ? _retryStats.recoveredCount : 0;
    var _retryDelayMin = _retryStats ? _retryStats.autoRetryDelayMinutes : 10;
    var _canManualRetry = _retryStats ? _retryStats.canManualRetry : false;
    var _autoRetryPending = _retryStats ? _retryStats.autoRetryPending : false;
    var _manualRetryCount = _retryStats ? _retryStats.manualRetryCount : 0;
    var _maxManualRetries = _retryStats ? _retryStats.maxManualRetries : 3;
    var _failedLogs = typeof failedLogs !== 'undefined' && Array.isArray(failedLogs) ? failedLogs : [];
    var _failedCount = _failedLogs.length;
    var _payload = campaign.campaign_payload;
    if (typeof _payload === 'string') {
      try { _payload = JSON.parse(_payload); } catch (e) { _payload = null; }
    }
    var _excludeSegs = _payload && Array.isArray(_payload.excludeSegmentSlugs) ? _payload.excludeSegmentSlugs : [];
    var _excludeIds = _payload && Array.isArray(_payload.excludeContactIds) ? _payload.excludeContactIds : [];
    var _costSourceLabel = campaign.cost_is_estimated ? 'Estimado' : 'Meta WABA';
    var _canSyncCost = campaign.status === 'completed' || campaign.status === 'failed';
  %>

  <div class="card campaign-dashboard-card">
    <section class="campaign-dashboard-section">
      <div class="campaign-dashboard-section__head">
        <div>
          <h2 class="card-title">Negocio</h2>
          <p class="campaign-dashboard-section__lead muted">Resumen comercial de la campaña.</p>
        </div>
        <% if (_canSyncCost) { %>
        <button
          type="button"
          class="small-btn secondary"
          id="campaign-sync-cost-btn"
          data-campaign-id="<%= campaign.id %>"
        >Sincronizar costo</button>
        <% } %>
      </div>
      <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--2" role="group" aria-label="Métricas de negocio">
        <% _businessMetrics.forEach(function (metric) { %>
        <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <span class="metric-num"><%= metric.display %></span>
          <span class="metric-lbl"><%= metric.label %></span>
        </div>
        <% }); %>
      </div>
      <p class="campaign-business-hint muted">
        <strong>Fuente:</strong> <%= _costSourceLabel %>.
        <% if (campaign.cost_synced_at) { %><span> Última sincronización: <%= formatMessageDateTime(campaign.cost_synced_at) %>.</span><% } %>
        <% if (_costInfo && _costInfo.hint) { %><span> <%= _costInfo.hint %></span><% } %>
      </p>
    </section>

    <section class="campaign-dashboard-section">
      <div class="campaign-dashboard-section__head">
        <div>
          <h2 class="card-title">Resultado global</h2>
          <p class="campaign-dashboard-section__lead muted">Visión general de destinatarios, envíos y problemas.</p>
        </div>
      </div>
      <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--3" role="group" aria-label="Resultado global">
        <% _globalMetrics.forEach(function (metric) { %>
        <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <span class="metric-num"><%= metric.display %></span>
          <span class="metric-lbl"><%= metric.label %></span>
        </div>
        <% }); %>
      </div>
    </section>

    <section class="campaign-dashboard-section">
      <div class="campaign-dashboard-section__head">
        <div>
          <h2 class="card-title">Rendimiento de envío</h2>
          <p class="campaign-dashboard-section__lead muted"><%= _performanceNote %></p>
        </div>
      </div>
      <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--4" role="group" aria-label="Rendimiento de envío">
        <% _performanceMetrics.forEach(function (metric) { %>
        <% if (metric.action) { %>
        <button
          type="button"
          class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %> metric--action"
          id="<%= metric.action.id %>"
          aria-haspopup="dialog"
          aria-controls="<%= metric.action.dialogId %>"
          title="<%= metric.action.title || metric.tooltip || '' %>"
        >
          <span class="metric-num"><%= metric.display %></span>
          <span class="metric-lbl"><%= metric.label %></span>
        </button>
        <% } else { %>
        <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <span class="metric-num"><%= metric.display %></span>
          <span class="metric-lbl"><%= metric.label %></span>
        </div>
        <% } %>
        <% }); %>
      </div>
      <p class="campaign-responders-hint muted">
        Cuenta como respuesta si el contacto escribió dentro de los <%= _respWindow %> días posteriores al envío.
      </p>
    </section>

    <section class="campaign-dashboard-section">
      <div class="campaign-dashboard-section__head">
        <div>
          <h2 class="card-title">Embudo Meta</h2>
          <p class="campaign-dashboard-section__lead muted">Estados exclusivos que suman el total de enviados.</p>
        </div>
      </div>
      <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--3" role="group" aria-label="Embudo Meta">
        <% _funnelMetrics.forEach(function (metric) { %>
        <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <span class="metric-num"><%= metric.display %></span>
          <span class="metric-lbl"><%= metric.label %></span>
        </div>
        <% }); %>
      </div>
      <p class="campaign-dashboard-formula muted">
        Validación: pendientes de entrega + entregados no leídos + leídos = enviados.
      </p>
    </section>

    <section class="campaign-dashboard-section campaign-dashboard-section--last">
      <div class="campaign-dashboard-section__head">
        <div>
          <h2 class="card-title">Incidencias de entrega</h2>
          <p class="campaign-dashboard-section__lead muted">Detalle técnico de problemas reportados por Meta.</p>
        </div>
      </div>
      <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--3" role="group" aria-label="Incidencias de entrega">
        <% _incidentMetrics.forEach(function (metric) { %>
        <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <span class="metric-num"><%= metric.display %></span>
          <span class="metric-lbl"><%= metric.label %></span>
        </div>
        <% }); %>
      </div>
      <% if (_incidentsNote) { %>
      <p class="campaign-dashboard-formula muted"><%= _incidentsNote %></p>
      <% } %>
    </section>
  </div>

  <div class="card">
    <% if (campaign.status === 'queued' || campaign.status === 'processing') { %>
    <p class="toast toast--ok">Envío en segundo plano. Actualiza la página para ver el progreso.</p>
    <% } else if (campaign.status === 'scheduled') { %>
    <p class="toast toast--ok">Campaña programada: se enviará a la hora indicada. Actualiza la página para ver el progreso.</p>
    <% } %>
    <dl class="detail-dl">
      <div><dt>Segmento(s)</dt><dd><%= campaignSegmentDisplay(campaign) %></dd></div>
      <% if (_excludeSegs.length || _excludeIds.length) { %>
      <div><dt>Exclusiones</dt><dd>
        <% if (_excludeSegs.length) { %>
        <span>Segmentos: <%= _excludeSegs.join(', ') %></span>
        <% } %>
        <% if (_excludeSegs.length && _excludeIds.length) { %><br /><% } %>
        <% if (_excludeIds.length) { %>
        <span>Contactos (IDs): <%= _excludeIds.join(', ') %></span>
        <% } %>
      </dd></div>
      <% } %>
      <div><dt>Plantilla</dt><dd><%= campaign.template_name %></dd></div>
      <div><dt>Estado</dt><dd><span class="badge <%= campaign.status %>"><%= campaign.status %></span></dd></div>
      <% if (campaign.scheduled_at) { %>
      <div><dt>Programada para</dt><dd><%= formatMessageDateTime(campaign.scheduled_at) %></dd></div>
      <% } %>
      <div><dt>Destinatarios</dt><dd><%= campaign.total_recipients %></dd></div>
      <% if (_recoveredCount > 0) { %>
      <div><dt>Recuperados en reintento</dt><dd><%= _recoveredCount %></dd></div>
      <% } %>
      <div><dt>Inversión / costo</dt><dd>
        <span id="campaign-cost-display"><%= _costInfo ? _costInfo.amountDisplay : 'Aún sin datos' %></span>
        <span class="muted"> · <%= _costSourceLabel %></span>
      </dd></div>
      <div><dt>Parámetros</dt><dd><%= campaign.message_text %></dd></div>
      <% if (campaign.image_url) { %>
      <div><dt>Imagen</dt><dd><a href="<%= campaign.image_url %>" target="_blank" rel="noopener">Abrir enlace</a></dd></div>
      <% } %>
    </dl>
  </div>

  <div class="card campaign-failed-card">
    <div class="campaign-failed-card__head">
      <h2 class="card-title">Incidencias detalladas (<%= _failedCount %>)</h2>
      <div class="campaign-failed-card__actions">
        <% if (_canManualRetry) { %>
        <button type="button" class="small-btn" id="campaign-retry-failed-btn" data-campaign-id="<%= campaign.id %>">
          Reintentar incidencias (<%= _failedCount %>)
        </button>
        <% } %>
        <% if (_failedCount > 0) { %>
        <a
          class="small-btn secondary"
          href="<%= basePath %>/api/campaigns/<%= campaign.id %>/failed-export"
          download
        >Exportar CSV</a>
        <% } %>
      </div>
    </div>
    <p class="muted campaign-retry-hint">
      Reintento automático ~<%= _retryDelayMin %> min después del envío para errores temporales.
      <% if (_autoRetryPending) { %> Pendiente de reintento automático.<% } %>
      <% if (_manualRetryCount > 0) { %> Reintentos manuales: <%= _manualRetryCount %>/<%= _maxManualRetries %>.<% } %>
    </p>
    <p id="campaign-retry-feedback" class="inline-warn" hidden role="status"></p>
    <% if (_failedCount === 0) { %>
    <p class="muted campaign-failed-empty">No hay incidencias activas de entrega en esta campaña.</p>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>Incidencia</th>
            <th>Motivo</th>
          </tr>
        </thead>
        <tbody>
          <% _failedLogs.forEach(function (log) { %>
          <tr>
            <td class="mono"><%= log.phone %></td>
            <td><span class="badge <%= log.status %>"><%= log.status %></span></td>
            <td><%= log.incident_label || 'Mensajes no entregables' %></td>
            <td><%= log.error_summary %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <div class="card">
    <h2 class="card-title">Registro de envíos</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>ID mensaje</th>
            <th>Detalle</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(function (log) { %>
          <tr>
            <td class="mono"><%= log.phone %></td>
            <td><span class="badge <%= log.status %>"><%= log.status %></span></td>
            <td class="mono"><%= log.whatsapp_message_id || '—' %></td>
            <td><pre class="log-pre"><%= JSON.stringify(log.response, null, 2) %></pre></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <dialog id="campaign-responders-dialog" class="modal-dialog campaign-responders-dialog" aria-labelledby="campaign-responders-dialog-title">
    <form method="dialog" class="modal-dialog-form campaign-responders-dialog__form">
      <h2 id="campaign-responders-dialog-title" class="modal-dialog-title">
        Respuestas únicas (<%= _respWindow %> días) · <%= _respCount %>
      </h2>
      <p class="muted campaign-responders-dialog__hint">
        Contactos que enviaron al menos un mensaje inbound dentro de los <%= _respWindow %> días posteriores al envío de la plantilla.
      </p>
      <% if (_respList.length === 0) { %>
      <p class="muted">Aún sin datos de respuestas en esta ventana.</p>
      <% } else { %>
      <div class="table-wrap campaign-responders-dialog__table-wrap">
        <table>
          <thead>
            <tr>
              <th>Teléfono</th>
              <th>Nombre</th>
              <th>Primera respuesta</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% _respList.forEach(function (row) {
              var _chatHref = row.conversationId
                ? basePath + '/conversations/' + row.conversationId
                : (row.contactId ? basePath + '/conversations/' + (-row.contactId) : null);
            %>
            <tr>
              <td class="mono"><%= row.phone %></td>
              <td><%= row.contactName || '—' %></td>
              <td><%= row.firstResponseAt ? formatMessageDateTime(row.firstResponseAt) : '—' %></td>
              <td class="campaign-responders-dialog__actions">
                <% if (_chatHref) { %>
                <a class="text-link" href="<%= _chatHref %>">Abrir chat</a>
                <% } else { %>
                <span class="muted">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
      <div class="modal-dialog-actions">
        <button type="submit" class="small-btn secondary">Cerrar</button>
      </div>
    </form>
  </dialog>
  <script>
    (function () {
      var openBtn = document.getElementById('campaign-responders-open');
      var dialog = document.getElementById('campaign-responders-dialog');
      if (openBtn && dialog) {
        openBtn.addEventListener('click', function () {
          if (typeof dialog.showModal === 'function') dialog.showModal();
        });
        dialog.addEventListener('click', function (ev) {
          if (ev.target === dialog) dialog.close();
        });
      }

      var basePath = '<%= basePath %>';

      var costBtn = document.getElementById('campaign-sync-cost-btn');
      if (costBtn) {
        costBtn.addEventListener('click', function () {
          var campaignId = costBtn.getAttribute('data-campaign-id');
          costBtn.disabled = true;
          fetch(basePath + '/api/campaigns/' + encodeURIComponent(campaignId) + '/sync-cost', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' },
          })
            .then(function (r) {
              return r.json();
            })
            .then(function (data) {
              if (data.ok) window.location.reload();
              else {
                costBtn.disabled = false;
                alert(data.error || 'No se pudo sincronizar');
              }
            })
            .catch(function () {
              costBtn.disabled = false;
              alert('Error de red');
            });
        });
      }

      var retryBtn = document.getElementById('campaign-retry-failed-btn');
      var retryFeedback = document.getElementById('campaign-retry-feedback');
      if (!retryBtn) return;
      retryBtn.addEventListener('click', function () {
        var campaignId = retryBtn.getAttribute('data-campaign-id');
        if (!campaignId) return;
        retryBtn.disabled = true;
        if (retryFeedback) {
          retryFeedback.hidden = true;
          retryFeedback.textContent = '';
        }
        fetch(basePath + '/api/campaigns/' + encodeURIComponent(campaignId) + '/retry-failed', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { Accept: 'application/json' },
        })
          .then(function (r) {
            return r.json().then(function (data) {
              return { ok: r.ok, data: data };
            });
          })
          .then(function (result) {
            if (!result.ok || !result.data.ok) {
              var msg = (result.data && result.data.error) || 'No se pudo reintentar';
              if (retryFeedback) {
                retryFeedback.className = 'inline-warn';
                retryFeedback.textContent = msg;
                retryFeedback.hidden = false;
              }
              retryBtn.disabled = false;
              return;
            }
            var d = result.data;
            var summary =
              'Reintento: ' +
              d.retried +
              ' teléfono(s), ' +
              d.recovered +
              ' recuperado(s), ' +
              d.stillFailed +
              ' aún con incidencia.';
            if (retryFeedback) {
              retryFeedback.className = 'toast toast--ok';
              retryFeedback.textContent = summary;
              retryFeedback.hidden = false;
            }
            window.setTimeout(function () {
              window.location.reload();
            }, 1200);
          })
          .catch(function () {
            if (retryFeedback) {
              retryFeedback.className = 'inline-warn';
              retryFeedback.textContent = 'Error de red al reintentar';
              retryFeedback.hidden = false;
            }
            retryBtn.disabled = false;
          });
      });
    })();
  </script>
</div>
