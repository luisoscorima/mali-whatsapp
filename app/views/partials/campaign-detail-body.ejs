<div class="page page--detail campaign-detail-page">
  <%
    var _analytics = typeof analytics !== 'undefined' && analytics ? analytics : null;
    var _businessMetrics = _analytics ? _analytics.business : [];
    var _globalMetrics = _analytics ? _analytics.globalResult : [];
    var _performanceMetrics = _analytics ? _analytics.performance : [];
    var _funnelMetrics = _analytics ? _analytics.funnel : [];
    var _incidentMetrics = _analytics ? _analytics.incidents : [];
    var _incidentTotalMetric = null;
    _globalMetrics.forEach(function (metric) {
      if (!_incidentTotalMetric && metric && metric.label === 'Problemas de entrega') {
        _incidentTotalMetric = Object.assign({}, metric, { label: 'Total de incidencias' });
      }
    });
    if (_incidentTotalMetric && _incidentTotalMetric.display) {
      var _incidentTotalMatch = String(_incidentTotalMetric.display).match(/^(\d+)\s*\(\d+%\)$/);
      if (_incidentTotalMatch) {
        _incidentTotalMetric = Object.assign({}, _incidentTotalMetric, {
          display: Number(_incidentTotalMatch[1]) > 0 ? (_incidentTotalMatch[1] + ' (100%)') : '0 (0%)'
        });
      }
    }
    var _incidentMetricsWithTotal = _incidentTotalMetric ? [_incidentTotalMetric].concat(_incidentMetrics) : _incidentMetrics;
    var _funnelStatusMap = {
      'Pendientes de entrega': 'sent',
      'Entregados no leídos': 'delivered',
      'Leídos': 'read'
    };
    var _performanceNote = _analytics ? _analytics.performanceNote : '';
    var _incidentsNote = _analytics ? _analytics.incidentsNote : '';
    var _costInfo = _analytics ? _analytics.cost : null;
    var _respMetrics = typeof responderMetrics !== 'undefined' && responderMetrics ? responderMetrics : null;
    var _respWindow = _analytics ? _analytics.responseWindowDays : (_respMetrics ? _respMetrics.windowDays : 7);
    var _respCount = _respMetrics ? _respMetrics.respondedCount : 0;
    var _respList = _respMetrics && Array.isArray(_respMetrics.responders) ? _respMetrics.responders : [];
    var _retryStats = typeof retryStats !== 'undefined' && retryStats ? retryStats : null;
    var _recoveredCount = _retryStats ? _retryStats.recoveredCount : 0;
    var _retryDelayMin = _retryStats ? _retryStats.autoRetryDelayMinutes : 10;
    var _canManualRetry = _retryStats ? _retryStats.canManualRetry : false;
    var _autoRetryPending = _retryStats ? _retryStats.autoRetryPending : false;
    var _manualRetryCount = _retryStats ? _retryStats.manualRetryCount : 0;
    var _maxManualRetries = _retryStats ? _retryStats.maxManualRetries : 3;
    var _failedLogs = typeof failedLogs !== 'undefined' && Array.isArray(failedLogs) ? failedLogs : [];
    var _failedCount = _failedLogs.length;
    var _payload = campaign.campaign_payload;
    if (typeof _payload === 'string') {
      try { _payload = JSON.parse(_payload); } catch (e) { _payload = null; }
    }
    var _excludeSegs = _payload && Array.isArray(_payload.excludeSegmentSlugs) ? _payload.excludeSegmentSlugs : [];
    var _excludeIds = _payload && Array.isArray(_payload.excludeContactIds) ? _payload.excludeContactIds : [];
    var _paramRows = [];
    if (typeof campaignParamSummary === 'function') {
      campaignParamSummary(campaign).forEach(function (item) {
        if (!item || !item.label) return;
        _paramRows.push({
          label: String(item.label),
          value: String(item.value || '').trim() || '—',
        });
      });
    }
    if (_paramRows.length === 0) {
      var _fallbackParamIndex = 1;
      String(campaign.message_text || '').split('|').forEach(function (part) {
        var _part = String(part || '').trim();
        if (!_part) return;
        if (/^media:/i.test(_part)) {
          _paramRows.push({ label: 'Cabecera', value: _part });
          return;
        }
        _paramRows.push({ label: '{{' + _fallbackParamIndex + '}}', value: _part });
        _fallbackParamIndex += 1;
      });
    }
    var _logRows = Array.isArray(logs) ? logs : [];
    var _firstSendAt = null;
    _logRows.forEach(function (log) {
      if (!log || !log.created_at) return;
      if (!_firstSendAt || new Date(log.created_at).getTime() < new Date(_firstSendAt).getTime()) {
        _firstSendAt = log.created_at;
      }
    });
    var _detailDateTime = _firstSendAt || campaign.created_at || null;
    var _modalLogsJson = JSON.stringify((Array.isArray(logs) ? logs : []).map(function (log) {
      return {
        id: log.id,
        phone: log.phone || '',
        contactName: log.contact_name || '',
        whatsappMessageId: log.whatsapp_message_id || '',
        status: log.status || '',
        detailText: JSON.stringify(log.response, null, 2),
        createdAt: log.created_at || null
      };
    })).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
    var _modalFailedLogsJson = JSON.stringify(_failedLogs.map(function (log) {
      return {
        id: log.id,
        phone: log.phone || '',
        contactName: log.contact_name || '',
        status: log.status || '',
        incidentType: log.incident_type || '',
        incidentLabel: log.incident_label || 'Mensajes no entregables',
        errorSummary: log.error_summary || '',
        createdAt: log.created_at || null
      };
    })).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
  %>

  <div class="campaign-detail-stack">
    <div class="card campaign-dashboard-card">
      <% if (campaign.status === 'queued' || campaign.status === 'processing') { %>
      <p class="toast toast--ok">Envío en segundo plano. Actualiza la página para ver el progreso.</p>
      <% } else if (campaign.status === 'scheduled') { %>
      <p class="toast toast--ok">Campaña programada: se enviará a la hora indicada. Actualiza la página para ver el progreso.</p>
      <% } %>

      <section class="campaign-dashboard-section">
        <div class="campaign-dashboard-section__head">
          <div>
            <h2 class="card-title">Resultado global</h2>
            <p class="campaign-dashboard-section__lead muted">Visión general de destinatarios, envíos y problemas. Haz clic en un indicador para abrir el detalle.</p>
          </div>
        </div>
        <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--3" role="group" aria-label="Resultado global">
          <% _globalMetrics.forEach(function (metric) { %>
          <% if (metric.action) { %>
          <button
            type="button"
            class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %> metric--action"
            data-metric-modal-type="<%= metric.action.type %>"
            data-metric-filter="<%= metric.action.filter %>"
            data-metric-title="<%= metric.action.title %>"
            data-metric-note="<%= metric.action.note || '' %>"
            title="<%= metric.tooltip || metric.action.title %>"
          >
          <% } else { %>
          <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <% } %>
            <span class="metric-num"><%= metric.display %></span>
            <span class="metric-lbl"><%= metric.label %></span>
          <% if (metric.action) { %>
          </button>
          <% } else { %>
          </div>
          <% } %>
          <% }); %>
        </div>
      </section>

      <section class="campaign-dashboard-section campaign-dashboard-section--last">
        <div class="campaign-dashboard-section__head">
          <div>
            <h2 class="card-title">Detalle de campaña</h2>
            <p class="campaign-dashboard-section__lead muted">Información general y contexto de la campaña.</p>
          </div>
        </div>
        <dl class="detail-dl">
          <div><dt>Segmento(s)</dt><dd><%= campaignSegmentDisplay(campaign) %></dd></div>
          <div><dt>Fecha y hora</dt><dd><%= _detailDateTime ? formatMessageDateTime(_detailDateTime) : '—' %></dd></div>
          <% if (_excludeSegs.length || _excludeIds.length) { %>
          <div><dt>Exclusiones</dt><dd>
            <% if (_excludeSegs.length) { %>
            <span>Segmentos: <%= _excludeSegs.join(', ') %></span>
            <% } %>
            <% if (_excludeSegs.length && _excludeIds.length) { %><br /><% } %>
            <% if (_excludeIds.length) { %>
            <span>Contactos (IDs): <%= _excludeIds.join(', ') %></span>
            <% } %>
          </dd></div>
          <% } %>
          <div><dt>Plantilla</dt><dd><%= campaign.template_name %></dd></div>
          <div><dt>Estado</dt><dd><span class="badge <%= campaign.status %>"><%= campaign.status %></span></dd></div>
          <% if (campaign.scheduled_at) { %>
          <div><dt>Programada para</dt><dd><%= formatMessageDateTime(campaign.scheduled_at) %></dd></div>
          <% } %>
          <% if (_recoveredCount > 0) { %>
          <div><dt>Recuperados en reintento</dt><dd><%= _recoveredCount %></dd></div>
          <% } %>
          <div><dt>Parámetros</dt><dd>
            <% if (_paramRows.length) { %>
            <% _paramRows.forEach(function (row) { %>
            <div><strong><%= row.label %>:</strong> <span class="mono"><%= row.value %></span></div>
            <% }); %>
            <% } else { %>
            —
            <% } %>
          </dd></div>
          <% if (campaign.image_url) { %>
          <div><dt>Imagen</dt><dd><a href="<%= campaign.image_url %>" target="_blank" rel="noopener">Abrir enlace</a></dd></div>
          <% } %>
        </dl>
      </section>
    </div>

    <div class="card campaign-dashboard-card">
      <section class="campaign-dashboard-section">
        <div class="campaign-dashboard-section__head">
          <div>
            <h2 class="card-title">Rendimiento de envío</h2>
            <p class="campaign-dashboard-section__lead muted"><%= _performanceNote %> Haz clic en un indicador para abrir el registro actual filtrado.</p>
          </div>
          <a href="#" class="campaign-concepts-link" id="campaign-concepts-open">Leyenda de conceptos</a>
        </div>
        <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--4" role="group" aria-label="Rendimiento de envío">
          <% _performanceMetrics.forEach(function (metric) { %>
          <% if (metric.action) { %>
          <% if (metric.action.dialogId) { %>
          <button
            type="button"
            class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %> metric--action"
            id="<%= metric.action.id %>"
            aria-haspopup="dialog"
            aria-controls="<%= metric.action.dialogId %>"
            title="<%= metric.action.title || metric.tooltip || '' %>"
          >
            <span class="metric-num"><%= metric.display %></span>
            <span class="metric-lbl"><%= metric.label %></span>
          </button>
          <% } else { %>
          <button
            type="button"
            class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %> metric--action"
            data-metric-modal-type="<%= metric.action.type %>"
            data-metric-filter="<%= metric.action.filter %>"
            data-metric-title="<%= metric.action.title %>"
            data-metric-note="<%= metric.action.note || '' %>"
            title="<%= metric.tooltip || metric.action.title %>"
          >
            <span class="metric-num"><%= metric.display %></span>
            <span class="metric-lbl"><%= metric.label %></span>
          </button>
          <% } %>
          <% } else { %>
          <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
            <span class="metric-num"><%= metric.display %></span>
            <span class="metric-lbl"><%= metric.label %></span>
          </div>
          <% } %>
          <% }); %>
        </div>
        <details class="campaign-meta-funnel-details">
          <summary class="campaign-meta-funnel-summary">Embudo Meta</summary>
          <div class="campaign-meta-funnel-grid" role="group" aria-label="Embudo Meta">
            <% _funnelMetrics.forEach(function (metric) { %>
            <% if (metric.action) { %>
            <button
              type="button"
              class="campaign-meta-funnel-item campaign-meta-funnel-item--button"
              data-metric-modal-type="<%= metric.action.type %>"
              data-metric-filter="<%= metric.action.filter %>"
              data-metric-title="<%= metric.action.title %>"
              data-metric-note="<%= metric.action.note || '' %>"
              title="<%= metric.tooltip || metric.action.title %>"
            >
            <% } else { %>
            <span class="campaign-meta-funnel-item"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
            <% } %>
              <strong><%= metric.label %><% if (_funnelStatusMap[metric.label]) { %> (<%= _funnelStatusMap[metric.label] %>)<% } %></strong> <%= metric.display %>
            <% if (metric.action) { %>
            </button>
            <% } else { %>
            </span>
            <% } %>
            <% }); %>
          </div>
          <p class="campaign-meta-funnel-ratios muted">
            Validación: pendientes de entrega + entregados no leídos + leídos = enviados.
          </p>
        </details>
      </section>

      <section class="campaign-dashboard-section">
        <div class="campaign-dashboard-section__head">
          <div>
            <h2 class="card-title">Negocio</h2>
            <p class="campaign-dashboard-section__lead muted">Resumen comercial de la campaña.</p>
          </div>
        </div>
        <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--2" role="group" aria-label="Métricas de negocio">
          <% _businessMetrics.forEach(function (metric) { %>
          <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
            <% if (metric.displayLines && metric.displayLines.length) { %>
            <span class="metric-num metric-num--stack">
              <% metric.displayLines.forEach(function (line, idx) { %>
              <span class="money-stack__line<%= idx > 0 ? ' money-stack__line--secondary' : '' %>"><%= line %></span>
              <% }); %>
            </span>
            <% } else { %>
            <span class="metric-num"><%= metric.display %></span>
            <% } %>
            <span class="metric-lbl"><%= metric.label %></span>
          </div>
          <% }); %>
        </div>
      </section>

      <section class="campaign-dashboard-section campaign-dashboard-section--last">
      </section>
    </div>

    <div class="card campaign-dashboard-card campaign-failed-card">
      <section class="campaign-dashboard-section">
        <div class="campaign-dashboard-section__head">
          <div>
            <h2 class="card-title">Incidencias de entrega</h2>
            <p class="campaign-dashboard-section__lead muted">Detalle técnico de problemas reportados por Meta. Haz clic en un indicador para abrir las incidencias activas filtradas.</p>
          </div>
        </div>
        <div class="metrics-row campaign-dashboard-grid campaign-dashboard-grid--4" role="group" aria-label="Incidencias de entrega">
          <% _incidentMetricsWithTotal.forEach(function (metric) { %>
          <% if (metric.action) { %>
          <button
            type="button"
            class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %> metric--action"
            data-metric-modal-type="<%= metric.action.type %>"
            data-metric-filter="<%= metric.action.filter %>"
            data-metric-title="<%= metric.action.title %>"
            data-metric-note="<%= metric.action.note || '' %>"
            title="<%= metric.tooltip || metric.action.title %>"
          >
          <% } else { %>
          <div class="metric campaign-summary-metric metric-tone--<%= metric.tone || 'neutral' %>"<% if (metric.tooltip) { %> title="<%= metric.tooltip %>"<% } %>>
          <% } %>
            <span class="metric-num"><%= metric.display %></span>
            <span class="metric-lbl"><%= metric.label %></span>
          <% if (metric.action) { %>
          </button>
          <% } else { %>
          </div>
          <% } %>
          <% }); %>
        </div>
        <% if (_incidentsNote) { %>
        <p class="campaign-dashboard-formula muted"><%= _incidentsNote %></p>
        <% } %>
      </section>

      <section class="campaign-dashboard-section campaign-dashboard-section--last">
        <p class="muted campaign-retry-hint">
          Reintento automático ~<%= _retryDelayMin %> min después del envío para errores temporales.
          <% if (_autoRetryPending) { %> Pendiente de reintento automático.<% } %>
          <% if (_manualRetryCount > 0) { %> Reintentos manuales: <%= _manualRetryCount %>/<%= _maxManualRetries %>.<% } %>
        </p>
      </section>
    </div>
  </div>

  <dialog id="campaign-concepts-dialog" class="modal-dialog campaign-concepts-dialog" aria-labelledby="campaign-concepts-dialog-title">
    <form method="dialog" class="modal-dialog-form campaign-concepts-dialog__form">
      <div class="campaign-drilldown-dialog__head">
        <div>
          <h2 id="campaign-concepts-dialog-title" class="modal-dialog-title">Leyenda de conceptos</h2>
          <p class="muted campaign-concepts-legend__intro">
            Meta trabaja con estados acumulativos en rendimiento y con estados exclusivos en el embudo. Los estados técnicos de referencia son <code>sent</code>, <code>delivered</code> y <code>read</code>.
          </p>
        </div>
      </div>
      <div class="campaign-concepts-legend__body">
        <ul class="campaign-concepts-legend__list">
          <li><strong>Pendientes de entrega (sent)</strong>: enviados que aún no fueron confirmados como entregados o leídos.</li>
          <li><strong>Entregados no leídos (delivered)</strong>: entregados correctamente, pero aún no leídos.</li>
          <li><strong>Leídos (read)</strong>: subconjunto final de entregados.</li>
          <li><strong>Enviados</strong>: <code>sent + delivered + read</code>.</li>
          <li><strong>Entregados</strong>: <code>delivered + read</code>.</li>
          <li><strong>Problemas de entrega</strong>: casos en <code>error</code>, <code>failed</code> o <code>undelivered</code>, además de destinatarios aún sin traza exitosa cuando la campaña sigue en proceso.</li>
          <li><strong>Total destinatarios</strong>: enviados + problemas de entrega.</li>
        </ul>
      </div>
      <div class="modal-dialog-actions">
        <button type="submit" class="small-btn secondary">Cerrar</button>
      </div>
    </form>
  </dialog>

  <dialog id="campaign-logs-dialog" class="modal-dialog campaign-drilldown-dialog" aria-labelledby="campaign-logs-dialog-title">
    <form method="dialog" class="modal-dialog-form campaign-drilldown-dialog__form">
      <div class="campaign-drilldown-dialog__head">
        <div>
          <h2 id="campaign-logs-dialog-title" class="modal-dialog-title">Registro actual</h2>
          <p class="muted campaign-drilldown-dialog__hint">Trazas actuales por destinatario. Si hubo reintentos, se muestra solo la última traza registrada.</p>
        </div>
        <div class="campaign-drilldown-dialog__actions campaign-drilldown-dialog__actions--top">
          <a id="campaign-logs-export-link" class="small-btn secondary" href="#">Exportar Excel</a>
        </div>
      </div>
      <p id="campaign-logs-dialog-note" class="muted campaign-drilldown-dialog__note" hidden></p>
      <div class="table-wrap campaign-drilldown-dialog__table-wrap">
        <table>
          <thead>
            <tr>
              <th>Teléfono</th>
              <th>Nombre</th>
              <th>Estado</th>
              <th>ID mensaje</th>
              <th>Detalle</th>
            </tr>
          </thead>
          <tbody id="campaign-logs-dialog-body"></tbody>
        </table>
      </div>
      <p id="campaign-logs-dialog-empty" class="muted" hidden>No hay trazas actuales para este filtro.</p>
      <div class="modal-dialog-actions">
        <button type="submit" class="small-btn secondary">Cerrar</button>
      </div>
    </form>
  </dialog>

  <dialog id="campaign-incidents-dialog" class="modal-dialog campaign-drilldown-dialog" aria-labelledby="campaign-incidents-dialog-title">
    <form method="dialog" class="modal-dialog-form campaign-drilldown-dialog__form">
      <div class="campaign-drilldown-dialog__head">
        <div>
          <h2 id="campaign-incidents-dialog-title" class="modal-dialog-title">Incidencias activas</h2>
          <p class="muted campaign-drilldown-dialog__hint">Incidencias activas por destinatario según la última traza con error.</p>
        </div>
        <div class="campaign-drilldown-dialog__actions campaign-drilldown-dialog__actions--top">
          <a id="campaign-incidents-export-link" class="small-btn secondary" href="#">Exportar Excel</a>
          <% if (_canManualRetry) { %>
          <button type="button" class="small-btn" id="campaign-incidents-retry-btn" data-campaign-id="<%= campaign.id %>">Reintentar</button>
          <% } %>
        </div>
      </div>
      <p id="campaign-incidents-dialog-note" class="muted campaign-drilldown-dialog__note" hidden></p>
      <div class="table-wrap campaign-drilldown-dialog__table-wrap">
        <table>
          <thead>
            <tr>
              <th>Teléfono</th>
              <th>Nombre</th>
              <th>Estado</th>
              <th>Incidencia</th>
              <th>Motivo</th>
            </tr>
          </thead>
          <tbody id="campaign-incidents-dialog-body"></tbody>
        </table>
      </div>
      <p id="campaign-incidents-dialog-empty" class="muted" hidden>No hay incidencias activas para este filtro.</p>
      <div class="modal-dialog-actions">
        <button type="submit" class="small-btn secondary">Cerrar</button>
      </div>
    </form>
  </dialog>

  <dialog id="campaign-responders-dialog" class="modal-dialog campaign-responders-dialog" aria-labelledby="campaign-responders-dialog-title">
    <form method="dialog" class="modal-dialog-form campaign-responders-dialog__form">
      <div class="campaign-drilldown-dialog__head">
        <div>
          <h2 id="campaign-responders-dialog-title" class="modal-dialog-title">
            Respuestas únicas (<%= _respWindow %> días) · <%= _respCount %>
          </h2>
          <p class="muted campaign-responders-dialog__hint">
            Cuentas únicas que respondieron dentro de los <%= _respWindow %> días posteriores al envío de la plantilla.
          </p>
        </div>
        <div class="campaign-drilldown-dialog__actions campaign-drilldown-dialog__actions--top">
          <a
            class="small-btn secondary"
            href="<%= basePath %>/api/campaigns/<%= campaign.id %>/responders-export"
          >Exportar Excel</a>
        </div>
      </div>
      <% if (_respList.length === 0) { %>
      <p class="muted">Aún sin datos de respuestas en esta ventana.</p>
      <% } else { %>
      <div class="table-wrap campaign-responders-dialog__table-wrap">
        <table>
          <thead>
            <tr>
              <th>Teléfono</th>
              <th>Nombre</th>
              <th>Primera respuesta</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% _respList.forEach(function (row) {
              var _chatHref = row.conversationId
                ? basePath + '/conversations/' + row.conversationId
                : (row.contactId ? basePath + '/conversations/' + (-row.contactId) : null);
            %>
            <tr>
              <td class="mono"><%= row.phone %></td>
              <td><%= row.contactName || '—' %></td>
              <td><%= row.firstResponseAt ? formatMessageDateTime(row.firstResponseAt) : '—' %></td>
              <td class="campaign-responders-dialog__actions">
                <% if (_chatHref) { %>
                <a class="text-link" href="<%= _chatHref %>">Abrir chat</a>
                <% } else { %>
                <span class="muted">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
      <div class="modal-dialog-actions">
        <button type="submit" class="small-btn secondary">Cerrar</button>
      </div>
    </form>
  </dialog>
  <script>
    (function () {
      var basePath = '<%= basePath %>';
      var campaignId = '<%= campaign.id %>';
      var allLogs = <%- _modalLogsJson %>;
      var allFailedLogs = <%- _modalFailedLogsJson %>;
      var conceptsBtn = document.getElementById('campaign-concepts-open');
      var conceptsDialog = document.getElementById('campaign-concepts-dialog');
      var respondersBtn = document.getElementById('campaign-responders-open');
      var respondersDialog = document.getElementById('campaign-responders-dialog');
      var logsDialog = document.getElementById('campaign-logs-dialog');
      var incidentsDialog = document.getElementById('campaign-incidents-dialog');
      var logsDialogTitle = document.getElementById('campaign-logs-dialog-title');
      var logsDialogNote = document.getElementById('campaign-logs-dialog-note');
      var logsDialogBody = document.getElementById('campaign-logs-dialog-body');
      var logsDialogEmpty = document.getElementById('campaign-logs-dialog-empty');
      var logsExportLink = document.getElementById('campaign-logs-export-link');
      var incidentsDialogTitle = document.getElementById('campaign-incidents-dialog-title');
      var incidentsDialogNote = document.getElementById('campaign-incidents-dialog-note');
      var incidentsDialogBody = document.getElementById('campaign-incidents-dialog-body');
      var incidentsDialogEmpty = document.getElementById('campaign-incidents-dialog-empty');
      var incidentsExportLink = document.getElementById('campaign-incidents-export-link');
      var incidentsRetryBtn = document.getElementById('campaign-incidents-retry-btn');

      function normalizeStatus(status) {
        return String(status || '').trim().toLowerCase();
      }

      function wireDialogDismiss(dialog) {
        if (!dialog) return;
        dialog.addEventListener('click', function (ev) {
          if (ev.target === dialog) dialog.close();
        });
      }

      function latestLogsByPhone(rows) {
        var latest = [];
        var seen = Object.create(null);
        (Array.isArray(rows) ? rows : []).forEach(function (row) {
          var phone = String((row && row.phone) || '').trim();
          var key = phone || ('log:' + String((row && row.id) || ''));
          if (seen[key]) return;
          seen[key] = true;
          latest.push(row);
        });
        return latest;
      }

      function filterCurrentLogs(filter) {
        var rows = latestLogsByPhone(allLogs);
        var key = String(filter || 'all_current').trim().toLowerCase();
        if (!key || key === 'all_current') return rows;
        return rows.filter(function (row) {
          var status = normalizeStatus(row.status);
          if (key === 'sent_all') return status === 'sent' || status === 'delivered' || status === 'read';
          if (key === 'delivered_all') return status === 'delivered' || status === 'read';
          if (key === 'read_only') return status === 'read';
          if (key === 'sent_only') return status === 'sent';
          if (key === 'delivered_only') return status === 'delivered';
          return true;
        });
      }

      function filterIncidents(filter) {
        var key = String(filter || 'all').trim().toLowerCase();
        if (!key || key === 'all') return Array.isArray(allFailedLogs) ? allFailedLogs : [];
        return (Array.isArray(allFailedLogs) ? allFailedLogs : []).filter(function (row) {
          return String((row && row.incidentType) || '').trim().toLowerCase() === key;
        });
      }

      function clearRows(tbody) {
        if (!tbody) return;
        while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
      }

      function createCell(tag, text, className) {
        var cell = document.createElement(tag || 'td');
        if (className) cell.className = className;
        cell.textContent = text == null || text === '' ? '—' : String(text);
        return cell;
      }

      function renderLogsRows(rows) {
        clearRows(logsDialogBody);
        (rows || []).forEach(function (row) {
          var tr = document.createElement('tr');
          tr.appendChild(createCell('td', row.phone, 'mono'));
          tr.appendChild(createCell('td', row.contactName));

          var statusTd = document.createElement('td');
          var badge = document.createElement('span');
          badge.className = 'badge ' + String(row.status || '');
          badge.textContent = String(row.status || '—');
          statusTd.appendChild(badge);
          tr.appendChild(statusTd);

          tr.appendChild(createCell('td', row.whatsappMessageId, 'mono'));

          var detailTd = document.createElement('td');
          var pre = document.createElement('pre');
          pre.className = 'log-pre';
          pre.textContent = row.detailText || '—';
          detailTd.appendChild(pre);
          tr.appendChild(detailTd);

          logsDialogBody.appendChild(tr);
        });
        logsDialogEmpty.hidden = rows.length > 0;
      }

      function renderIncidentRows(rows) {
        clearRows(incidentsDialogBody);
        (rows || []).forEach(function (row) {
          var tr = document.createElement('tr');
          tr.appendChild(createCell('td', row.phone, 'mono'));
          tr.appendChild(createCell('td', row.contactName));

          var statusTd = document.createElement('td');
          var badge = document.createElement('span');
          badge.className = 'badge ' + String(row.status || '');
          badge.textContent = String(row.status || '—');
          statusTd.appendChild(badge);
          tr.appendChild(statusTd);

          tr.appendChild(createCell('td', row.incidentLabel || 'Mensajes no entregables'));
          tr.appendChild(createCell('td', row.errorSummary || '—'));
          incidentsDialogBody.appendChild(tr);
        });
        incidentsDialogEmpty.hidden = rows.length > 0;
      }

      function buildLogsExportHref(filter) {
        return (
          basePath +
          '/api/campaigns/' +
          encodeURIComponent(campaignId) +
          '/logs-export?filter=' +
          encodeURIComponent(String(filter || 'all_current'))
        );
      }

      function buildIncidentsExportHref(filter) {
        return (
          basePath +
          '/api/campaigns/' +
          encodeURIComponent(campaignId) +
          '/incidents-export?filter=' +
          encodeURIComponent(String(filter || 'all'))
        );
      }

      function setOptionalNote(node, text) {
        if (!node) return;
        var value = String(text || '').trim();
        node.textContent = value;
        node.hidden = !value;
      }

      function openDialog(dialog) {
        if (dialog && typeof dialog.showModal === 'function') dialog.showModal();
      }

      function handleMetricTrigger(btn) {
        if (!btn) return;
        var type = String(btn.getAttribute('data-metric-modal-type') || '').trim();
        var filter = String(btn.getAttribute('data-metric-filter') || '').trim();
        var title = String(btn.getAttribute('data-metric-title') || '').trim();
        var note = String(btn.getAttribute('data-metric-note') || '').trim();

        if (type === 'logs') {
          var rows = filterCurrentLogs(filter);
          logsDialogTitle.textContent = (title || 'Registro de envíos') + ' · ' + rows.length;
          setOptionalNote(logsDialogNote, note);
          logsExportLink.setAttribute('href', buildLogsExportHref(filter));
          renderLogsRows(rows);
          openDialog(logsDialog);
          return;
        }

        if (type === 'incidents') {
          var incidentRows = filterIncidents(filter);
          incidentsDialogTitle.textContent = (title || 'Incidencias detalladas') + ' · ' + incidentRows.length;
          var retryNote = incidentsRetryBtn
            ? 'El botón Reintentar aplica a todas las incidencias activas de la campaña.'
            : '';
          var baseIncidentsNote = [note, retryNote].filter(Boolean).join(' ');
          incidentsDialog.setAttribute('data-base-note', baseIncidentsNote);
          setOptionalNote(incidentsDialogNote, baseIncidentsNote);
          incidentsExportLink.setAttribute('href', buildIncidentsExportHref(filter));
          renderIncidentRows(incidentRows);
          openDialog(incidentsDialog);
        }
      }

      document.querySelectorAll('[data-metric-modal-type]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          handleMetricTrigger(btn);
        });
      });

      if (conceptsBtn && conceptsDialog) {
        conceptsBtn.addEventListener('click', function (ev) {
          ev.preventDefault();
          openDialog(conceptsDialog);
        });
      }

      if (respondersBtn && respondersDialog) {
        respondersBtn.addEventListener('click', function () {
          openDialog(respondersDialog);
        });
      }

      wireDialogDismiss(conceptsDialog);
      wireDialogDismiss(respondersDialog);
      wireDialogDismiss(logsDialog);
      wireDialogDismiss(incidentsDialog);

      function setRetryButtonsDisabled(disabled) {
        if (incidentsRetryBtn) incidentsRetryBtn.disabled = disabled;
      }

      function runRetryRequest() {
        if (!incidentsRetryBtn) return;
        setRetryButtonsDisabled(true);
        if (incidentsDialogNote) {
          setOptionalNote(incidentsDialogNote, incidentsDialog.getAttribute('data-base-note') || '');
        }
        fetch(basePath + '/api/campaigns/' + encodeURIComponent(campaignId) + '/retry-failed', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { Accept: 'application/json' },
        })
          .then(function (r) {
            return r.json().then(function (data) {
              return { ok: r.ok, data: data };
            });
          })
          .then(function (result) {
            if (!result.ok || !result.data.ok) {
              var msg = (result.data && result.data.error) || 'No se pudo reintentar';
              if (incidentsDialogNote && incidentsDialog.open) {
                incidentsDialogNote.textContent = msg;
                incidentsDialogNote.hidden = false;
              }
              setRetryButtonsDisabled(false);
              return;
            }
            var d = result.data;
            var summary =
              'Reintento: ' +
              d.retried +
              ' teléfono(s), ' +
              d.recovered +
              ' recuperado(s), ' +
              d.stillFailed +
              ' aún con incidencia activa.';
            if (incidentsDialogNote && incidentsDialog.open) {
              incidentsDialogNote.textContent = summary;
              incidentsDialogNote.hidden = false;
            }
            window.setTimeout(function () {
              window.location.reload();
            }, 1200);
          })
          .catch(function () {
            if (incidentsDialogNote && incidentsDialog.open) {
              incidentsDialogNote.textContent = 'Error de red al reintentar';
              incidentsDialogNote.hidden = false;
            }
            setRetryButtonsDisabled(false);
          });
      }

      if (incidentsRetryBtn) {
        incidentsRetryBtn.addEventListener('click', function () {
          runRetryRequest();
        });
      }
    })();
  </script>
</div>
