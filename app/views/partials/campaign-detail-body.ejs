<div class="page page--detail campaign-detail-page">
  <% 
    var _logTotal = logs.length;
    var _nSent = 0, _nDel = 0, _nRead = 0, _nErr = 0, _nOtro = 0;
    var _otrosSeen = {};
    var _otrosLabels = [];
    logs.forEach(function (log) {
      var s = String(log.status || '').trim().toLowerCase();
      if (s === 'sent') _nSent++;
      else if (s === 'delivered') _nDel++;
      else if (s === 'read') _nRead++;
      else if (s === 'error' || s === 'failed' || s === 'undelivered') _nErr++;
      else {
        _nOtro++;
        var raw = String(log.status || '').trim();
        if (raw && !_otrosSeen[raw]) {
          _otrosSeen[raw] = true;
          _otrosLabels.push(raw);
        }
      }
    });
    var _salidaOk = _nSent + _nDel + _nRead;
    var _readForPct = _nRead;
    var _errorPct = _logTotal > 0 ? Math.round((_nErr / _logTotal) * 100) : 0;
    var _readPct = _salidaOk > 0 ? Math.round((_readForPct / _salidaOk) * 100) : null;
    var _onDevicePct = _salidaOk > 0 ? Math.round(((_nDel + _nRead) / _salidaOk) * 100) : null;
    var _readOnDeliveredPct = (_nDel + _nRead) > 0 ? Math.round((_nRead / (_nDel + _nRead)) * 100) : null;
    var _otrosTitle = _otrosLabels.length ? _otrosLabels.join(', ') : '';
  %>
  <div class="card campaign-detail-metrics">
    <h2 class="card-title">Indicadores de esta campaña</h2>
    <div class="metrics-row metrics-row--history metrics-row--compact" role="region" aria-label="Indicadores de campaña">
      <div class="metric"><span class="metric-num"><%= _logTotal %></span><span class="metric-lbl">Total</span></div>
      <div class="metric"><span class="metric-num"><%= _salidaOk %></span><span class="metric-lbl">Salida OK</span></div>
      <div class="metric"><span class="metric-num"><%= _errorPct %>%</span><span class="metric-lbl">Error</span></div>
      <div class="metric"><span class="metric-num"><%= _readPct !== null ? _readPct + '%' : '—' %></span><span class="metric-lbl">Lectura</span></div>
    </div>
    <details class="campaign-meta-funnel-details">
      <summary class="campaign-meta-funnel-summary">Embudo Meta (detalle)</summary>
      <div class="campaign-meta-funnel-grid" role="group" aria-label="Contadores por estado">
        <span class="campaign-meta-funnel-item"><strong>sent</strong> <%= _nSent %></span>
        <span class="campaign-meta-funnel-item"><strong>delivered</strong> <%= _nDel %></span>
        <span class="campaign-meta-funnel-item"><strong>read</strong> <%= _nRead %></span>
        <span class="campaign-meta-funnel-item"><strong>error</strong> <%= _nErr %></span>
        <span class="campaign-meta-funnel-item"<% if (_otrosTitle) { %> title="<%= _otrosTitle %>"<% } %>><strong>otros</strong> <%= _nOtro %></span>
      </div>
      <% if (_onDevicePct !== null || _readOnDeliveredPct !== null) { %>
      <p class="campaign-meta-funnel-ratios muted">
        <% if (_onDevicePct !== null) { %>
        <span>En dispositivo (Meta): <%= _onDevicePct %>%</span>
        <% } %>
        <% if (_onDevicePct !== null && _readOnDeliveredPct !== null) { %><span class="campaign-meta-funnel-ratios-sep"> · </span><% } %>
        <% if (_readOnDeliveredPct !== null) { %>
        <span>Lectura / entregado en dispositivo: <%= _readOnDeliveredPct %>%</span>
        <% } %>
      </p>
      <% } %>
    </details>
  </div>
  <div class="card">
    <% if (campaign.status === 'queued' || campaign.status === 'processing') { %>
    <p class="toast toast--ok">Envío en segundo plano. Actualiza la página para ver el progreso.</p>
    <% } else if (campaign.status === 'scheduled') { %>
    <p class="toast toast--ok">Campaña programada: se enviará a la hora indicada. Actualiza la página para ver el progreso.</p>
    <% } %>
    <dl class="detail-dl">
      <div><dt>Segmento</dt><dd><%= campaign.segment %></dd></div>
      <div><dt>Plantilla</dt><dd><%= campaign.template_name %></dd></div>
      <div><dt>Estado</dt><dd><span class="badge <%= campaign.status %>"><%= campaign.status %></span></dd></div>
      <% if (campaign.scheduled_at) { %>
      <div><dt>Programada para</dt><dd><%= formatMessageDateTime(campaign.scheduled_at) %></dd></div>
      <% } %>
      <div><dt>Destinatarios</dt><dd><%= campaign.total_recipients %></dd></div>
      <div><dt>Parámetros</dt><dd><%= campaign.message_text %></dd></div>
      <% if (campaign.image_url) { %>
      <div><dt>Imagen</dt><dd><a href="<%= campaign.image_url %>" target="_blank" rel="noopener">Abrir enlace</a></dd></div>
      <% } %>
    </dl>
  </div>

  <div class="card">
    <h2 class="card-title">Registro de envíos</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>ID mensaje</th>
            <th>Detalle</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(function (log) { %>
          <tr>
            <td class="mono"><%= log.phone %></td>
            <td><span class="badge <%= log.status %>"><%= log.status %></span></td>
            <td class="mono"><%= log.whatsapp_message_id || '—' %></td>
            <td><pre class="log-pre"><%= JSON.stringify(log.response, null, 2) %></pre></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
