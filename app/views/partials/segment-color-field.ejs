<% const _segColor = typeof selectedColorKey !== 'undefined' ? selectedColorKey : 'teal'; %>
<% const _compact = typeof compactRow !== 'undefined' && compactRow; %>
<% const _tones = ['teal', 'emerald', 'blue', 'violet', 'amber', 'rose', 'slate']; %>
<% const _toneTitles = { teal: 'MALI', emerald: 'Verde', blue: 'Azul', violet: 'Violeta', amber: 'Ámbar', rose: 'Rosa', slate: 'Gris' }; %>
<% if (_compact) { %>
<fieldset class="segment-field segment-field--color segment-color-rings-field segment-color-rings-field--compact">
  <legend class="segment-field-lbl">Color</legend>
  <div class="segment-color-rings-row" role="radiogroup" aria-label="Color del segmento">
    <% _tones.forEach(function (tone) { %>
    <label class="segment-color-ring-label" title="<%= _toneTitles[tone] %>">
      <input type="radio" name="color_key" value="<%= tone %>" <%= _segColor === tone ? 'checked' : '' %> required />
      <span class="segment-color-ring" data-seg-tone="<%= tone %>" aria-hidden="true"></span>
    </label>
    <% }); %>
  </div>
</fieldset>
<% } else { %>
<fieldset class="field segment-color-rings-field">
  <legend class="field-label">Color en conversaciones</legend>
  <div class="segment-color-rings-row" role="radiogroup" aria-label="Color del segmento">
    <% _tones.forEach(function (tone) { %>
    <label class="segment-color-ring-label" title="<%= _toneTitles[tone] %>">
      <input type="radio" name="color_key" value="<%= tone %>" <%= _segColor === tone ? 'checked' : '' %> required />
      <span class="segment-color-ring" data-seg-tone="<%= tone %>" aria-hidden="true"></span>
    </label>
    <% }); %>
  </div>
</fieldset>
<% } %>
