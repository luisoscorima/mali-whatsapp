<% const _rt = typeof refreshTitle !== 'undefined' ? refreshTitle : 'Actualizar'; %>
<% const _ra = typeof refreshAriaLabel !== 'undefined' ? refreshAriaLabel : _rt; %>
<button
  type="button"
  class="wa-refresh-btn wa-refresh-btn--icon-only"
  onclick="location.reload()"
  title="<%= _rt %>"
  aria-label="<%= _ra %>"
>
  <span class="wa-refresh-btn__icon" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
  </span>
</button>
