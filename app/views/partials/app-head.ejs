<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/png" href="<%= maliLogoUrl %>" />
<link rel="apple-touch-icon" href="<%= maliLogoUrl %>" />
<title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'MALI WhatsApp' %></title>
<script>
  try {
    var _t = localStorage.getItem('mali-theme');
    if (_t === 'dark' || _t === 'light') document.documentElement.setAttribute('data-theme', _t);
  } catch (e) {}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>
<link rel="stylesheet" href="<%= basePath %>/css/styles.css" />
<link rel="stylesheet" href="<%= basePath %>/css/wa-shell.css" />
<link rel="stylesheet" href="<%= basePath %>/css/conversations.css" />
<script src="<%= basePath %>/js/theme.js" defer></script>
<% if (typeof extraHeadScripts !== 'undefined' && extraHeadScripts) { %>
<% extraHeadScripts.forEach(function (src) { %>
<script src="<%= src %>" defer></script>
<% }); %>
<% } %>
