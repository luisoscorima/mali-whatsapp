<% const _p = typeof preview !== 'undefined' && preview ? preview : null; %>
<% if (_p) { %>
<div class="template-live-preview template-live-preview--detail">
  <div class="template-live-preview__sticky">
    <div class="template-live-preview__phone">
      <div class="template-live-preview__screen">
        <div class="template-live-preview__message">
          <% if (_p.headerMediaUrl && _p.headerMediaType === 'image') { %>
          <div class="template-live-preview__media template-live-preview__media--image">
            <img src="<%= _p.headerMediaUrl %>" alt="Imagen de cabecera" loading="lazy" decoding="async" />
          </div>
          <% } else if (_p.headerMediaType === 'video') { %>
          <div class="template-live-preview__media template-live-preview__media--placeholder">
            <span class="badge neutral">VIDEO</span><span>Video de cabecera</span>
          </div>
          <% } else if (_p.headerMediaType === 'document') { %>
          <div class="template-live-preview__media template-live-preview__media--placeholder">
            <span class="badge neutral">DOCUMENT</span><span>Documento de cabecera</span>
          </div>
          <% } %>

          <% if (_p.headerText) { %>
          <div class="template-live-preview__header-text"><%- formatWhatsAppHtml(_p.headerText) %></div>
          <% } %>

          <% if (_p.bodyText) { %>
          <div class="template-live-preview__body"><%- formatWhatsAppHtml(_p.bodyText) %></div>
          <% } else { %>
          <div class="template-live-preview__body template-live-preview__body--empty">Sin texto de cuerpo.</div>
          <% } %>

          <% if (_p.footerText) { %>
          <div class="template-live-preview__footer"><%- formatWhatsAppHtml(_p.footerText) %></div>
          <% } %>

          <% if (_p.buttons && _p.buttons.length) { %>
          <div class="template-live-preview__buttons">
            <% _p.buttons.forEach(function (btn) { %>
            <button type="button" class="template-live-preview__button" tabindex="-1">
              <span class="template-live-preview__button-text"><%= btn.text || 'Botón' %></span>
              <% if (btn.url) { %>
              <span class="template-live-preview__button-url" title="<%= btn.url %>"><%- summarizeTemplatePreviewUrl(btn.url) %></span>
              <% } %>
            </button>
            <% }); %>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <% if (_p.headerMediaType) { %>
    <p class="inline-help muted">
      Cabecera: <strong><%= String(_p.headerMediaType).toUpperCase() %></strong>
    </p>
    <% } else if (_p.headerText) { %>
    <p class="inline-help muted">
      Cabecera: <strong>TEXT</strong>
    </p>
    <% } %>
  </div>
</div>
<% } %>
