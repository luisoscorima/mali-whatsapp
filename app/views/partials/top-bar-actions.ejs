<% const barVariant = typeof topBarVariant !== 'undefined' ? topBarVariant : 'default'; %>
<% const initial = requireAuth && currentUser && currentUser.email ? String(currentUser.email).charAt(0).toUpperCase() : '?'; %>
<div class="top-bar-actions top-bar-actions--<%= barVariant %>">
  <% if (requireAuth && currentUser && currentUser.isMaster) { %>
  <form method="post" action="<%= basePath %>/admin/switch-area" class="area-switch-form" title="Solo master: cambiar área de trabajo">
    <label class="area-switch-label">
      <span class="muted">Área</span>
      <select name="area" class="area-switch-select" aria-label="Cambiar área">
        <option value="ti" <%= currentUser.area === 'ti' ? 'selected' : '' %>>TI (dev)</option>
        <option value="pam" <%= currentUser.area === 'pam' ? 'selected' : '' %>>PAM</option>
        <option value="educacion" <%= currentUser.area === 'educacion' ? 'selected' : '' %>>Educación</option>
      </select>
    </label>
    <button type="submit" class="small-btn secondary area-switch-btn">Cambiar</button>
  </form>
  <% } %>
  <button type="button" class="theme-toggle" data-theme-toggle title="Modo claro / oscuro" aria-label="Cambiar tema">◐</button>
  <% if (requireAuth) { %>
    <details class="user-menu">
      <summary class="user-menu-trigger" aria-label="Menú de cuenta">
        <span class="user-avatar" aria-hidden="true"><%= initial %></span>
      </summary>
      <div class="user-menu-dropdown">
        <p class="user-menu-name"><%= currentUser.email %></p>
        <p class="user-menu-meta">
          <span class="area-pill area-pill--menu"><%= areaLabel %></span>
          <% if (currentUser.isMaster) { %>
            <span class="area-pill area-pill--master area-pill--menu">Master</span>
          <% } %>
        </p>
        <form method="post" action="<%= basePath %>/logout" class="user-menu-logout">
          <button type="submit" class="secondary small-btn user-menu-logout-btn">Cerrar sesión</button>
        </form>
      </div>
    </details>
  <% } else { %>
    <span class="muted top-bar-dev-hint">Dev · <%= areaLabel %></span>
  <% } %>
</div>
