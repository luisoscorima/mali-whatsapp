<% if (messages.length === 0) { %>
  <p class="empty-state">Sin mensajes almacenados.</p>
<% } else { %>
  <% const bp = typeof basePath !== 'undefined' ? basePath : ''; %>
  <% function parsePayload(raw) {
       if (!raw) return null;
       if (typeof raw === 'object') return raw;
       try { return JSON.parse(raw); } catch (e) { return null; }
     }
     function mediaIcon(t) {
       if (t === 'image') return '📷';
       if (t === 'video') return '🎬';
       if (t === 'audio') return '🎵';
       if (t === 'voice') return '🎙️';
       if (t === 'document') return '📎';
       if (t === 'sticker') return '🎭';
       if (t === 'location') return '📍';
       if (t === 'contacts') return '👤';
       if (t === 'interactive' || t === 'button') return '🔘';
       if (t === 'campaign') return '📢';
       return '';
     }
     function mediaLabel(t) {
       if (t === 'image') return 'Imagen';
       if (t === 'video') return 'Video';
       if (t === 'audio') return 'Audio';
       if (t === 'voice') return 'Nota de voz';
       if (t === 'document') return 'Documento';
       if (t === 'sticker') return 'Sticker';
       if (t === 'location') return 'Ubicación';
       if (t === 'contacts') return 'Contacto';
       if (t === 'interactive' || t === 'button') return 'Interactivo';
       if (t === 'campaign') return 'Campaña';
       return '';
     }
     function isMediaType(t) {
       return ['image', 'video', 'audio', 'voice', 'document', 'sticker'].indexOf(t) !== -1;
     }
     /** URL absoluta https (S3) o ruta bajo basePath (p. ej. /uploads/chat-media/...). */
     function resolvePreviewMediaUrl(base, url) {
       if (!url) return '';
       var u = String(url).trim();
       if (/^https?:\/\//i.test(u)) return u;
       var pathPart = u.indexOf('/') === 0 ? u : '/' + u;
       var b = String(base || '').replace(/\/$/, '');
       return b + pathPart;
     }
     function mediaDownloadHref(base, convId, msgId) {
       if (!convId || !msgId) return '';
       return resolvePreviewMediaUrl(base, '/conversations/' + convId + '/messages/' + msgId + '/download');
     }
     function extractReferralBubble(raw) {
       if (!raw || typeof raw !== 'object') return null;
       var ref = raw.referral;
       if (!ref && raw.context && raw.context.referral) ref = raw.context.referral;
       if (!ref || typeof ref !== 'object') return null;
       var url = String(ref.source_url || '');
       var lu = url.toLowerCase();
       var platform = 'Meta';
       if (lu.indexOf('instagram') !== -1 || lu.indexOf('ig.me') !== -1) platform = 'Instagram';
       else if (lu.indexOf('facebook') !== -1 || lu.indexOf('fb.me') !== -1 || lu.indexOf('fb.com') !== -1) platform = 'Facebook';
       return {
         platform: platform,
         headline: ref.headline ? String(ref.headline) : '',
         body: ref.body ? String(ref.body) : '',
         source_id: ref.source_id ? String(ref.source_id) : ''
       };
     }
  %>
  <% const _convId = typeof conversationId !== 'undefined' ? conversationId : null; %>
  <div class="chat-thread chat-thread--inbox" id="chat-thread">
    <% messages.forEach((m) => { %>
      <% const raw = parsePayload(m.raw_payload); %>
      <% const refBubble = m.direction !== 'outbound' ? extractReferralBubble(raw) : null; %>
      <% const lp = raw && raw.local_preview; %>
      <% const mediaUrl = lp && lp.url ? resolvePreviewMediaUrl(bp, lp.url) : ''; %>
      <% const mt = String(m.message_type || 'text'); %>
      <% const showTypeRow = isMediaType(mt) || (mt !== 'text' && mediaIcon(mt)); %>
      <div class="chat-bubble <%= m.direction === 'outbound' ? 'chat-bubble--out' : 'chat-bubble--in' %><%= m.direction === 'outbound' && m.is_ai ? ' chat-bubble--ai' : '' %>">
        <% if (m.direction === 'outbound' && m.is_ai) { %>
          <span class="chat-bubble__ai-tag" title="Respuesta automática (IA)"><span aria-hidden="true">✨</span> IA</span>
        <% } %>
        <% if (refBubble) { %>
          <div class="chat-referral-bubble" role="note" aria-label="Origen anuncio <%= refBubble.platform %>">
            <span class="chat-referral-bubble__platform">📣 <%= refBubble.platform %></span>
            <% if (refBubble.headline) { %><p class="chat-referral-bubble__headline"><%= refBubble.headline %></p><% } %>
            <% if (refBubble.body) { %><p class="chat-referral-bubble__body"><%= refBubble.body %></p><% } %>
          </div>
        <% } %>
        <% if (showTypeRow) { %>
          <div class="chat-bubble__type" title="<%= mediaLabel(mt) || mt %>">
            <span class="chat-msg-type-icon" aria-hidden="true"><%= mediaIcon(mt) || '📎' %></span>
            <span class="chat-msg-type-label"><%= mediaLabel(mt) || mt %></span>
          </div>
        <% } %>
        <% const lpMime = lp && lp.mime ? String(lp.mime) : ''; %>
        <% if (mediaUrl && (mt === 'image' || mt === 'sticker')) { %>
          <div class="chat-bubble__media">
            <img class="chat-msg-media chat-msg-media--img" src="<%= mediaUrl %>" alt="" loading="lazy" decoding="async" />
            <% const _dlImg = _convId && m.id ? mediaDownloadHref(bp, _convId, m.id) : mediaUrl; %>
            <a class="chat-msg-download-link" href="<%= _dlImg %>"<%= _convId && m.id ? '' : ' download' %>>Descargar</a>
          </div>
        <% } else if (mediaUrl && mt === 'video') { %>
          <div class="chat-bubble__media">
            <video class="chat-msg-media chat-msg-media--video" controls playsinline preload="metadata" src="<%= mediaUrl %>"></video>
          </div>
        <% } else if (mediaUrl && (mt === 'audio' || mt === 'voice')) { %>
          <div class="chat-bubble__media">
            <audio class="chat-msg-media chat-msg-media--audio" controls preload="metadata" src="<%= mediaUrl %>"></audio>
          </div>
        <% } else if (mediaUrl && mt === 'document') { %>
          <div class="chat-bubble__media chat-bubble__media--doc">
            <% const _dlDoc = _convId && m.id ? mediaDownloadHref(bp, _convId, m.id) : mediaUrl; %>
            <% if (lpMime.indexOf('pdf') !== -1) { %>
              <iframe class="chat-msg-media chat-msg-media--pdf" title="Vista PDF" src="<%= mediaUrl %>"></iframe>
              <a class="chat-msg-download-link" href="<%= _dlDoc %>">Descargar</a>
              <a class="chat-msg-doc-link" href="<%= mediaUrl %>" target="_blank" rel="noopener noreferrer">Abrir PDF en pestaña nueva</a>
            <% } else { %>
              <a class="chat-msg-download-link" href="<%= _dlDoc %>">Descargar</a>
              <a class="chat-msg-doc-link" href="<%= mediaUrl %>" target="_blank" rel="noopener noreferrer">Abrir en pestaña nueva</a>
            <% } %>
          </div>
        <% } else if (isMediaType(mt) && !mediaUrl) { %>
          <% if (m.direction === 'outbound') { %>
            <p class="chat-msg-fallback">Adjunto enviado (vista previa no guardada: revisa S3 o permisos de escritura en uploads).</p>
          <% } else { %>
            <p class="chat-msg-fallback">No se pudo descargar la vista previa del archivo.</p>
          <% } %>
        <% } %>
        <% const campPreview = mt === 'campaign' && raw && raw.preview ? raw.preview : null; %>
        <% if (campPreview) { %>
          <div class="chat-campaign-preview">
            <% if (campPreview.headerMediaUrl && campPreview.headerMediaType === 'image') { %>
              <div class="chat-campaign-preview__media">
                <img src="<%= campPreview.headerMediaUrl %>" alt="" loading="lazy" decoding="async" />
              </div>
            <% } else if (campPreview.headerMediaType === 'video') { %>
              <div class="chat-campaign-preview__media chat-campaign-preview__media--placeholder">
                <span class="chat-msg-type-icon" aria-hidden="true">🎬</span> Video de cabecera
              </div>
            <% } else if (campPreview.headerMediaType === 'document') { %>
              <div class="chat-campaign-preview__media chat-campaign-preview__media--placeholder">
                <span class="chat-msg-type-icon" aria-hidden="true">📎</span> Documento de cabecera
              </div>
            <% } %>
            <% if (campPreview.headerText) { %>
              <div class="chat-campaign-preview__header"><%- formatWhatsAppHtml(campPreview.headerText) %></div>
            <% } %>
            <% if (campPreview.bodyText) { %>
              <div class="chat-campaign-preview__body"><%- formatWhatsAppHtml(campPreview.bodyText) %></div>
            <% } %>
            <% if (campPreview.footerText) { %>
              <div class="chat-campaign-preview__footer"><%- formatWhatsAppHtml(campPreview.footerText) %></div>
            <% } %>
            <% if (campPreview.buttons && campPreview.buttons.length) { %>
              <div class="chat-campaign-preview__buttons">
                <% campPreview.buttons.forEach(function (btn) { %>
                  <div class="chat-campaign-preview__button">
                    <span class="chat-campaign-preview__button-text"><%= btn.text || 'Botón' %></span>
                    <% if (btn.url) { %>
                      <span class="chat-campaign-preview__button-url" title="<%= btn.url %>"><%- summarizeTemplatePreviewUrl(btn.url) %></span>
                    <% } %>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        <% } else if (m.body_text) { %>
          <div class="chat-bubble__text"><%= m.body_text %></div>
        <% } %>
        <div class="chat-meta">
          <%= m.direction === 'outbound' ? 'Tú' : 'Usuario' %> ·
          <% if (mt === 'campaign' && raw && raw.campaign_id) { %>
            <a class="chat-campaign-ref" href="<%= bp %>/campaigns/<%= raw.campaign_id %>" title="Ver campaña #<%= raw.campaign_id %>">Campaña #<%= raw.campaign_id %></a>
          <% } else { %>
            <%= mediaLabel(mt) || mt %>
          <% } %>
          · <%= formatMessageDateTime(m.created_at) %>
        </div>
        <% if (m.direction === 'outbound') { %>
          <% 
            var _ds = raw && raw.delivery_status;
            var _dso = _ds && (typeof _ds === 'string' ? (function(){ try { return JSON.parse(_ds); } catch (e) { return null; } })() : _ds);
            var _st = _dso && _dso.status ? String(_dso.status).toLowerCase() : '';
            if (!_st && raw && raw.status) _st = String(raw.status).toLowerCase();
            var _dl = 'Enviado (pendiente de confirmación)';
            var _dc = 'chat-delivery--sent';
            if (_st === 'read') { _dl = 'Leído'; _dc = 'chat-delivery--read'; }
            else if (_st === 'delivered') { _dl = 'Entregado'; _dc = 'chat-delivery--delivered'; }
            else if (_st === 'failed' || _st === 'undelivered') { _dl = 'Error de entrega'; _dc = 'chat-delivery--failed'; }
            else if (_st === 'sent') { _dl = 'Enviado a WhatsApp'; _dc = 'chat-delivery--sent'; }
          %>
          <div class="chat-delivery-row <%= _dc %>" title="<%= _dl %>" aria-label="<%= _dl %>">
            <% if (_dc === 'chat-delivery--failed') { %>
              <span class="chat-delivery-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </span>
            <% } else if (_dc === 'chat-delivery--read') { %>
              <span class="chat-delivery-icon chat-delivery-icon--dbl" aria-hidden="true">
                <svg width="18" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12l5 5L22 5"/><path d="M8 12l3 3L22 5"/></svg>
              </span>
            <% } else if (_dc === 'chat-delivery--delivered') { %>
              <span class="chat-delivery-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
            <% } else { %>
              <span class="chat-delivery-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
            <% } %>
            <span class="chat-delivery-label"><%= _dl %></span>
          </div>
        <% } %>
      </div>
    <% }); %>
  </div>
<% } %>
