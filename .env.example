PORT=3000
NODE_ENV=development
# URL publica del panel (sin barra final). Con subruta NPM: https://proyectosti.mali.pe/whatsapp
APP_BASE_URL=http://localhost:3000
# Subruta si Nginx reenvia solo el path interno (location /whatsapp/ + proxy_pass .../). Ej: /whatsapp
# Dejar vacio si sirves el panel en la raiz del subdominio (sin location /whatsapp/)
BASE_PATH=
REQUIRE_AUTH=false
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=cambia_este_password
VERIFY_TOKEN=pon_aqui_un_token_de_verificacion
APP_SECRET=opcional_para_validar_firma_x_hub_signature_256
REQUIRE_WEBHOOK_SIGNATURE=false
WHATSAPP_TOKEN=pon_aqui_tu_token
PHONE_NUMBER_ID=pon_aqui_tu_phone_number_id
DEFAULT_TEMPLATE_NAME=hello_world
DEFAULT_TEMPLATE_LANGUAGE=en_US
TEMPLATES_WITHOUT_COMPONENTS=hello_world
# Valores por defecto de plantilla (el panel Configuracion guarda en BD y tiene prioridad)
# Cuantas variables {{1}}..{{N}} tiene el BODY de tu plantilla en Meta (0 = solo si usas plantillas sin cuerpo)
TEMPLATE_BODY_VARIABLE_COUNT=4
# Si true, {{1}} se toma del nombre del contacto; el formulario rellena {{2}} en adelante
TEMPLATE_BODY_VARIABLE_1_FROM_CONTACT=false
# Etiquetas para cada campo del formulario (mismo orden que {{n}} en Meta)
TEMPLATE_BODY_VARIABLE_LABELS=Fecha y hora del evento,Dirección completa,Link RSVP,Nota o recordatorio
DEFAULT_BATCH_SIZE=40
DEFAULT_BATCH_DELAY_MS=1500
RATE_LIMIT_MAX=300
CAMPAIGN_RATE_LIMIT_MAX=5
# Max importaciones CSV por hora e IP (panel)
CONTACTS_IMPORT_RATE_MAX=30
POSTGRES_DB=mali_whatsapp
POSTGRES_USER=mali_user
POSTGRES_PASSWORD=cambia_esta_clave
DATABASE_URL=postgresql://mali_user:cambia_esta_clave@postgres:5432/mali_whatsapp
