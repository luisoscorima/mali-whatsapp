# =============================================================================
# Mali WhatsApp MVP — plantilla de entorno
# Copia y edita:  cp .env.example .env
# No subas .env a Git. En producción, tras cambios, recrea el contenedor app.
# =============================================================================

# --- Servidor ---
PORT=3000
# development | production
NODE_ENV=development

# URL pública que ven usuarios y Meta (sin barra final).
# Local: http://localhost:3000  |  Producción: https://whatsapp.mali.pe
APP_BASE_URL=http://localhost:3000
# Vacío si la app está en la raíz del dominio (recomendado con subdominio dedicado).
BASE_PATH=

# Zona horaria IANA para fechas/horas en el panel (listas de chat, mensajes, exportaciones). Por defecto Lima.
# DISPLAY_TIMEZONE=America/Lima

# Días de retención de la tabla audit_logs (borrado de filas más antiguas al arrancar y cada 24 h). Por defecto 30; máx. 365.
# AUDIT_LOG_RETENTION_DAYS=30

# --- Autenticación del panel ---
# Producción: REQUIRE_AUTH=true y SESSION_SECRET largo y aleatorio (no uses "123456").
REQUIRE_AUTH=false
SESSION_SECRET=
# Solo si REQUIRE_AUTH=false (dev): área simulada ti | pam | patronato | educacion | educacion_ca | educacion_ep
DEV_AREA=ti
# Opcional, solo primer arranque para crear usuario master; luego quítalo del servidor.
# MASTER_INITIAL_PASSWORD=

# --- Webhook Meta (WhatsApp → tu servidor) ---
# VERIFY_TOKEN: el mismo texto que "Token de verificación" en Meta → WhatsApp → Webhook.
# Si tiene +, =, # o espacios, usa SIEMPRE comillas dobles (si no, + en URL puede romper pruebas con curl).
# Ejemplo: VERIFY_TOKEN="mi_secreto+verif="
VERIFY_TOKEN=
# APP_SECRET: Configuración de la app → Básica → Clave secreta (cadena completa).
META_APP_ID=906465795346761
APP_SECRET=
# Producción recomendado: true (valida X-Hub-Signature-256 con el cuerpo RAW del POST).
REQUIRE_WEBHOOK_SIGNATURE=false
# true = una línea de log por cada change del POST con estructura (entryId, field, counts); quitar tras diagnosticar.
WEBHOOK_DEBUG=false

# --- Respuesta automática (Groq OpenAI API, llama-3.1-8b-instant) ---
# Sin clave, el webhook no invoca la IA (solo persiste mensajes entrantes).
GROQ_API_KEY=

# --- WhatsApp Cloud API (envío / plantillas) — áreas: TI, PAM, Patronato, Educación, Educación CA, Educación EP ---
# Prioridad: valores en Admin → Credenciales Meta (BD) > variables aquí.
# PAM = línea comercial nueva. Patronato = número e historial anteriores (ex PAM).
# Educación / CA / EP: pueden compartir el mismo WABA y token en Meta; Phone number ID distinto por área.
# Token: Business Manager → usuario del sistema → token con permisos WhatsApp (o API Setup).
WHATSAPP_TOKEN_TI=
PHONE_NUMBER_ID_TI=
WHATSAPP_TOKEN_PAM=
PHONE_NUMBER_ID_PAM=
WHATSAPP_TOKEN_PATRONATO=
PHONE_NUMBER_ID_PATRONATO=
WHATSAPP_TOKEN_EDUCACION=
PHONE_NUMBER_ID_EDUCACION=
WHATSAPP_TOKEN_EDUCACION_CA=
PHONE_NUMBER_ID_EDUCACION_CA=
WHATSAPP_TOKEN_EDUCACION_EP=
PHONE_NUMBER_ID_EDUCACION_EP=
# Respaldo genérico si falta un sufijo por área
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=

# Opcional: WABA para sincronizar plantillas / resolver webhook cuando no hay phone_number_id en metadata
# WABA_ID_TI=
# WABA_ID_PAM=
# WABA_ID_PATRONATO=
# WABA_ID_EDUCACION=
# WABA_ID_EDUCACION_CA=
# WABA_ID_EDUCACION_EP=
# Respaldo genérico
# WABA_ID=

# --- PostgreSQL (Docker Compose: host del servicio = postgres) ---
POSTGRES_DB=mali_whatsapp
POSTGRES_USER=mali_user
POSTGRES_PASSWORD=cambia_esta_clave
# IMPORTANTE: si la contraseña contiene @, :, / u otros reservados en URL,
# codifícalos en DATABASE_URL (ej. @ → %40, : → %3A).
# Ejemplo contraseña "p@ss": postgresql://mali_user:p%40ss@postgres:5432/mali_whatsapp
DATABASE_URL=postgresql://mali_user:cambia_esta_clave@postgres:5432/mali_whatsapp

# AWS S3 — vista previa de adjuntos en conversaciones (subida PutObject).
# Si ACCESS_KEY_S3 y SECRET_KEY_S3 están vacíos, se usa almacenamiento local (public/uploads/chat-media).
ACCESS_KEY_S3=
SECRET_KEY_S3=
BUCKET_NAME="mali-assets"
CARPETA="assets-whatsapp-mali"
# Región del bucket (debe coincidir con la del bucket en la consola AWS).
AWS_REGION=us-east-1
# URL pública opcional (sin barra final): CloudFront u otro CDN. Si está vacío, la app usa
# https://{BUCKET}.s3.{AWS_REGION}.amazonaws.com/{CARPETA}/chat-media/...
# S3_PUBLIC_URL_BASE=https://dxxxxxxxx.cloudfront.net
S3_PUBLIC_URL_BASE=
# Si PutObject falla (IAM, región, ACL), guardar igual en disco (volumen Docker). false = solo S3, sin fallback.
S3_CHAT_MEDIA_FALLBACK_DISK=true
# Solo si el bucket permite ACL de objetos: public-read (muchos buckets nuevos lo bloquean; usa política de bucket).
# S3_CHAT_MEDIA_ACL=public-read
#
# Reintento automático de envíos fallidos en campañas (minutos tras completed; intentos por teléfono; máx. manuales).
# CAMPAIGN_AUTO_RETRY_DELAY_MINUTES=10
# CAMPAIGN_MAX_RETRY_ATTEMPTS=2
# CAMPAIGN_MAX_MANUAL_RETRIES=3
#
# KPI «respondieron» en detalle de campaña (días tras el envío).
# CAMPAIGN_RESPONSE_WINDOW_DAYS=7
#
# Costo estimado por mensaje entregado (USD) si Meta no devuelve analytics WABA.
# CAMPAIGN_COST_PER_MESSAGE_USD=0.05
#
# Para que el navegador cargue la imagen desde S3 sin firmar URLs, el objeto debe ser legible públicamente, p. ej. política:
# { "Effect":"Allow", "Principal":"*", "Action":"s3:GetObject",
#   "Resource":"arn:aws:s3:::TU_BUCKET/TU_CARPETA/chat-media/*" }
