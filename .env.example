# Copia a .env: cp .env.example .env
# Variables opcionales (plantillas, lotes, rate limits): valores por defecto en app/server.js y panel Configuracion.

PORT=3000
NODE_ENV=development

APP_BASE_URL=http://localhost:3000
BASE_PATH=

REQUIRE_AUTH=false
SESSION_SECRET=
DEV_AREA=pam
# MASTER_INITIAL_PASSWORD=clave_solo_primer_arranque

VERIFY_TOKEN=
APP_SECRET=
REQUIRE_WEBHOOK_SIGNATURE=false

WHATSAPP_TOKEN_PAM=
PHONE_NUMBER_ID_PAM=
WHATSAPP_TOKEN_EDUCACION=
PHONE_NUMBER_ID_EDUCACION=
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=

# Opcional: ID de WhatsApp Business Account (para sincronizar plantillas). Si falla la detección automática desde PHONE_NUMBER_ID, cópialo de WhatsApp Manager (cuenta del API) o de Meta Business Suite.
# WABA_ID_PAM=
# WABA_ID_EDUCACION=

POSTGRES_DB=mali_whatsapp
POSTGRES_USER=mali_user
POSTGRES_PASSWORD=cambia_esta_clave
DATABASE_URL=postgresql://mali_user:cambia_esta_clave@postgres:5432/mali_whatsapp
